---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;

const pageTitle = title;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Prevent indexing of deck pages -->
    <meta name="robots" content="noindex, nofollow" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&family=Questrial&family=Roboto+Mono:wght@300&display=swap"
      rel="stylesheet"
    />

    <title>{pageTitle} | Aura Vision</title>

    <style is:global>
      /* ── Deck slide system ───────────────────────────────── */
      html, body {
        margin: 0;
        padding: 0;
        background: #020309; /* near-black outside slide area */
        width: 100vw;
        height: 100vh;
        overflow: hidden;
      }

      /* Scale all rem-based sizes proportionally to the deck width.
         At 1920px → 16px (default). Smaller/larger viewports scale linearly. */
      html {
        font-size: calc(min(100vw, 100vh * 16 / 9) / 120);
      }

      body {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .deck {
        position: relative;
        /* Fit the largest 16:9 box inside the viewport */
        width: min(100vw, calc(100vh * 16 / 9));
        height: min(100vh, calc(100vw * 9 / 16));
        overflow: hidden;
        flex-shrink: 0;
        border-radius: 2px;
        box-shadow: 0 0 80px rgba(0, 0, 0, 0.6);
      }

      /* ── Scroll mode (all slides stacked vertically) ──── */
      html.scroll-mode,
      html.scroll-mode body {
        height: auto;
        overflow-x: hidden;
        overflow-y: auto;
        scrollbar-gutter: stable;
      }

      html.scroll-mode .deck {
        width: 100%;
        height: auto;
        overflow: visible;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1rem;
        box-sizing: border-box;
        box-shadow: none;
      }

      html.scroll-mode .deck > section {
        position: relative;
        opacity: 1;
        pointer-events: auto;
        width: 100%;
        aspect-ratio: 16 / 9;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.5rem;
        overflow: hidden;
        flex-shrink: 0;
      }

      /* ── Print / PDF styles ──────────────────────────────── */
      @media print {
        html {
          font-size: calc(13.333in / 120);
        }
        html, body {
          width: 13.333in;
          height: auto;
          margin: 0;
          padding: 0;
          background: #0a0f1e !important;
          -webkit-print-color-adjust: exact !important;
          print-color-adjust: exact !important;
          color-adjust: exact !important;
          overflow: visible;
          display: block;
        }

        .deck {
          position: static;
          width: 13.333in;
          height: auto;
          overflow: visible;
          border-radius: 0;
          box-shadow: none;
        }

        .deck > section {
          position: relative;
          opacity: 1;
          pointer-events: auto;
          width: 13.333in;
          height: 7.5in;
          min-height: 7.5in;
          max-height: 7.5in;
          background: #0a0f1e !important;
          page-break-after: always;
          break-after: page;
          page-break-inside: avoid;
          break-inside: avoid;
          overflow: hidden;
          box-sizing: border-box;
        }

        .deck > section:last-child {
          page-break-after: avoid;
          break-after: avoid;
        }

        .deck-controls,
        #progress,
        .print\\:hidden {
          display: none !important;
        }

        /* Force background colors/images to print */
        * {
          -webkit-print-color-adjust: exact !important;
          print-color-adjust: exact !important;
        }
      }
    </style>

    <!-- @page must be in an is:inline style to avoid Tailwind/Vite stripping it -->
    <style is:inline>
      @page {
        size: 13.333in 7.5in;
        margin: 0;
      }
    </style>
  </head>

  <body class="bg-[#020309] overflow-hidden">
    <div class="deck" id="deck">
      <slot />
    </div>

    <!-- Controls -->
    <div class="deck-controls fixed bottom-4 right-4 z-50 flex items-center gap-2 print:hidden">
      <!-- Slide counter -->
      <span id="slide-counter" class="text-white/20 text-xs font-mono mr-1"></span>

      <!-- PDF button -->
      <button
        id="pdf-btn"
        title="Print to PDF"
        class="flex items-center gap-1.5 rounded-full bg-white/5 border border-white/10 px-3 py-1.5 text-xs text-white/30 font-mono backdrop-blur-sm cursor-pointer hover:bg-white/10 hover:text-white/60 transition-all duration-300"
      >
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
        PDF
      </button>

      <!-- Fullscreen button -->
      <button
        id="fs-btn"
        title="Toggle fullscreen"
        class="flex items-center gap-1.5 rounded-full bg-white/5 border border-white/10 px-3 py-1.5 text-xs text-white/30 font-mono backdrop-blur-sm cursor-pointer hover:bg-white/10 hover:text-white/60 transition-all duration-300"
      >
        <svg id="fs-icon-expand" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 3 21 3 21 9" />
          <polyline points="9 21 3 21 3 15" />
          <line x1="21" y1="3" x2="14" y2="10" />
          <line x1="3" y1="21" x2="10" y2="14" />
        </svg>
        <svg id="fs-icon-shrink" class="h-3.5 w-3.5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="4 14 10 14 10 20" />
          <polyline points="20 10 14 10 14 4" />
          <line x1="14" y1="10" x2="21" y2="3" />
          <line x1="3" y1="21" x2="10" y2="14" />
        </svg>
      </button>
    </div>

    <!-- Progress bar -->
    <div class="fixed bottom-0 left-0 right-0 h-[2px] bg-white/5 z-50 print:hidden">
      <div id="progress" class="h-full bg-cyan-400/40 transition-all duration-200" style="width: 0%"></div>
    </div>

    <script>
      const isScrollMode = new URLSearchParams(window.location.search).has('scroll');
      if (isScrollMode) document.documentElement.classList.add('scroll-mode');

      const deck = document.getElementById("deck")!;
      const slides = Array.from(deck.querySelectorAll<HTMLElement>(":scope > section"));
      const counter = document.getElementById("slide-counter")!;
      const progress = document.getElementById("progress")!;
      const total = slides.length;
      let current = 0;

      // Read initial slide from hash
      const hashMatch = window.location.hash.match(/^#(\d+)$/);
      if (hashMatch) {
        const idx = parseInt(hashMatch[1], 10) - 1;
        if (idx >= 0 && idx < total) current = idx;
      }

      function showSlide(index: number) {
        if (index < 0 || index >= total) return;
        slides[current].classList.remove("active");
        current = index;
        slides[current].classList.add("active");
        counter.textContent = `${current + 1} / ${total}`;
        progress.style.width = `${((current + 1) / total) * 100}%`;
        window.location.hash = `#${current + 1}`;
      }

      // Initialize
      if (isScrollMode) {
        // In scroll mode all slides are visible; hide nav UI
        slides.forEach(s => s.classList.add('active'));
        counter.style.display = 'none';
        document.querySelector('.deck-controls')?.setAttribute('style', 'display:none');
        document.querySelector('#progress')?.parentElement?.setAttribute('style', 'display:none');
      } else {
        showSlide(current);
      }

      // Keyboard navigation
      document.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight" || e.key === "ArrowDown" || e.key === " ") {
          e.preventDefault();
          showSlide(current + 1);
        } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
          e.preventDefault();
          showSlide(current - 1);
        } else if (e.key === "Home") {
          e.preventDefault();
          showSlide(0);
        } else if (e.key === "End") {
          e.preventDefault();
          showSlide(total - 1);
        }
      });

      // PDF
      document.getElementById("pdf-btn")?.addEventListener("click", () => {
        window.print();
      });

      // Fullscreen
      const fsBtn = document.getElementById("fs-btn")!;
      const fsExpand = document.getElementById("fs-icon-expand")!;
      const fsShrink = document.getElementById("fs-icon-shrink")!;

      fsBtn.addEventListener("click", () => {
        if (!document.fullscreenElement) {
          document.documentElement.requestFullscreen();
        } else {
          document.exitFullscreen();
        }
      });

      document.addEventListener("fullscreenchange", () => {
        const isFs = !!document.fullscreenElement;
        fsExpand.classList.toggle("hidden", isFs);
        fsShrink.classList.toggle("hidden", !isFs);
      });
    </script>
  </body>
</html>
