---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Aura Vision — Your in-store AI analyst, no new sensors needed.",
  ogImage = "/og-default.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Fonts: Questrial (titles) + Open Sans (body) + Space Mono (labels) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&family=Questrial&family=Roboto+Mono:wght@300&display=swap"
      rel="stylesheet"
    />

    <title>{title} | Aura Vision</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Aura Vision`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

  </head>
  <body class="min-h-screen bg-slate-900 text-white antialiased">
    <slot />

    <script>
      import netlifyIdentity from "netlify-identity-widget";

      netlifyIdentity.init();

      const hash = window.location.hash;
      const isAuthRedirect =
        hash.includes("confirmation_token") ||
        hash.includes("recovery_token") ||
        hash.includes("invite_token");

      netlifyIdentity.on("init", (user: ReturnType<typeof netlifyIdentity.currentUser>) => {
        if (!user && isAuthRedirect) {
          netlifyIdentity.open();
        }
        if (!user) {
          netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    </script>
  </body>
</html>
