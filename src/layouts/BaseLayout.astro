---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Aura Vision — Your in-store AI analyst, no new sensors needed.",
  ogImage = "/og-default.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Fonts: Questrial (titles) + Open Sans (body) + Roboto Mono (labels) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&family=Questrial&family=Roboto+Mono:wght@300&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&family=Questrial&family=Roboto+Mono:wght@300&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&family=Questrial&family=Roboto+Mono:wght@300&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <title>{title} | Aura Vision</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Aura Vision`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:site_name" content="Aura Vision" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Aura Vision`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <!-- Structured Data -->
    <slot name="head" />

    <!-- Google Analytics (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JWFF6CDCHE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JWFF6CDCHE');
    </script>

    <!-- HubSpot Tracking -->
    <script type="text/javascript" id="hs-script-loader" async defer src="//js.hs-scripts.com/4084500.js"></script>

  </head>
  <body class="min-h-screen bg-slate-900 text-white antialiased">
    <slot />

    <script>
      // Only load Netlify Identity widget on admin pages or auth redirects
      const hash = window.location.hash;
      const isAuthRedirect =
        hash.includes("confirmation_token") ||
        hash.includes("recovery_token") ||
        hash.includes("invite_token");
      const isAdmin = window.location.pathname.startsWith("/admin");

      if (isAdmin || isAuthRedirect) {
        import("netlify-identity-widget").then(({ default: netlifyIdentity }) => {
          netlifyIdentity.init();
          netlifyIdentity.on("init", (user: ReturnType<typeof netlifyIdentity.currentUser>) => {
            if (!user && isAuthRedirect) {
              netlifyIdentity.open();
            }
            if (!user) {
              netlifyIdentity.on("login", () => {
                document.location.href = "/admin/";
              });
            }
          });
        });
      }
    </script>
  </body>
</html>
