---
import ContactFormFields from "./ContactFormFields.astro";

interface Props {
  headingLevel?: 'h1' | 'h2';
  title?: string;
  subtitle?: string;
}

const { headingLevel = 'h2', title = 'Get in touch', subtitle = "Whether you're ready for a demo or just exploring, we'd love to hear from you." } = Astro.props;
const Heading = headingLevel;
---

<section id="contact" class="section-major relative overflow-hidden">
  <!-- Cyan-purple gradient background -->
  <div class="absolute inset-0 bg-gradient-to-r from-slate-800 via-purple-950 to-fuchsia-500"></div>
  <div class="absolute inset-0 backdrop-blur-3xl"></div>

  <div class="relative container-site">
    <div class="grid gap-16 lg:grid-cols-2 lg:gap-24 items-start">
      <!-- Left: Heading -->
      <div class="flex flex-col">
        <Heading class="heading-section text-gradient" data-text={title}>
          {title}
        </Heading>
        <p class="mt-6 text-xl text-white/80 md:text-2xl">
          {subtitle}
        </p>
      </div>

      <!-- Right: Form -->
      <div>
        <ContactFormFields />
      </div>
    </div>
  </div>
</section>
