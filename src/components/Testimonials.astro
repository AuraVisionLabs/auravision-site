---
import TestimonialCard from "./TestimonialCard.astro";

const testimonials = [
  {
    headliner: "The data and insights we gain from Aura Vision are a game changer",
    quote: "They give us a deeper understanding of our customers, which helps shape our strategy, and enables faster, smarter decision-making.",
    name: "Carly Atherton",
    role: "Head of Multichannel\nOperations Development",
    company: "Virgin Media O2",
    photo: "/images/carly.png",
    logo: "/images/logos/vmo2.svg",
  },
  {
    headliner: "This proves how impactful Aura Vision is as a tool",
    quote: "It not only validates our strategies but also gives us the confidence to make data-driven decisions that ultimately grow the business.",
    name: "Samantha Turner",
    role: "Business Transformation\nManager",
    company: "Adidas",
    photo: "/images/samantha.png",
    logo: "/images/logos/adidas.svg",
  },
  {
    headliner: "Aura Vision is our secret weapon",
    quote: "Being able to segment our staff from our customers meant the accuracy of our conversion reporting went up 24%, leading us to make smarter decisions.",
    name: "Tres White",
    role: "Purple Innovation",
    company: "Purple",
    photo: "/images/tres.png",
    logo: "/images/logos/purple.svg",
  },
  {
    headliner: "Simplicity and ease of integration",
    quote: "I really like the simplicity and ease of integration with our existing camera system, which basically every store has.",
    name: "Frenkel Tel",
    role: "Store Innovation Lead",
    company: "A.S. Watson (Kruidvat)",
    photo: "/images/frenkel.jpg",
    logo: "/images/logos/aswatson.png",
  },
];
---

<section class="section-major">
  <div class="container-site">
    <div class="text-center mb-16">
      <h2 class="heading-section">
        <span class="text-gradient block mx-auto" data-text="Our clients have">Our clients have</span>
        <span class="text-gradient block mx-auto" data-text="a thing or two to say...">a thing or two to say...</span>
      </h2>
    </div>
  </div>

  <div class="relative overflow-hidden">
    <!-- Fade edges -->
    <div class="pointer-events-none absolute left-0 top-0 bottom-0 z-10 w-32 bg-gradient-to-r from-slate-900 to-transparent"></div>
    <div class="pointer-events-none absolute right-0 top-0 bottom-0 z-10 w-32 bg-gradient-to-l from-slate-900 to-transparent"></div>

    <div id="testimonials-track" class="flex items-stretch gap-8 pb-4" style="overflow: visible;">
      {/* Triple the cards for seamless infinite scroll */}
      {[...testimonials, ...testimonials, ...testimonials].map(({ headliner, quote, name, role, company, photo, logo }) => (
        <div class="testimonial-card w-[calc(100vw-3rem)] sm:w-[420px] flex-shrink-0 flex">
          <TestimonialCard
            headliner={headliner}
            quote={quote}
            name={name}
            role={role}
            photo={photo}
            logo={logo}
            company={company}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const track = document.getElementById("testimonials-track")!;
  const container = track.parentElement!;
  const cards = track.querySelectorAll<HTMLElement>(".testimonial-card");
  const totalOriginal = cards.length / 3; // we tripled the cards
  const gap = 32; // gap-8 = 2rem = 32px
  let autoScrollTimer: ReturnType<typeof setInterval>;

  function getCardWidth() {
    return cards[0].offsetWidth + gap;
  }

  // Centre the first card of the middle set initially
  function centreCard(index: number) {
    const cardWidth = getCardWidth();
    const viewportWidth = window.innerWidth;
    const offset = index * cardWidth - (viewportWidth - cards[0].offsetWidth) / 2;
    track.style.transform = `translateX(${-offset}px)`;
  }

  // Start from the middle set so we can scroll both directions
  let currentIndex = totalOriginal;
  centreCard(currentIndex);

  // Silently normalize currentIndex into Set B before animating
  function wrapIndex() {
    if (currentIndex >= totalOriginal * 2) {
      track.style.transition = "none";
      currentIndex -= totalOriginal;
      centreCard(currentIndex);
      // Force reflow so the jump is painted before the animation
      void track.offsetHeight;
    } else if (currentIndex < totalOriginal) {
      track.style.transition = "none";
      currentIndex += totalOriginal;
      centreCard(currentIndex);
      void track.offsetHeight;
    }
  }

  function advance() {
    wrapIndex();
    currentIndex++;
    track.style.transition = "transform 0.7s cubic-bezier(0.4, 0, 0.2, 1)";
    centreCard(currentIndex);
  }

  // --- Drag handling ---
  let isDragging = false;
  let startX = 0;
  let dragOffset = 0;
  let currentTranslateX = 0;

  function getTranslateX(): number {
    const style = getComputedStyle(track);
    const matrix = new DOMMatrixReadOnly(style.transform);
    return matrix.m41;
  }

  function onDragStart(x: number) {
    isDragging = true;
    startX = x;
    currentTranslateX = getTranslateX();
    track.style.transition = "none";
    clearInterval(autoScrollTimer);
    container.style.cursor = "grabbing";
  }

  function onDragMove(x: number) {
    if (!isDragging) return;
    dragOffset = x - startX;
    track.style.transform = `translateX(${currentTranslateX + dragOffset}px)`;
  }

  function onDragEnd() {
    if (!isDragging) return;
    isDragging = false;
    container.style.cursor = "grab";

    const cardWidth = getCardWidth();
    const threshold = cardWidth * 0.2;

    if (dragOffset < -threshold) {
      currentIndex++;
    } else if (dragOffset > threshold) {
      currentIndex--;
    }

    // Silently wrap before animating so there's no visible jump
    wrapIndex();

    track.style.transition = "transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)";
    centreCard(currentIndex);

    dragOffset = 0;
    autoScrollTimer = setInterval(advance, 4000);
  }

  // Mouse events
  container.style.cursor = "grab";
  container.addEventListener("mousedown", (e) => {
    e.preventDefault();
    onDragStart(e.clientX);
  });
  window.addEventListener("mousemove", (e) => onDragMove(e.clientX));
  window.addEventListener("mouseup", () => onDragEnd());

  // Touch events
  container.addEventListener("touchstart", (e) => {
    onDragStart(e.touches[0].clientX);
  }, { passive: true });
  container.addEventListener("touchmove", (e) => {
    onDragMove(e.touches[0].clientX);
  }, { passive: true });
  container.addEventListener("touchend", () => onDragEnd());

  // Pause on hover (non-drag)
  container.addEventListener("mouseenter", () => clearInterval(autoScrollTimer));
  container.addEventListener("mouseleave", () => {
    if (!isDragging) {
      autoScrollTimer = setInterval(advance, 4000);
    }
  });

  // Re-centre on resize
  window.addEventListener("resize", () => centreCard(currentIndex));

  autoScrollTimer = setInterval(advance, 4000);
</script>
