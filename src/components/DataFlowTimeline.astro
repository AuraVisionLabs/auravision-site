---
/**
 * A vertical timeline for sequential data-flow steps.
 *
 * Props:
 *  - steps: Array of { title: string; body: string }
 */

interface Step {
  title: string;
  body: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<div class="relative ml-4 border-l-2 border-blue-200 pl-8 space-y-12">
  {steps.map((step, i) => (
    <div class="relative">
      {/* Numbered dot on the timeline */}
      <div class="absolute -left-[2.85rem] top-0 flex h-10 w-10 items-center justify-center rounded-full bg-blue-600 text-white text-sm font-title font-medium shadow-md ring-4 ring-white">
        {i + 1}
      </div>
      <div class="pt-1">
        <h3 class="font-title text-lg font-medium text-slate-900 mb-2">{step.title}</h3>
        <p class="text-sm leading-relaxed text-slate-600">{step.body}</p>
      </div>
    </div>
  ))}
</div>
