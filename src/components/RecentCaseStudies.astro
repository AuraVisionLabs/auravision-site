---
import { getCollection } from "astro:content";
import { ArrowRight } from "@lucide/astro";

const studies = await getCollection("case-studies");
const recent = studies
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2);
---

<section class="py-24 md:py-32 px-6 md:px-12">
  <div class="mx-auto max-w-site">
    <!-- Header -->
    <div class="mb-14 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <h2 class="font-title text-3xl md:text-5xl tracking-tight leading-tight text-gradient" data-text="Customer Stories">
          Customer Stories
        </h2>
      </div>
      <a href="/case-studies" class="group shrink-0 self-start md:self-auto inline-flex items-center gap-2 text-lg font-medium text-cyan-300 transition-colors hover:text-purple-300">
        See all posts
        <ArrowRight class="h-5 w-5 text-cyan-500 transition-colors group-hover:text-purple-300" stroke-width={2} />
      </a>
    </div>

    <!-- Cards -->
    <div class="grid gap-8 md:grid-cols-2">
      {
        recent.map((study) => (
          <a
            href={`/case-studies/${study.slug}`}
            class="group rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm overflow-hidden transition-all hover:border-white/10 hover:bg-white/[0.05]"
          >
            {study.data.coverImage && (
              <div class="aspect-video overflow-hidden bg-white/5">
                <img
                  src={study.data.coverImage}
                  alt={study.data.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-6">
              <p class="text-xs uppercase tracking-widest text-white/40 mb-2">
                {study.data.client}
              </p>
              <h3 class="font-title text-xl tracking-tight mb-3 group-hover:text-accent transition-colors">
                {study.data.title}
              </h3>
              <p class="text-sm text-white/50 leading-relaxed line-clamp-3 mb-4">
                {study.data.summary}
              </p>

              {study.data.metrics && study.data.metrics.length > 0 && (
                <div class="flex flex-wrap gap-3 mb-4">
                  {study.data.metrics.slice(0, 3).map((metric) => (
                    <span class="text-xs px-3 py-1.5 rounded-full border border-white/5 bg-white/[0.03] text-white/60">
                      <span class="font-semibold text-accent">{metric.value}</span>{" "}
                      {metric.label}
                    </span>
                  ))}
                </div>
              )}

              <span class="inline-flex items-center gap-1.5 text-sm text-white/40 group-hover:text-accent transition-colors">
                Read story
                <ArrowRight class="w-3.5 h-3.5" />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
