---
import { getCollection } from "astro:content";
import { ArrowRight } from "@lucide/astro";
import CaseStudyCard from "./CaseStudyCard.astro";

const studies = await getCollection("case-studies");
const recent = studies
  .sort((a, b) => (a.data.sortOrder ?? 999) - (b.data.sortOrder ?? 999) || b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 4);
---

<section class="section-major">
  <div class="container-site">
    <!-- Header -->
    <div class="mb-14 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <h2 class="heading-section text-gradient" data-text="Customer Stories">
          Customer Stories
        </h2>
      </div>
      <a href="/case-studies" class="btn-pill shrink-0 self-start md:self-auto">
        See all stories
        <ArrowRight class="h-4 w-4" stroke-width={2} />
      </a>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-2 gap-3 md:gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        recent.map((study, i) => (
          <CaseStudyCard
            slug={study.slug}
            title={study.data.title}
            client={study.data.client}
            clientLogo={study.data.clientLogo}
            summary={study.data.summary}
            coverImage={study.data.coverImage}
            class={i === 3 ? "lg:hidden" : ""}
          />
        ))
      }
    </div>
  </div>
</section>
