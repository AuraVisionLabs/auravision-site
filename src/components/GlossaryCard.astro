---
import { ArrowRight } from "@lucide/astro";

interface Props {
  slug: string;
  title: string;
  description: string;
  category: string;
  headingLevel?: "h2" | "h3";
  class?: string;
}

const {
  slug,
  title,
  description,
  category,
  headingLevel = "h3",
  class: className,
} = Astro.props;

const Heading = headingLevel;

const categoryColors: Record<string, string> = {
  analytics: "bg-cyan-500/10 text-cyan-400",
  technology: "bg-violet-500/10 text-violet-400",
  privacy: "bg-emerald-500/10 text-emerald-400",
  operations: "bg-amber-500/10 text-amber-400",
};

const colorClass = categoryColors[category] ?? "bg-white/10 text-white/60";
---

<a
  data-fade
  href={`/glossary/${slug}`}
  class:list={[
    "group flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-sm overflow-hidden transition-all duration-300 hover:border-cyan-400/30 hover:bg-white/[0.06] hover:shadow-[0_0_40px_rgba(8,145,178,1.0)] p-6",
    className,
  ]}
>
  <div class="flex items-center gap-3 mb-3">
    <span class:list={["text-xs font-medium px-3 py-1 rounded-full capitalize", colorClass]}>
      {category}
    </span>
  </div>

  <Heading class="font-title text-xl tracking-tight mb-3 text-white group-hover:text-accent transition-colors duration-300">
    {title}
  </Heading>

  <p class="text-sm text-white/50 leading-relaxed mb-5 line-clamp-3">
    {description}
  </p>

  <div class="mt-auto">
    <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-accent opacity-0 translate-y-1 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
      Read definition
      <ArrowRight class="w-4 h-4" />
    </span>
  </div>
</a>
