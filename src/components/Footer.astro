---
const currentYear = new Date().getFullYear();
---

<footer class="">
  <!-- Main footer -->
  <div class="bg-white">
    <div class="border-t border-slate-200">
      <div class="mx-auto max-w-site px-6 py-16 lg:px-8">
        <div class="flex flex-col gap-12 lg:flex-row lg:justify-between">
          <!-- Left: nav columns -->
          <div class="flex flex-wrap gap-16 font-title text-sm tracking-[0.05em]">
            <div class="flex flex-col gap-3">
              <p class="font-medium text-slate-900 uppercase tracking-widest text-lg mb-1">
                Aura Vision
              </p>
              <a href="/case-studies" class="text-slate-500 hover:text-slate-900 transition-colors">Case Studies</a>
              <a href="/blog" class="text-slate-500 hover:text-slate-900 transition-colors">Blog</a>
              <a href="/press" class="text-slate-500 hover:text-slate-900 transition-colors">Press</a>
              <a href="https://support.auravision.ai" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-slate-900 transition-colors">Help Center</a>
              <a href="/about" class="text-slate-500 hover:text-slate-900 transition-colors">About</a>
              <a href="/contact" class="text-slate-500 hover:text-slate-900 transition-colors">Contact</a>
            </div>
            <div class="flex flex-col gap-3">
              <p class="font-medium text-slate-900 uppercase tracking-widest text-lg mb-1">
                Trust &amp; Legal
              </p>
              <a href="/security" class="text-slate-500 hover:text-slate-900 transition-colors">Security</a>
              <a href="/product-privacy" class="text-slate-500 hover:text-slate-900 transition-colors">Privacy</a>
              <a href="/privacy" class="text-slate-500 hover:text-slate-900 transition-colors">Privacy Notice</a>
              <a href="/data-processing-addendum" class="text-slate-500 hover:text-slate-900 transition-colors">Data Processing Addendum</a>
              <a href="https://status.auravision.ai/" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-slate-900 transition-colors">System Status</a>
            </div>
          </div>

          <!-- Right: logo + tagline -->
          <div class="flex flex-col items-start lg:items-end">
            <img
              src="/images/aura-vision-logo-dark-tag.svg"
              alt="Aura Vision - Instant answers. Faster decisions."
              class="h-14 md:h-20 w-auto"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-slate-200">
      <div class="mx-auto max-w-site px-6 py-6 lg:px-8 text-xs text-slate-400">
        <p>&copy; {currentYear} Aura Vision. All rights reserved.</p>
      </div>
    </div>
  </div>
</footer>
