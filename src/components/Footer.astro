---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-white/10">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
    <div class="flex flex-col gap-12 md:flex-row md:justify-between">
      <!-- Left: logo + tagline -->
      <div class="flex flex-col gap-4">
        <img
          src="/images/aura-vision-wordmark.svg"
          alt="Auravision"
          class="h-5 w-auto self-start"
        />
        <p class="text-sm text-white/40 max-w-xs">
          AI-powered retail intelligence. Anonymous, scalable, secure.
        </p>
      </div>

      <!-- Right: nav columns -->
      <div class="flex gap-16 text-sm">
        <div class="flex flex-col gap-3">
          <p class="font-medium text-white/70 uppercase tracking-wider text-xs mb-1">Company</p>
          <a href="/#about" class="text-white/40 hover:text-white transition-colors">About</a>
          <a href="/#case-studies" class="text-white/40 hover:text-white transition-colors">Case Studies</a>
          <a href="/contact" class="text-white/40 hover:text-white transition-colors">Contact</a>
        </div>
        <div class="flex flex-col gap-3">
          <p class="font-medium text-white/70 uppercase tracking-wider text-xs mb-1">Connect</p>
          <a
            href="mailto:hello@auravision.ai"
            class="text-white/40 hover:text-white transition-colors"
          >
            hello@auravision.ai
          </a>
          <a
            href="https://linkedin.com/company/auravision"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/40 hover:text-white transition-colors"
          >
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 border-t border-white/10 pt-8 text-xs text-white/30">
      <p>&copy; {currentYear} Auravision. All rights reserved.</p>
    </div>
  </div>
</footer>
