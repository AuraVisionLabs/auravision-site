---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  linkText?: string;
  linkHref?: string;
  reversed?: boolean;
}

const {
  title,
  subtitle,
  description,
  linkText,
  linkHref = "/contact",
  reversed = false,
} = Astro.props;
---

<section class="section-major">
  <div class="container-site">
    <div class="grid items-center gap-16 md:grid-cols-2">
      <div class:list={[reversed && "order-1 md:order-2"]}>
        <h2 class="heading-section leading-tight text-gradient" data-text={title}>
          {title}
        </h2>
        <p class="mt-4 text-xl text-white font-medium md:text-2xl">
          {subtitle}
        </p>
        <p class="mt-6 text-body" set:html={description}>
        </p>
        {linkText && (
          <a href={linkHref} class="btn-pill mt-8">
            {linkText}
          </a>
        )}
      </div>
      <div class:list={[reversed && "order-2 md:order-1"]}>
        <slot name="visual">
          <div class="flex items-center justify-center glass-card aspect-video">
            <p class="text-sm text-white/20">Visual coming soon</p>
          </div>
        </slot>
      </div>
    </div>
  </div>
</section>
