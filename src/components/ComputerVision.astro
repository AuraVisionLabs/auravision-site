---
const specGroups = [
  {
    title: "Works with your cameras",
    specs: [
      { label: "Connectivity", value: "Any IP, RTSP, ONVIF camera" },
      { label: "Camera types", value: "Fisheye & standard lenses" },
      { label: "Video processing", value: "On-premise / edge" },
    ],
  },
  {
    title: "Privacy by design",
    specs: [
      { label: "Personal data", value: "Zero PII stored or shared" },
      { label: "Facial recognition", value: "Never" },
      { label: "Security", value: "ISO 27001 ISMS" },
    ],
  },
  {
    title: "Accuracy you can audit",
    specs: [
      { label: "AI", value: "Tailored per retailer, audited per store" },
      { label: "Analytics", value: "20+ metrics, 15-min intervals" },
      { label: "Segmentation", value: "Age, gender, staff-customer" },
    ],
  },
  {
    title: "Scales with your stores",
    specs: [
      { label: "Bandwidth", value: "< 50 Kb/s per camera" },
      { label: "Data access", value: "Cloud dashboard, REST API" },
      { label: "Integrations", value: "POS & SSO" },
    ],
  },
];
---

<section class="cv-video-section relative overflow-hidden">
  <!-- Full-width video background -->
  <video
    id="cv-bg-video"
    class="absolute inset-0 h-full w-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="none"
  >
    <source src="/videos/aura-vision-tech-demo.webm" type="video/webm" />
    <source src="/videos/aura-vision-tech-demo.mp4" type="video/mp4" />
  </video>

  <!-- Dark overlay on top of video -->
  <div class="absolute inset-0"></div>

  <!-- Top fade to page background -->
  <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-t from-transparent to-slate-900 pointer-events-none z-[1]"></div>

  <!-- Bottom fade to page background -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-b from-transparent to-slate-900 pointer-events-none z-[1]"></div>

  <div class="relative z-10 section-major">
    <!-- Dark specs panel -->
    <div class="container-site">
      <div data-fade class="rounded-2xl border border-white/10 bg-slate-950/50 backdrop-blur-xl p-8 md:p-12">
        <div class="text-center mb-10">
          <h2 class="heading-section">
            <span class="text-gradient block mx-auto" data-text="Get the latest Computer vision AI,">Get the latest Computer vision AI,</span>
            <span class="text-gradient block mx-auto" data-text="without the hassle">without the hassle</span>
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-8 sm:gap-y-10 font-mono text-sm max-w-4xl mx-auto">
          {specGroups.map((group, gi) => (
            <div data-fade style={`transition-delay: ${gi * 100}ms`}>
              <p class="text-xs sm:text-sm uppercase tracking-[0.15em] text-cyan-200 font-semibold mb-3 sm:mb-4">{group.title}</p>
              <div class="space-y-2 sm:space-y-3 pl-2 sm:pl-4 border-l border-white/10">
                {group.specs.map((s) => (
                  <div>
                    <p class="text-[9px] sm:text-[10px] uppercase tracking-[0.2em] text-white/40 font-medium">{s.label}</p>
                    <p class="text-white leading-snug text-xs sm:text-sm">{s.value}</p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Lazy-load the background video when it scrolls near the viewport
  const video = document.getElementById("cv-bg-video") as HTMLVideoElement | null;
  if (video) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            video.preload = "auto";
            video.load();
            observer.disconnect();
          }
        });
      },
      { rootMargin: "200px" }
    );
    observer.observe(video);
  }
</script>
