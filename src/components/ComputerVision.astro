---
const specs = [
  { label: "Connectivity", value: "Any IP, RTSP, ONVIF camera" },
  { label: "Camera types", value: "Fisheye & Standard lenses", tags: ["Fisheye", "Standard lenses"] },
  { label: "Video Processing", value: "On-premise / edge" },
  { label: "Bandwidth", value: "< 50 Kb/s per camera" },
  { label: "AI", value: "Tailored to every retailer" },
  { label: "Accuracy", value: "Audited for every store" },
  { label: "Data access", value: "Cloud dashboard, REST API", tags: ["Cloud dashboard", "REST API"] },
  { label: "Integrations", value: "POS, SSO", tags: ["POS", "SSO"] },
  { label: "Latency", value: "Real-time, 15-min intervals" },
  { label: "Demographics", value: "Age, gender, staff-customer", tags: ["Age", "Gender", "Staff-customer"] },
  { label: "Zone coverage", value: "Entrances, departments, products, queues, service areas", tags: ["Entrances", "Departments", "Products", "Displays", "Activations", "Queues", "Checkouts", "Service areas"] },
  { label: "Analytics", value: "20+ metrics" },
  { label: "Privacy", value: "Zero PII stored or shared" },
  { label: "Facial recognition", value: "Never" },
  { label: "Security", value: "ISO27001 ISMS" }
];
---

<section class="cv-video-section relative overflow-hidden">
  <!-- Full-width video background -->
  <video
    id="cv-bg-video"
    class="absolute inset-0 h-full w-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="none"
  >
    <source src="/videos/aura-vision-tech-demo.webm" type="video/webm" />
    <source src="/videos/aura-vision-tech-demo.mp4" type="video/mp4" />
  </video>

  <!-- Dark overlay on top of video -->
  <div class="absolute inset-0"></div>

  <!-- Top fade to page background -->
  <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-t from-transparent to-slate-900 pointer-events-none z-[1]"></div>

  <!-- Bottom fade to page background -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-b from-transparent to-slate-900 pointer-events-none z-[1]"></div>

  <div class="relative z-10 section-major">
    <!-- Dark specs panel -->
    <div class="container-site">
      <div data-fade class="rounded-2xl border border-white/10 bg-slate-950/50 backdrop-blur-xl p-8 md:p-12">
        <div class="text-center mb-10">
          <h2 class="heading-section">
            <span class="text-gradient block mx-auto" data-text="Cutting-edge computer vision">Cutting-edge computer vision</span>
            <span class="text-gradient block mx-auto" data-text="that just works">that just works</span>
          </h2>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-4 sm:gap-x-10 sm:gap-y-8 font-mono text-sm">
          {specs.map((s, i) => (
            <div data-fade style={`transition-delay: ${i * 80}ms`} class="pl-2 sm:pl-4">
              <p class="text-[9px] sm:text-[10px] uppercase tracking-[0.2em] text-cyan-200 font-semibold mb-0.5 sm:mb-1">{s.label}</p>
              {s.tags ? (
                <div class="flex flex-wrap gap-1 sm:gap-1.5 mt-1">
                  {s.tags.map((tag: string) => (
                    <span class="inline-block text-[10px] sm:text-xs text-slate-900 bg-white/90 rounded-full px-2 py-0.5 leading-tight font-medium">{tag}</span>
                  ))}
                </div>
              ) : (
                <p class="text-white leading-snug sm:leading-relaxed text-xs sm:text-sm">{s.value}</p>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Lazy-load the background video when it scrolls near the viewport
  const video = document.getElementById("cv-bg-video") as HTMLVideoElement | null;
  if (video) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            video.preload = "auto";
            video.load();
            observer.disconnect();
          }
        });
      },
      { rootMargin: "200px" }
    );
    observer.observe(video);
  }
</script>
