---
/**
 * A reusable info-card grid section.
 *
 * Props:
 *  - items: Array of { title: string; body: string; icon?: astro component; link?: { href: string; label: string } }
 *  - columns?: 2 | 3 (default 2)
 */

interface QAItem {
  title: string;
  body: string;
  icon?: any;
  link?: { href: string; label: string };
}

interface Props {
  items: QAItem[];
  columns?: 2 | 3;
}

const { items, columns = 2 } = Astro.props;

const gridCols = columns === 3
  ? "grid-cols-1 md:grid-cols-2 lg:grid-cols-3"
  : "grid-cols-1 md:grid-cols-2";
---

<div class={`grid ${gridCols} gap-8`}>
  {items.map((item) => {
    const Icon = item.icon;
    return (
      <div class="group rounded-2xl border border-slate-200 bg-white p-8 transition-shadow hover:shadow-lg">
        {Icon && (
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-blue-50 text-blue-600">
            <Icon class="h-5 w-5" />
          </div>
        )}
        <h3 class="font-title text-xs font-medium uppercase tracking-[0.15em] text-blue-600 mb-4">
          {item.title}
        </h3>
        <p class="text-sm leading-relaxed text-slate-600" set:html={item.body} />
        {item.link && (
          <a
            href={item.link.href}
            target={item.link.href.startsWith("http") ? "_blank" : undefined}
            rel={item.link.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="mt-4 inline-block text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors"
          >
            {item.link.label} &rarr;
          </a>
        )}
      </div>
    );
  })}
</div>
