---
interface Props {
  title?: string;
  subtitle?: string;
  callout?: string;
  video?: string;
  category?: string;
}

import SlideWrapper from './SlideWrapper.astro';

const { title, subtitle, callout, video, category = "Technology" } = Astro.props;
---

<SlideWrapper class="slide-tech">
  {video && (
    <video
      class="absolute inset-0 w-full h-full object-cover"
      src={video}
      autoplay
      muted
      loop
      playsinline
    />
  )}

  {title && (
    <div class="absolute top-0 left-0 right-0 z-[5] px-[3rem] pt-[2rem] pb-[1.5rem] pointer-events-none flex flex-col items-start gap-[0.375rem]">
      {category && <span class="font-title text-white text-[2rem] bg-[#0a0f1e]/75 backdrop-blur-sm px-3 py-1 rounded-lg">{category}</span>}
      <span class="font-title text-[6rem] tracking-[0.01em] text-white leading-[1.2] bg-[#0a0f1e]/75 backdrop-blur-sm px-3 py-1 rounded-lg">{title}</span>
      {subtitle && <span class="font-body text-[2.5rem] text-white bg-[#0a0f1e]/75 backdrop-blur-sm px-3 py-1 rounded-lg">{subtitle}</span>}
    </div>
  )}

  {callout && (
    <div class="absolute bottom-[3rem] left-0 right-0 z-[5] px-[3rem] pointer-events-none flex items-start">
      <span class="font-body text-[2.5rem] text-white bg-[#0a0f1e]/75 backdrop-blur-sm px-3 py-1 rounded-lg" set:html={callout} />
    </div>
  )}
</SlideWrapper>
