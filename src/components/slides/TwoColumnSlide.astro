---
type ContentBlock =
  | { type: "title"; text: string }
  | { type: "text"; text: string }
  | { type: "image"; src: string; alt?: string };

interface Props {
  title?: string;
  subtitle?: string;
  left: ContentBlock[];
  right: ContentBlock[];
  category?: string;
}

import SlideWrapper from './SlideWrapper.astro';

const { title, subtitle, left, right, category = "Process" } = Astro.props;
const columns = [left, right];
---

<SlideWrapper class="slide-two-column" title={title} subtitle={subtitle} category={category}>
  <div class="relative z-[1] flex items-start justify-center h-full px-[3rem] w-full pt-[16rem] gap-[4rem]">
    {columns.map((blocks) => (
      <div class="flex-1">
        {blocks.map((block) => {
          if (block.type === "title") return <h3 class="font-title text-[4rem] text-white mb-4">{block.text}</h3>;
          if (block.type === "text") return <p class="font-body text-[2.5rem] text-white leading-relaxed">{block.text}</p>;
          if (block.type === "image") return <img src={block.src} alt={block.alt ?? ""} class="w-full h-auto rounded-lg mb-4" />;
        })}
      </div>
    ))}
  </div>
</SlideWrapper>
