---
type TextSize = "h1" | "h2" | "h3" | "h4" | "h5" | "h6" | "p-lg" | "p-md" | "p-sm" | "p-xs";

type BgColor = "none" | "cyan" | "fuchsia" | "purple" | "blue" | "red" | "orange" | "white";

type ContentBlock =
  | { type: "text"; text: string; size?: TextSize; bg?: BgColor }
  | { type: "image"; src: string; alt?: string; width?: "full" | "half" }
  | { type: "logos"; items: Array<{ src: string; alt?: string }>; fit?: "fill" | "fixed" }
  | { type: "testimonial"; headliner: string; quote: string; size?: "sm" | "md" | "lg" }
  | { type: "profile"; name: string; role: string; photo?: string; logo?: string; company?: string }
  | { type: "snapshot"; src: string; camera?: string }
  | { type: "inlinetable"; columns: Array<{ label: string; header: string; level: number }> }
  | { type: "metrics"; items: string[] }
  | { type: "heatmap" }
  | { type: "chat" }
  | { type: "device" };

type CellOptions = {
  background?: "none" | BgColor;
  glow?: "none" | BgColor;
};

interface Props {
  blocks: ContentBlock[];
  options?: CellOptions;
  compact?: boolean;
  stripedMode?: boolean;
  class?: string;
}

import { Footprints, BadgePercent, UserStar, UsersRound, VenusAndMars, ArrowLeftRight, Funnel, Clock, Eye, Flame } from "@lucide/astro";
import PathMapCompare from '../PathMapCompare.astro';
import ChatAnimation from '../ChatAnimation.astro';
import WireframeCube from '../WireframeCube.astro';

const metricsMap: Record<string, { label: string; Icon: any }> = {
  footfall: { label: "Footfall", Icon: Footprints },
  staffing: { label: "Staffing", Icon: UserStar },
  queues: { label: "Queues", Icon: UsersRound },
  demographics: { label: "Demographics", Icon: VenusAndMars },
  "passers-by": { label: "Passers-by", Icon: ArrowLeftRight },
  capture: { label: "Capture", Icon: Funnel },
  dwell: { label: "Dwell", Icon: Clock },
  impressions: { label: "Impressions", Icon: Eye },
  heatmaps: { label: "Heatmaps", Icon: Flame },
  conversion: { label: "Conversion", Icon: BadgePercent },
};

const { blocks, options, compact, stripedMode, class: className } = Astro.props;

const glowStyles: Record<string, string> = {
  cyan: "border-cyan-400 shadow-[0_0_24px_rgba(34,211,238,0.4)]",
  fuchsia: "border-fuchsia-500 shadow-[0_0_24px_rgba(217,70,239,0.4)]",
  purple: "border-purple-500 shadow-[0_0_24px_rgba(168,85,247,0.4)]",
  blue: "border-blue-500 shadow-[0_0_24px_rgba(59,130,246,0.4)]",
  red: "border-red-500 shadow-[0_0_24px_rgba(239,68,68,0.4)]",
  orange: "border-orange-500 shadow-[0_0_24px_rgba(249,115,22,0.4)]",
};

const bgStyles: Record<string, string> = {
  cyan: "bg-cyan-400/20",
  fuchsia: "bg-fuchsia-500/20",
  purple: "bg-purple-500/20",
  blue: "bg-blue-500/20",
  red: "bg-red-500/20",
  orange: "bg-orange-500/20",
  white: "bg-white",
  "white-transparent": "bg-white/10",
};

const bgStylesFull: Record<string, string> = {
  cyan: "bg-cyan-400",
  fuchsia: "bg-fuchsia-500",
  purple: "bg-purple-500",
  blue: "bg-blue-500",
  red: "bg-red-500",
  orange: "bg-orange-500",
};

const bg = options?.background && options.background !== "none" ? `${bgStyles[options.background]} backdrop-blur-sm py-[2rem] px-[3rem] rounded-[3rem] shadow-2xl` : "";
const glow = options?.glow && options.glow !== "none" ? `border-[0.5rem] ${glowStyles[options.glow]} py-[2rem] px-[3rem] rounded-[3rem]` : "";
const isDark = options?.background === "white";

const sizeClasses: Record<string, string> = {
  "h1": `font-title text-[6rem] ${isDark ? 'text-slate-900' : 'text-white'} mb-6`,
  "h2": `font-title text-[4.5rem] ${isDark ? 'text-slate-900' : 'text-white'} mb-5`,
  "h3": `font-title text-[3.5rem] ${isDark ? 'text-slate-900' : 'text-white'} mb-4`,
  "h4": `font-title text-[2.8rem] ${isDark ? 'text-slate-900' : 'text-white'} mb-3`,
  "h5": `font-title text-[2.4rem] ${isDark ? 'text-slate-900' : 'text-white'} mb-2`,
  "h6": `font-title text-[2rem] ${isDark ? 'text-slate-900' : 'text-white'} mb-2`,
  "p-lg": `font-body text-[2.5rem] ${isDark ? 'text-slate-700' : 'text-white'} leading-relaxed mb-6`,
  "p-md": `font-body text-[2rem] ${isDark ? 'text-slate-700' : 'text-white'} leading-relaxed mb-6`,
  "p-sm": `font-body text-[1.5rem] ${isDark ? 'text-slate-700' : 'text-white'} leading-relaxed mb-4`,
  "p-xs": `font-body text-[1.2rem] ${isDark ? 'text-slate-700' : 'text-white'} leading-relaxed mb-4`,
};
---

<div class:list={["min-h-0 flex flex-col overflow-visible", bg, glow, className]}>
  {blocks.map((block) => {
    if (block.type === "text") {
      const hasBg = block.bg && block.bg !== "none";
      let textBg = "";
      if (hasBg) {
        if (compact && !stripedMode) {
          textBg = `${bgStylesFull[block.bg!]} py-[1rem] px-[1.5rem] rounded-[1rem] shadow-lg`;
        } else if (!compact) {
          textBg = `${bgStyles[block.bg!]} backdrop-blur-sm py-[1.5rem] px-[2rem] rounded-[2rem]`;
        }
      }
      const sizeClass = compact ? sizeClasses[block.size ?? "p-md"].replace(/mb-\d+/g, "mb-0") : sizeClasses[block.size ?? "p-md"];
      return <div class={`${sizeClass} ${textBg}`} set:html={block.text} />;
    }
    if (block.type === "image") return <img src={block.src} alt={block.alt ?? ""} class={`${block.width === "half" ? "w-1/2" : "w-full"} h-auto rounded-4xl mb-4 shadow-2xl`} />;
    if (block.type === "logos") {
      const isFill = (block.fit ?? "fill") === "fill";
      return isFill ? (
      <div class="flex items-center gap-[1.5rem] mb-4">
        {block.items.map((item) => (
          <img src={item.src} alt={item.alt ?? ""} class={`h-auto max-h-[4rem] w-0 flex-1 object-contain ${item.src.endsWith('.svg') ? '[filter:brightness(0)_invert(1)]' : '[filter:grayscale(1)_invert(1)_brightness(2)]'}`} />
        ))}
      </div>
      ) : (
      <div class="mb-4">
        {block.items.map((item) => (
          <img src={item.src} alt={item.alt ?? ""} class={`h-[8rem] w-auto object-contain ${item.src.endsWith('.svg') ? '[filter:brightness(0)_invert(1)]' : '[filter:grayscale(1)_invert(1)_brightness(2)]'}`} />
        ))}
      </div>
      );}
    if (block.type === "testimonial") {
      const tSize = block.size ?? "lg";
      const tHeadline = tSize === "sm" ? "text-[1.6rem]" : tSize === "md" ? "text-[2.4rem]" : "text-[3rem]";
      const tQuote = tSize === "sm" ? "text-[1.1rem]" : tSize === "md" ? "text-[1.3rem]" : "text-[1.5rem]";
      return (
      <div class="pt-[2rem] mb-4">
        <p class={`font-body italic ${tHeadline} text-white/90 leading-snug mb-[2rem]`}>&ldquo;{block.headliner}&rdquo;</p>
        <p class={`font-body ${tQuote} leading-relaxed text-white/70`}>{block.quote}</p>
      </div>
    );}
    if (block.type === "profile") return (
      <div class="mt-auto flex items-center gap-[1.5rem]">
        {block.photo ? (
          <img src={block.photo} alt={block.name} class="h-[5rem] w-[5rem] rounded-full object-cover ring-1 ring-white flex-shrink-0" />
        ) : (
          <div class="h-[5rem] w-[5rem] rounded-full bg-white/10 flex-shrink-0" />
        )}
        <div class="min-w-0 flex-1">
          <p class="font-title font-medium text-white/90 text-[1.7rem] leading-tight mb-[0.3rem]">{block.name}</p>
          {block.role.split("\n").map((line: string) => (
            <p class="font-title text-[1.3rem] text-white/50 leading-tight">{line}</p>
          ))}
        </div>
        {block.logo && (
          <img src={block.logo} alt={block.company || ""} class={`h-[4rem] w-auto flex-shrink-0 opacity-60 ${block.logo.endsWith('.svg') ? '[filter:brightness(0)_invert(1)]' : '[filter:grayscale(1)_invert(1)_brightness(2)]'}`} />
        )}
      </div>
    );
    if (block.type === "metrics") {
      const selected = (block.items ?? []).map((key: string) => metricsMap[key]).filter(Boolean);
      return (
        <div class="grid mt-auto" style="grid-template-columns:repeat(auto-fill,7rem);gap:2rem;">
          {selected.map(({ label, Icon }) => (
            <div class="flex flex-col items-center text-center">
              <div class="mb-[0.8rem] flex h-[7rem] w-[7rem] mx-auto items-center justify-center rounded-[1.5rem] bg-white/10 border border-white/10">
                <Icon class="h-[3.5rem] w-[3.5rem] text-white" stroke-width={1.5} />
              </div>
              <p class="font-mono font-light text-[1.2rem] tracking-widest text-white/80">{label}</p>
            </div>
          ))}
        </div>
      );
    }
    if (block.type === "heatmap") return <div class="flex-1 min-h-0"><PathMapCompare /></div>;
    if (block.type === "chat") return <div class="flex-1 min-h-0"><ChatAnimation /></div>;
    if (block.type === "device") return <div class="flex-1 min-h-0 flex items-center justify-center"><WireframeCube /></div>;
    if (block.type === "snapshot") return (
      <div class="flex-1 min-h-0 relative">
        {block.camera && <img src={block.camera} alt="Dome camera" class="absolute top-[2rem] left-[2rem] w-[18%] h-auto z-10 drop-shadow-2xl -scale-x-100" />}
        <img src={block.src} alt="Snapshots" class="w-[70%] h-auto object-contain rounded-3xl ml-[12%] mt-[12%]" />
      </div>
    );
    if (block.type === "inlinetable") {
      const maxLevel = Math.max(...block.columns.map((c) => c.level));
      const totalRows = maxLevel + 1;
      return (
        <table class="mt-auto w-full border-separate table-fixed" style="border-spacing: 0.4rem;">
          {Array.from({ length: totalRows }, (_, rowIdx) => {
            if (rowIdx === maxLevel) {
              return (
                <tr>
                  {block.columns.map((col) => (
                    <td class="text-center px-[0.5rem] py-[0.4rem]"><span class="font-body text-[1.5rem] text-white/70">{col.label}</span></td>
                  ))}
                </tr>
              );
            }
            const rowFromTop = rowIdx;
            const emptyAbove = (col: typeof block.columns[number]) => maxLevel - col.level;
            return (
              <tr class="h-[6rem]">
                {block.columns.map((col) => {
                  if (rowFromTop < emptyAbove(col)) {
                    return <td />;
                  } else if (rowFromTop === emptyAbove(col)) {
                    return <td class="bg-purple-500 rounded-[0.8rem] text-center px-[0.8rem] py-[0.6rem]"><span class="font-title text-[1.5rem] text-white leading-tight">{col.header}</span></td>;
                  } else {
                    const blueIdx = rowFromTop - emptyAbove(col) - 1;
                    const blueCount = col.level - 1;
                    const opacity = blueCount > 0 ? 1 - (blueIdx / blueCount) * 0.7 : 1;
                    return <td class="rounded-[0.8rem]" style={`background: rgba(59,130,246,${opacity})`} />;
                  }
                })}
              </tr>
            );
          })}
        </table>
      );
    }
  })}
</div>
