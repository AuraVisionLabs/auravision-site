---
interface Props {
  title?: string;
  items: Array<{ value: string; label: string }>;
}

const { title, items } = Astro.props;
---

<section class="slide-metrics">
  <div class="flex flex-col items-center justify-center h-full px-16">
    {title && (
      <h2 class="font-title text-5xl tracking-tight text-white mb-16 text-center">
        {title}
      </h2>
    )}

    <div class={`grid gap-12 ${items.length <= 2 ? 'grid-cols-2' : items.length === 3 ? 'grid-cols-3' : 'grid-cols-4'} max-w-5xl w-full`}>
      {items.map((item) => (
        <div class="fragment text-center">
          <p class="font-title text-7xl tracking-tight text-cyan-400 mb-3">
            {item.value}
          </p>
          <p class="text-lg text-white/60 font-light leading-snug max-w-xs mx-auto">
            {item.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
