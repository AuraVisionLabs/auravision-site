---
interface Props {
  title?: string;
  subtitle?: string;
  columns: Array<{ title: string; body?: string }>;
  category?: string;
}

import SlideWrapper from './SlideWrapper.astro';

const { title, subtitle, columns, category = "Process" } = Astro.props;
---

<SlideWrapper class="slide-process" title={title} subtitle={subtitle} category={category}>
  <div class="relative z-[1] flex items-start justify-center h-full px-[3rem] w-full pt-[16rem] gap-[4rem]">
    {columns.map((col) => (
      <div class="flex-1">
        <h3 class="font-title text-[4rem] text-white mb-4">{col.title}</h3>
        {col.body && <p class="font-body text-[2.5rem] text-white leading-relaxed">{col.body}</p>}
      </div>
    ))}
  </div>
</SlideWrapper>
