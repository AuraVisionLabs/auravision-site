---
interface Props {
  heading?: string;
  title: string;
  subtitle?: string;
  steps: Array<{ number: string; title: string; description?: string }>;
  milestones?: Array<{ duration: string; label: string }>;
}

const { heading, title, subtitle, steps, milestones } = Astro.props;
---

<section class="slide-timeline" data-heading={heading}>
  <div class="flex flex-col items-start justify-center h-full px-16 w-full">
    <h2 class="font-title text-8xl tracking-tight text-white leading-snug">
      {title}
    </h2>

    {subtitle && (
      <p class="mt-4 text-4xl text-white font-body">
        {subtitle}
      </p>
    )}

    {/* Numbered steps */}
    <div class="mt-10 grid grid-cols-2 gap-6 w-full">
      {steps.map((step) => (
        <div class="flex items-start gap-4">
          <span class="flex-shrink-0 flex items-center justify-center h-8 w-8 rounded-full bg-cyan-400/10 border border-cyan-400/20 text-cyan-400 text-sm font-mono">
            {step.number}
          </span>
          <div>
            <h3 class="text-base font-medium text-white/90">{step.title}</h3>
            {step.description && (
              <p class="mt-1 text-sm text-white/50 font-light leading-relaxed">{step.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>

    {/* Timeline milestones */}
    {milestones && milestones.length > 0 && (
      <div class="mt-12 w-full">
        <div class="relative flex items-center">
          {/* Line */}
          <div class="absolute left-0 right-0 h-px bg-white/10" />

          {milestones.map((m, i) => (
            <div class="relative flex-1 flex flex-col items-center">
              <div class="relative z-10 h-3 w-3 rounded-full bg-cyan-400 border-2 border-[#0a0f1e] mb-3" />
              <p class="font-title text-lg text-white">{m.duration}</p>
              <p class="text-xs text-white/40 mt-1 text-center max-w-[120px]">{m.label}</p>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
