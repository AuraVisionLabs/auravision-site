---
interface Props {
  heading?: string;
  title: string;
  contacts: Array<{ name: string; email?: string; phone?: string; website?: string }>;
}

import SlideWrapper from './SlideWrapper.astro';

const { heading, title, contacts } = Astro.props;
---

<SlideWrapper class="slide-contact" heading={heading} category="Contact">
  <div class="flex flex-col items-start justify-center h-full px-16 w-full">
    <img src="/images/aura-vision-wordmark.svg" alt="Aura Vision" class="w-auto h-16 mb-16 object-contain" />

    <h2 class="font-title text-8xl tracking-tight text-white leading-snug w-full">
      {title}
    </h2>

    <div class="mt-12 space-y-8">
      {contacts.map((contact) => (
        <div class="space-y-2">
          <p class="text-lg font-medium text-white/90">{contact.name}</p>
          <div class="flex flex-wrap gap-x-8 gap-y-1">
            {contact.email && (
              <p class="text-sm text-white/50 font-mono">
                <span class="text-white/30">E:</span> {contact.email}
              </p>
            )}
            {contact.phone && (
              <p class="text-sm text-white/50 font-mono">
                <span class="text-white/30">M:</span> {contact.phone}
              </p>
            )}
            {contact.website && (
              <p class="text-sm text-white/50 font-mono">
                <span class="text-white/30">W:</span> {contact.website}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</SlideWrapper>
