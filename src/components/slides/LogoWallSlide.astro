---
interface Props {
  title?: string;
  logos?: Array<{ name: string; src: string }>;
}

// Default client logos from the site
const defaultLogos = [
  { name: "Virgin Media O2", src: "/images/logos/vmo2.svg" },
  { name: "Adidas", src: "/images/logos/adidas.svg" },
  { name: "Paddy Power", src: "/images/logos/paddypower.svg" },
  { name: "Purple", src: "/images/logos/purple.svg" },
  { name: "Casper", src: "/images/logos/casper.svg" },
  { name: "Browns", src: "/images/logos/browns.svg" },
  { name: "Gymshark", src: "/images/logos/gymshark.svg" },
  { name: "DFS", src: "/images/logos/dfs.svg" },
  { name: "Flannels", src: "/images/logos/flannels.svg" },
  { name: "Schuh", src: "/images/logos/schuh.svg" },
  { name: "Decathlon", src: "/images/logos/decathlon.svg" },
  { name: "Onitsuka Tiger", src: "/images/logos/onitsuka.svg" },
];

const { title = "Trusted by leading brands", logos } = Astro.props;
const displayLogos = logos && logos.length > 0 ? logos : defaultLogos;
---

<section class="slide-logo-wall">
  <div class="flex flex-col items-center justify-center h-full px-16">
    {title && (
      <h2 class="font-title text-5xl tracking-tight text-white mb-16 text-center">
        {title}
      </h2>
    )}

    <div class="grid grid-cols-6 gap-12 max-w-5xl w-full items-center justify-items-center">
      {displayLogos.map((logo) => (
        <div class="fragment flex items-center justify-center">
          <img
            src={logo.src}
            alt={logo.name}
            class={`max-h-12 max-w-[120px] object-contain opacity-60 ${logo.src.endsWith('.svg') ? '[filter:brightness(0)_invert(1)]' : '[filter:grayscale(1)]'}`}
          />
        </div>
      ))}
    </div>
  </div>
</section>
