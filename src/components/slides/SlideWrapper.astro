---
interface Props {
  title?: string;
  subtitle?: string;
  category?: string;
  categoryBg?: string;
  class?: string;
  style?: string;
  hideWatermark?: boolean;
  background?: string;
}

const { title, subtitle, category, categoryBg, class: className, style, hideWatermark, background } = Astro.props;

// Background images removed

const categoryBgColors: Record<string, string> = {
  cyan: "#22d3ee",
  fuchsia: "#d946ef",
  purple: "#a855f7",
  blue: "#3b82f6",
  red: "#ef4444",
  orange: "#f97316",
};
const catBgStyle = categoryBg && categoryBg !== "none" && categoryBgColors[categoryBg]
  ? `background:${categoryBgColors[categoryBg]};padding:0.4rem 1.5rem;border-radius:0.8rem;display:inline-block;`
  : "";
---

<section
  class:list={[
    "absolute inset-0 flex flex-col items-start justify-center",
    "opacity-0 pointer-events-none will-change-[opacity] bg-[#0a0f1e]",
    "[&.active]:opacity-100 [&.active]:pointer-events-auto",
    className,
  ]}
  style={style}
>
  {/* Background image slot removed */}

  <div class="absolute top-0 left-0 right-0 z-[5] px-[4rem] pt-[4rem] pb-[1.5rem] pointer-events-none min-h-[14rem]">
    {category && <div class="font-title text-white text-[2rem] mb-[0.375rem]" style={catBgStyle}>{category}</div>}
    {title && <div class="font-title text-[6rem] tracking-[0.01em] text-white leading-[1.2] text-gradient" data-text={title}>{title}</div>}
    {subtitle && <div class="font-body text-[2.5rem] text-white/80 mt-[0.4rem]">{subtitle}</div>}
  </div>

  <slot />

  {!hideWatermark && <img src="/images/aura-vision-icon.svg" alt="" class="absolute top-[3rem] right-[3rem] z-10 h-[4rem] w-[4rem] pointer-events-none" />}
</section>

<style is:global>
  section a {
    color: rgb(34 211 238);
    text-decoration: none;
  }
</style>
