---
interface Props {
  title?: string;
  subtitle?: string;
  category?: string;
  categoryBg?: string;
  class?: string;
  style?: string;
}

const { title, subtitle, category, categoryBg, class: className, style } = Astro.props;

const categoryBgColors: Record<string, string> = {
  cyan: "#22d3ee",
  fuchsia: "#d946ef",
  purple: "#a855f7",
  blue: "#3b82f6",
  red: "#ef4444",
  orange: "#f97316",
};
const catBgStyle = categoryBg && categoryBg !== "none" && categoryBgColors[categoryBg]
  ? `background:${categoryBgColors[categoryBg]};padding:0.4rem 1.5rem;border-radius:0.8rem;display:inline-block;`
  : "";
---

<section
  class:list={[
    "absolute inset-0 flex flex-col items-start justify-center",
    "opacity-0 pointer-events-none will-change-[opacity] bg-[#0a0f1e]",
    "[&.active]:opacity-100 [&.active]:pointer-events-auto",
    className,
  ]}
  style={style}
>
  {/* Bottom gradient glow */}
  <div class="absolute bottom-0 left-0 right-0 h-[40%] bg-[linear-gradient(to_top,rgba(34,211,238,0.06)_0%,rgba(217,70,239,0.04)_40%,transparent_100%)] pointer-events-none z-0" />

  <div class="absolute top-0 left-0 right-0 z-[5] px-[4rem] pt-[4rem] pb-[1.5rem] pointer-events-none min-h-[14rem]">
    {category && <div class="font-title text-white text-[2rem] mb-[0.375rem]" style={catBgStyle}>{category}</div>}
    {title && <div class="font-title text-[6rem] tracking-[0.01em] text-white leading-[1.2]">{title}</div>}
    {subtitle && <div class="font-body text-[2.5rem] text-white/60 mt-[0.4rem]">{subtitle}</div>}
  </div>

  <slot />

  <img src="/images/aura-vision-icon.svg" alt="" class="absolute top-[1.5rem] right-[1.75rem] z-10 opacity-75 h-[6rem] w-[6rem] pointer-events-none" />
</section>

<style is:global>
  section a {
    color: rgb(34 211 238);
    text-decoration: none;
  }
</style>
