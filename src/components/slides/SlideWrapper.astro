---
interface Props {
  heading?: string;
  category?: string;
  class?: string;
  style?: string;
}

const { heading, category, class: className, style } = Astro.props;
---

<section
  class:list={[
    "absolute inset-0 flex flex-col items-start justify-center",
    "opacity-0 pointer-events-none will-change-[opacity] bg-[#0a0f1e]",
    "[&.active]:opacity-100 [&.active]:pointer-events-auto",
    className,
  ]}
  style={style}
>
  {/* Bottom gradient glow */}
  <div class="absolute bottom-0 left-0 right-0 h-[40%] bg-[linear-gradient(to_top,rgba(34,211,238,0.06)_0%,rgba(217,70,239,0.04)_40%,transparent_100%)] pointer-events-none z-0" />

  {heading && (
    <div class="absolute top-0 left-0 right-0 z-[5] px-[3rem] pt-[2rem] pb-[1.5rem] pointer-events-none">
      {category && <div class="font-title text-white text-[1.5rem] mb-[0.375rem]">{category}</div>}
      <div class="font-title text-[5rem] tracking-[0.01em] text-white leading-[1.2]">{heading}</div>
    </div>
  )}

  <slot />

  <img src="/images/aura-vision-icon.svg" alt="" class="absolute bottom-[1.5rem] right-[1.75rem] z-10 opacity-75 h-[4.5rem] w-[4.5rem] pointer-events-none" />
</section>
