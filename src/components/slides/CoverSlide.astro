---
interface Props {
  title: string;
  tagline: string;
  logo?: string;
  clientLogo?: string;
  footer?: string;
  background?: string;
}

import SlideWrapper from './SlideWrapper.astro';

const { title, tagline, logo, clientLogo, footer, background } = Astro.props;
---

<SlideWrapper
  class="slide-cover"
  hideWatermark
  background={background}
>
  <div class="relative z-10 flex flex-col items-start justify-center h-full px-[7rem]">
    {clientLogo ? (
      <div class="flex items-center gap-[6rem] w-full mb-12">
        <img src={clientLogo} alt="" class="max-h-[8rem] w-auto object-contain object-left [filter:brightness(0)_invert(1)]" />
        {logo ? (
          <img src={logo} alt="" class="max-h-[8rem] w-auto object-contain object-left [filter:brightness(0)_invert(1)]" />
        ) : (
          <img src="/images/aura-vision-wordmark.svg" alt="Aura Vision" class="max-h-[8rem] w-auto object-contain object-left" />
        )}
      </div>
    ) : logo ? (
      <img src={logo} alt="" class="w-[60%] h-auto mb-10 object-contain object-left [filter:brightness(0)_invert(1)]" />
    ) : (
      <img src="/images/aura-vision-wordmark.svg" alt="Aura Vision" class="h-auto mb-12 object-contain object-left" />
    )}

    <p class="text-5xl text-white leading-tight">
      {tagline}
    </p>

    <h1 class="mt-10 text-8xl text-white font-body tracking-wide">
      {title}
    </h1>
  </div>

  {/* Bottom-left company attribution */}
  <div class="absolute bottom-16 left-[3rem] z-10  px-[5rem]">
    <p class="text-lg text-white font-light text-[2rem]" set:html={footer ?? 'Aura Vision Labs Ltd · <a href="https://auravision.ai">auravision.ai</a>'} />
  </div>
</SlideWrapper>
