---
interface Props {
  src: string;
  alt?: string;
  caption?: string;
}

const { src, alt = "", caption } = Astro.props;
---

<section class="slide-image relative" style={`background-image: url('${src}'); background-size: cover; background-position: center;`}>
  {caption && (
    <div class="absolute bottom-8 left-0 right-0 text-center">
      <span class="inline-block bg-slate-900/80 backdrop-blur-sm px-6 py-3 rounded-full text-sm text-white/80">
        {caption}
      </span>
    </div>
  )}
</section>
