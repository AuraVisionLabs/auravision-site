---
interface Props {
  headliner: string;
  quote: string;
  name: string;
  role: string;
  photo?: string;
  logo?: string;
  company?: string;
}

const { headliner, quote, name, role, photo, logo, company } = Astro.props;
---

<section class="slide-testimonial">
  <div class="flex items-center justify-center h-full px-16">
    <div class="max-w-3xl text-center">
      <!-- Quote mark -->
      <svg class="h-12 w-12 text-cyan-400/60 mx-auto mb-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z" />
        <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 .001 0 1 1 1z" />
      </svg>

      {headliner && (
        <p class="fragment font-title text-3xl text-white leading-snug mb-6">
          "{headliner}"
        </p>
      )}

      <p class="fragment text-lg text-white/60 font-light leading-relaxed mb-10">
        {quote}
      </p>

      <div class="fragment flex items-center justify-center gap-4">
        {photo ? (
          <div class="profile-glow relative h-14 w-14 flex-shrink-0">
            <img src={photo} alt={name} class="relative z-10 h-14 w-14 rounded-full object-cover ring-1 ring-white" />
          </div>
        ) : (
          <div class="h-14 w-14 rounded-full bg-white/10 flex-shrink-0" />
        )}

        <div class="text-left">
          <p class="font-title font-medium text-white/90 leading-tight">{name}</p>
          <p class="text-sm text-white/50">{role}</p>
        </div>

        {logo && (
          <img
            src={logo}
            alt={company || ""}
            class="h-8 w-auto ml-4 opacity-60 [filter:brightness(0)_invert(1)]"
          />
        )}
      </div>
    </div>
  </div>
</section>
