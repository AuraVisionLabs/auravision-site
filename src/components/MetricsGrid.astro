---
import { Footprints, UserStar, UsersRound, Map, Flame, Venus, ArrowLeftRight, Funnel, Clock } from "@lucide/astro";

const metrics = [
  { label: "Footfall", Icon: Footprints },
  { label: "Staffing", Icon: UserStar },
  { label: "Queues", Icon: UsersRound },
  { label: "Journeys", Icon: Map },
  { label: "Heatmaps", Icon: Flame },
  { label: "Demo\u00ADgraphics", Icon: Venus },
  { label: "Passers-by", Icon: ArrowLeftRight },
  { label: "Capture rate", Icon: Funnel },
  { label: "Dwell time", Icon: Clock },
];
---

<section class="py-16 md:py-24">
  <div class="mx-auto px-6">
    <div id="metrics-grid" class="grid grid-cols-5 lg:grid-cols-9 gap-8 gap-y-10 tracking-[0.05em] font-mono font-light text-xs tracking-widest text-white md:text-xs">
      {metrics.map(({ label, Icon }) => (
        <div class="metric-item flex flex-col items-center text-center cursor-default">
          <div class="icon-box mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-white/[0.04] transition-all duration-300">
            <Icon class="h-8 w-8 text-white transition-colors duration-300" stroke-width={1.5} />
          </div>
          <p class="transition-colors duration-300" set:html={label} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .metric-item:hover :global(svg),
  .metric-item.sweep :global(svg) {
    color: rgb(34 211 238); /* cyan-400 full opacity */
  }

  .metric-item:hover p,
  .metric-item.sweep p {
    color: rgb(34 211 238); /* cyan-400 full opacity */
  }

  .metric-item:hover .icon-box,
  .metric-item.sweep .icon-box {
    transform: scale(1.1);
    background-color: rgb(2 6 23); /* slate-950, matches nav */
  }

  @media (prefers-reduced-motion: reduce) {
    .metric-item.sweep :global(svg),
    .metric-item.sweep p {
      color: inherit;
    }

    .metric-item.sweep .icon-box {
      transform: none;
      background-color: rgb(255 255 255 / 0.04);
    }
  }
</style>

<script>
  const grid = document.getElementById("metrics-grid")!;
  const items = grid.querySelectorAll(".metric-item");
  let sweepPaused = false;
  let sweepTimer: ReturnType<typeof setInterval>;

  grid.addEventListener("mouseenter", () => {
    sweepPaused = true;
    items.forEach((item) => item.classList.remove("sweep"));
  });

  grid.addEventListener("mouseleave", () => {
    sweepPaused = false;
  });

  function sweep() {
    if (sweepPaused) return;
    items.forEach((item, i) => {
      setTimeout(() => {
        if (sweepPaused) return;
        item.classList.add("sweep");
        setTimeout(() => item.classList.remove("sweep"), 400);
      }, i * 400);
    });
  }

  sweep();
  sweepTimer = setInterval(sweep, 5000);
</script>
