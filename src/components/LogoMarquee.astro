---
const clients = [
  { name: "Virgin Media O2", logo: "/images/logos/vmo2.svg" },
  { name: "Adidas", logo: "/images/logos/adidas.svg" },
  { name: "Paddy Power", logo: "/images/logos/paddypower.svg" },
  { name: "Purple", logo: "/images/logos/purple.svg" },
  { name: "Casper", logo: "/images/logos/casper.svg" },
  { name: "Browns", logo: "/images/logos/browns.svg" },
  { name: "Bedford", logo: "/images/logos/bedford.webp" },
];

// Repeat logos enough times so each half of the track is wider than the largest screens (5K+)
const repeatedClients = [...clients, ...clients, ...clients, ...clients];
---

<section data-fade="200" class="section-minor overflow-hidden">
  <div class="relative">
    <!-- Fade edges -->
    <div class="pointer-events-none absolute left-0 top-0 bottom-0 z-10 w-24 bg-gradient-to-r from-slate-900 to-transparent"></div>
    <div class="pointer-events-none absolute right-0 top-0 bottom-0 z-10 w-24 bg-gradient-to-l from-slate-900 to-transparent"></div>

    <!-- Scrolling track: two copies for seamless loop -->
    <div class="animate-marquee flex w-max items-center gap-20">
      {repeatedClients.map((client) => (
        <img
          src={client.logo}
          alt={client.name}
          class={`max-h-[57.6px] max-w-[150px] flex-shrink-0 object-contain opacity-50 ${client.logo.endsWith('.svg') ? '[filter:brightness(0)_invert(1)]' : '[filter:grayscale(1)]'}`}
          loading="lazy"
        />
      ))}
      {/* Duplicate for seamless loop */}
      {repeatedClients.map((client) => (
        <img
          src={client.logo}
          alt={client.name}
          class={`max-h-[57.6px] max-w-[150px] flex-shrink-0 object-contain opacity-50 ${client.logo.endsWith('.svg') ? '[filter:brightness(0)_invert(1)]' : '[filter:grayscale(1)]'}`}
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>
