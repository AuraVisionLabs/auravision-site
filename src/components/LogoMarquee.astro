---
const clients = [
  { name: "Decathlon" },
  { name: "Adidas" },
  { name: "Sports Direct" },
  { name: "JD Sports" },
  { name: "Primark" },
  { name: "River Island" },
];
---

<section class="py-16 border-y border-white/5 overflow-hidden">
  <p class="text-center text-xs uppercase tracking-widest text-white/30 mb-10">
    Trusted by leading retailers
  </p>

  <div class="relative">
    <!-- Fade edges -->
    <div class="pointer-events-none absolute left-0 top-0 bottom-0 z-10 w-24 bg-gradient-to-r from-black to-transparent"></div>
    <div class="pointer-events-none absolute right-0 top-0 bottom-0 z-10 w-24 bg-gradient-to-l from-black to-transparent"></div>

    <!-- Scrolling track: two copies for seamless loop -->
    <div class="animate-marquee flex w-max items-center gap-16">
      {clients.map((client) => (
        <div class="flex h-10 w-36 flex-shrink-0 items-center justify-center rounded-lg border border-white/10 bg-white/[0.02] px-4">
          <span class="text-xs text-white/30 whitespace-nowrap">{client.name}</span>
        </div>
      ))}
      {/* Duplicate for seamless loop */}
      {clients.map((client) => (
        <div class="flex h-10 w-36 flex-shrink-0 items-center justify-center rounded-lg border border-white/10 bg-white/[0.02] px-4">
          <span class="text-xs text-white/30 whitespace-nowrap">{client.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
