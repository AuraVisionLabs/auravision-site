---
const clients = [
  { name: "Virgin Media O2", logo: "/images/logos/vmo2.svg" },
  { name: "Adidas", logo: "/images/logos/adidas.svg" },
  { name: "Paddy Power", logo: "/images/logos/paddy power.svg" },
  { name: "Purple", logo: "/images/logos/purple.svg" },
  { name: "Casper", logo: "/images/logos/casper.svg" },
  { name: "Browns", logo: "/images/logos/browns.svg" },
];
---

<section class="py-16 overflow-hidden">
  <div class="relative">
    <!-- Fade edges -->
    <div class="pointer-events-none absolute left-0 top-0 bottom-0 z-10 w-24 bg-gradient-to-r from-slate-900 to-transparent"></div>
    <div class="pointer-events-none absolute right-0 top-0 bottom-0 z-10 w-24 bg-gradient-to-l from-slate-900 to-transparent"></div>

    <!-- Scrolling track: two copies for seamless loop -->
    <div class="animate-marquee flex w-max items-center gap-20">
      {clients.map((client) => (
        <img
          src={client.logo}
          alt={client.name}
          class="h-12 w-max-3xl flex-shrink-0 object-contain opacity-50 [filter:brightness(0)_invert(1)]"
          loading="lazy"
        />
      ))}
      {/* Duplicate for seamless loop */}
      {clients.map((client) => (
        <img
          src={client.logo}
          alt={client.name}
          class="h-12 w-max-3xl flex-shrink-0 object-contain opacity-50 [filter:brightness(0)_invert(1)]"
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>
