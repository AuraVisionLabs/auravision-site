---
import { Bot } from "@lucide/astro";

const heatmapDays = ["M","T","W","T","F","S","S"];
const heatmapHours = ["9","10","11","12","1","2","3","4","5"];
const heatmapGrid = [
  ["o","o","g","g","g","g","g","g","g"], // Mon
  ["g","g","g","g","o","o","o","g","g"], // Tue
  ["g","g","g","g","g","g","g","g","g"], // Wed
  ["g","g","g","g","g","o","o","o","g"], // Thu
  ["g","g","g","g","g","g","g","g","g"], // Fri
  ["g","g","o","o","o","r","r","o","g"], // Sat
  ["g","g","g","r","o","g","g","g","g"], // Sun
];
const hmColor: Record<string, string> = {
  g: "bg-emerald-500/70",
  o: "bg-amber-500/80",
  r: "bg-red-500",
};
---

<div class="chat-animation relative h-[280px] md:h-[260px] w-full">
  <div class="chat-pair space-y-3 w-full lg:max-w-md lg:ml-auto">
    <div class="chat-user flex justify-end items-start gap-2.5 opacity-0">
      <div class="max-w-[80%] text-base leading-relaxed rounded-2xl rounded-tr-sm px-5 py-3 shadow-lg bg-cyan-600 text-white font-medium">
      </div>
      <div class="chat-user-avatar flex-shrink-0 w-9 h-9 rounded-full bg-cyan-600/50 flex items-center justify-center text-[11px] font-semibold text-white/70 mt-0.5">
      </div>
    </div>
    <div class="chat-bot-image flex justify-start items-start gap-2.5 opacity-0 pr-[38px]">
      <div class="flex-shrink-0 w-9 h-9 rounded-full bg-purple-600/50 flex items-center justify-center mt-0.5">
        <Bot class="w-4 h-4 text-white/70" stroke-width={2} />
      </div>
      <div class="max-w-[80%] rounded-2xl rounded-tl-sm shadow-lg overflow-hidden bg-purple-600/20 border border-purple-500/20">
        <div class="chat-visual-container relative w-[200px] aspect-[5/3] bg-gradient-to-br from-purple-500/30 via-cyan-500/20 to-purple-600/30">

          <!-- Visual 0: Entries image + stat -->
          <div class="chat-visual hidden absolute inset-0" data-visual="0">
            <img class="w-full h-full object-cover" src="/images/entries.png" alt="Store entries" />
            <div class="absolute top-2 right-2 flex items-center gap-1.5 rounded-xl px-3 py-1.5 text-sm font-bold shadow-md backdrop-blur-sm bg-emerald-500/80 text-white">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
              <span>+32%</span>
            </div>
          </div>

          <!-- Visual 1: Capture image + stat -->
          <div class="chat-visual hidden absolute inset-0" data-visual="1">
            <img class="w-full h-full object-cover" src="/images/capture.png" alt="Capture rate" />
            <div class="absolute top-2 right-2 flex items-center gap-1.5 rounded-xl px-3 py-1.5 text-sm font-bold shadow-md backdrop-blur-sm bg-red-500/80 text-white">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
              <span>-2.1%</span>
            </div>
          </div>

          <!-- Visual 2: Staffing heatmap -->
          <div class="chat-visual hidden absolute inset-0 p-2" data-visual="2">
            <div class="grid h-full w-full" style={`grid-template-columns: 14px repeat(${heatmapHours.length}, 1fr); grid-template-rows: 14px repeat(${heatmapDays.length}, 1fr); gap: 1.5px;`}>
              <div></div>
              {heatmapHours.map(h => (
                <div class="flex items-center justify-center text-[7px] font-semibold text-white/50">{h}</div>
              ))}
              {heatmapDays.map((day, d) => (
                <>
                  <div class="flex items-center justify-center text-[7px] font-semibold text-white/50">{day}</div>
                  {heatmapGrid[d].map(cell => (
                    <div class={`rounded-[2px] ${hmColor[cell]}`}></div>
                  ))}
                </>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
    <div class="chat-bot flex justify-start items-start gap-2.5 opacity-0 pr-[38px]">
      <div class="flex-shrink-0 w-9 h-9"></div>
      <div class="min-w-[70px] min-h-[47px] max-w-[80%] text-base leading-relaxed rounded-2xl rounded-tl-sm px-5 py-3 shadow-lg bg-purple-600 text-white font-medium">
      </div>
    </div>
  </div>
</div>

<script>
  const messages = [
    {
      user: "Was it worth opening stores the day after Christmas?",
      bot: "<strong>Yes.</strong> Stores saw 32% more traffic and 10% higher conversion than the previous week.",
      visual: 0,
    },
    {
      user: "Are our new window displays delivering ROI?",
      bot: "<strong>Likely not.</strong> Capture rates decreased 2.1% during the period, despite an increase in traffic and engagement.",
      visual: 1,
    },
    {
      user: "Are we staffed correctly for weekend peaks?",
      bot: "<strong>In most but not all stores.</strong> Staff coverage often dips in the New York flagship around 2-3pm Saturdays.",
      visual: 2,
    },
  ];

  const CHAR_INTERVAL = 18;
  const THINKING_DURATION = 1200;
  const INITIALS = ["JT", "SR", "KM", "AL", "DP", "HW"];

  function initChatAnimation(container: Element) {
    const userBubble = container.querySelector(".chat-user")!;
    const botBubble = container.querySelector(".chat-bot")!;
    const botImageBubble = container.querySelector(".chat-bot-image")!;
    const userText = userBubble.querySelector(".max-w-\\[80\\%\\]") as HTMLElement;
    const botText = botBubble.querySelector(".max-w-\\[80\\%\\]") as HTMLElement;
    const avatarEl = container.querySelector(".chat-user-avatar") as HTMLElement;
    const visualPanels = container.querySelectorAll(".chat-visual");
    let index = 0;
    let initialsIndex = 0;
    let streamTimer: number | undefined;

    function resetClasses(el: Element) {
      el.classList.remove("chat-fade-in-up", "chat-fade-out-up");
      void (el as HTMLElement).offsetWidth;
    }

    function showThinkingDots(el: HTMLElement) {
      el.innerHTML = '<span class="thinking-dots"><span></span><span></span><span></span></span>';
    }

    function streamText(el: HTMLElement, text: string, onDone: () => void) {
      el.innerHTML = "";
      let i = 0;

      const parts: string[] = [];
      let cursor = 0;
      const tagRegex = /<\/?[a-zA-Z][^>]*>/g;
      let match;
      while ((match = tagRegex.exec(text)) !== null) {
        if (match.index > cursor) {
          for (let c = cursor; c < match.index; c++) {
            parts.push(text[c]);
          }
        }
        parts.push(match[0]);
        cursor = match.index + match[0].length;
      }
      for (let c = cursor; c < text.length; c++) {
        parts.push(text[c]);
      }

      let accumulated = "";
      streamTimer = window.setInterval(() => {
        if (i < parts.length) {
          accumulated += parts[i];
          el.innerHTML = accumulated;
          i++;
        }
        if (i >= parts.length) {
          clearInterval(streamTimer);
          streamTimer = undefined;
          onDone();
        }
      }, CHAR_INTERVAL);
    }

    function showPair() {
      const pair = messages[index];
      userText.textContent = pair.user;
      botText.textContent = "";
      avatarEl.textContent = INITIALS[initialsIndex];
      initialsIndex = (initialsIndex + 1) % INITIALS.length;

      // Show the matching visual panel, hide the rest
      visualPanels.forEach((panel) => {
        const panelIndex = Number(panel.getAttribute("data-visual"));
        if (panelIndex === pair.visual) {
          panel.classList.remove("hidden");
        } else {
          panel.classList.add("hidden");
        }
      });

      // Reset all to hidden
      userBubble.classList.remove("chat-fade-in-up", "chat-fade-out-up");
      botBubble.classList.remove("chat-fade-in-up", "chat-fade-out-up");
      botImageBubble.classList.remove("chat-fade-in-up", "chat-fade-out-up");
      (userBubble as HTMLElement).style.opacity = "0";
      (botBubble as HTMLElement).style.opacity = "0";
      (botImageBubble as HTMLElement).style.opacity = "0";

      // Fade in user message
      requestAnimationFrame(() => {
        resetClasses(userBubble);
        userBubble.classList.add("chat-fade-in-up");
      });

      // Show image bubble first after user appears
      setTimeout(() => {
        resetClasses(botImageBubble);
        botImageBubble.classList.add("chat-fade-in-up");
      }, 800);

      // Show bot text bubble with thinking dots after image
      setTimeout(() => {
        showThinkingDots(botText);
        resetClasses(botBubble);
        botBubble.classList.add("chat-fade-in-up");
      }, 1400);

      // Replace dots with streaming text
      setTimeout(() => {
        streamText(botText, pair.bot, () => {
          const holdTime = 2400;
          setTimeout(() => {
            resetClasses(userBubble);
            resetClasses(botBubble);
            resetClasses(botImageBubble);
            userBubble.classList.add("chat-fade-out-up");
            botBubble.classList.add("chat-fade-out-up");
            botImageBubble.classList.add("chat-fade-out-up");

            setTimeout(() => {
              index = (index + 1) % messages.length;
              showPair();
            }, 800);
          }, holdTime);
        });
      }, 1400 + THINKING_DURATION);
    }

    showPair();
  }

  document.querySelectorAll(".chat-animation").forEach(initChatAnimation);
</script>
