---
import { Bot } from "@lucide/astro";
import ContactFormFields from "./ContactFormFields.astro";

const heatmapDays = ["M","T","W","T","F","S","S"];
const heatmapHours = ["9","10","11","12","1","2","3","4","5"];
const heatmapGrid = [
  ["o","o","g","g","g","g","g","g","g"], // Mon
  ["g","g","g","g","o","o","o","g","g"], // Tue
  ["g","g","g","g","g","g","g","g","g"], // Wed
  ["g","g","g","g","g","o","o","o","g"], // Thu
  ["g","g","g","g","g","g","g","g","g"], // Fri
  ["g","g","o","o","o","r","r","o","g"], // Sat
  ["g","g","g","r","o","g","g","g","g"], // Sun
];
const hmColor: Record<string, string> = {
  g: "bg-emerald-500/70",
  o: "bg-amber-500/80",
  r: "bg-red-500",
};
---

<div class="chat-animation-wrapper relative h-[480px] md:h-[480px] w-full overflow-visible">
  <div class="chat-animation absolute inset-0 rounded-[32px] bg-white/5 pt-12 px-6 pb-6 overflow-hidden [mask-image:linear-gradient(to_bottom,black_60%,transparent_90%)] transition-all duration-500">
    <div class="chat-pair space-y-2.5 w-full lg:max-w-md lg:ml-auto">
    <div class="chat-user flex justify-end items-start gap-2 opacity-0">
      <div class="max-w-[80%] text-sm leading-relaxed rounded-2xl rounded-tr-sm px-4 py-2.5 shadow-lg bg-cyan-600 text-white font-medium">
      </div>
      <div class="chat-user-avatar flex-shrink-0 w-8 h-8 rounded-full bg-cyan-600/50 flex items-center justify-center text-[10px] font-semibold text-white/70 mt-0.5">
      </div>
    </div>
    <div class="chat-bot-image flex justify-start items-start gap-2 opacity-0 pr-[34px]">
      <div class="flex-shrink-0 w-8 h-8 rounded-full bg-purple-600/50 flex items-center justify-center mt-0.5">
        <Bot class="w-3.5 h-3.5 text-white/70" stroke-width={2} />
      </div>
      <div class="max-w-[80%] rounded-2xl rounded-tl-sm shadow-lg overflow-hidden bg-purple-600/20 border border-purple-500/20">
        <div class="chat-visual-container relative w-[210px] aspect-[5/3] bg-gradient-to-br from-purple-500/30 via-cyan-500/20 to-purple-600/30">

          <!-- Visual 0: Entries image + stat -->
          <div class="chat-visual hidden absolute inset-0" data-visual="0">
            <img class="w-full h-full object-cover" src="/images/entries.png" alt="Store entries" />
            <div class="absolute top-2 right-2 flex items-center gap-1.5 rounded-xl px-3 py-1.5 text-sm font-bold shadow-md backdrop-blur-sm bg-emerald-500/80 text-white">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
              <span>+32%</span>
            </div>
          </div>

          <!-- Visual 1: Capture image + stat -->
          <div class="chat-visual hidden absolute inset-0" data-visual="1">
            <img class="w-full h-full object-cover" src="/images/capture.png" alt="Capture rate" />
            <div class="absolute top-2 right-2 flex items-center gap-1.5 rounded-xl px-3 py-1.5 text-sm font-bold shadow-md backdrop-blur-sm bg-red-500/80 text-white">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
              <span>-2.1%</span>
            </div>
          </div>

          <!-- Visual 2: Staffing heatmap -->
          <div class="chat-visual hidden absolute inset-0 pt-2 pl-2 pb-3.5 pr-3.5" data-visual="2">
            <div class="grid h-full w-full" style={`grid-template-columns: 14px repeat(${heatmapHours.length}, 1fr); grid-template-rows: 14px repeat(${heatmapDays.length}, 1fr); gap: 1.5px;`}>
              <div></div>
              {heatmapHours.map(h => (
                <div class="flex items-center justify-center text-[7px] font-semibold text-white/50">{h}</div>
              ))}
              {heatmapDays.map((day, d) => (
                <>
                  <div class="flex items-center justify-center text-[7px] font-semibold text-white/50">{day}</div>
                  {heatmapGrid[d].map(cell => (
                    <div class={`rounded-[2px] ${hmColor[cell]}`}></div>
                  ))}
                </>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
    <div class="chat-bot flex justify-start items-start gap-2 opacity-0 pr-[34px]">
      <div class="flex-shrink-0 w-8 h-8"></div>
      <div class="min-w-[60px] min-h-[40px] max-w-[80%] text-sm leading-relaxed rounded-2xl rounded-tl-sm px-4 py-2.5 shadow-lg bg-purple-600 text-white font-medium">
      </div>
    </div>
  </div>
  </div>
  <!-- Prompt bar - outside the masked container so it stays full opacity -->
  <div class="chat-prompt-bar absolute bottom-0 left-0 right-0 z-10 px-6 pb-4 w-full transition-all duration-500">
    <div class="relative bg-white/5 rounded-full h-[64px] shadow-[0_0_16px_rgba(255,255,255,0.2)] transition-shadow duration-500 hover:shadow-[0_0_25px_rgba(34,211,238,1.0)] w-full lg:max-w-md lg:ml-auto">
      <input
        type="text"
        placeholder="Ask Aura a question"
        class="chat-prompt-input absolute inset-0 w-full bg-transparent rounded-full pl-6 pr-16 text-lg text-white placeholder-white/40 outline-none"
      />
      <button
        class="chat-prompt-send absolute right-3 top-1/2 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full bg-white/5 hover:bg-cyan-500 transition-all duration-300 text-white/40 hover:text-white cursor-pointer"
        aria-label="Send message"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
    </div>
  </div>
  <!-- Contact form overlay - hidden initially -->
  <div class="chat-contact-form absolute inset-0 z-20 rounded-2xl px-6 py-6 overflow-visible opacity-0 pointer-events-none transition-all duration-500 translate-y-4 flex items-center">
    <div class="w-full lg:max-w-md lg:ml-auto">
      <h3 class="text-xs font-medium uppercase tracking-widest text-cyan-400 mb-4">Book a demo to Ask Aura a question</h3>
      <ContactFormFields formName="contact-hero" compact={true} submitLabel="Book a demo" submitClass="rounded-full bg-purple-600 px-8 py-3 text-base font-medium text-white transition-all duration-300 hover:bg-purple-500 hover:shadow-[0_0_20px_rgba(147,51,234,0.8)] cursor-pointer" />
    </div>
  </div>
</div>

<script>
  const messages = [
    {
      user: "Was it worth opening stores the day after Christmas?",
      bot: "<strong>Yes.</strong> Stores saw 32% more traffic and 10% higher conversion than the previous week.",
      visual: 0,
    },
    {
      user: "Are our new window displays delivering ROI?",
      bot: "<strong>Likely not.</strong> Capture rates decreased 2.1% during the period, despite an increase in traffic and engagement.",
      visual: 1,
    },
    {
      user: "Are we staffed correctly for weekend peaks?",
      bot: "<strong>In most but not all stores.</strong> Staff coverage often dips in the New York flagship around 2-3pm Saturdays.",
      visual: 2,
    },
  ];

  const CHAR_INTERVAL = 18;
  const THINKING_DURATION = 1200;
  const INITIALS = ["JT", "SR", "KM", "AL", "DP", "HW"];

  function initChatAnimation(container: Element) {
    const userBubble = container.querySelector(".chat-user")!;
    const botBubble = container.querySelector(".chat-bot")!;
    const botImageBubble = container.querySelector(".chat-bot-image")!;
    const userText = userBubble.querySelector(".max-w-\\[80\\%\\]") as HTMLElement;
    const botText = botBubble.querySelector(".max-w-\\[80\\%\\]") as HTMLElement;
    const avatarEl = container.querySelector(".chat-user-avatar") as HTMLElement;
    const visualPanels = container.querySelectorAll(".chat-visual");
    let index = 0;
    let initialsIndex = 0;
    let streamTimer: number | undefined;

    function resetClasses(el: Element) {
      el.classList.remove("chat-fade-in-up", "chat-fade-out-up");
      void (el as HTMLElement).offsetWidth;
    }

    function showThinkingDots(el: HTMLElement) {
      el.innerHTML = '<span class="thinking-dots"><span></span><span></span><span></span></span>';
    }

    function streamText(el: HTMLElement, text: string, onDone: () => void) {
      el.innerHTML = "";
      let i = 0;

      const parts: string[] = [];
      let cursor = 0;
      const tagRegex = /<\/?[a-zA-Z][^>]*>/g;
      let match;
      while ((match = tagRegex.exec(text)) !== null) {
        if (match.index > cursor) {
          for (let c = cursor; c < match.index; c++) {
            parts.push(text[c]);
          }
        }
        parts.push(match[0]);
        cursor = match.index + match[0].length;
      }
      for (let c = cursor; c < text.length; c++) {
        parts.push(text[c]);
      }

      let accumulated = "";
      streamTimer = window.setInterval(() => {
        if (i < parts.length) {
          accumulated += parts[i];
          el.innerHTML = accumulated;
          i++;
        }
        if (i >= parts.length) {
          clearInterval(streamTimer);
          streamTimer = undefined;
          onDone();
        }
      }, CHAR_INTERVAL);
    }

    function showPair() {
      const pair = messages[index];
      userText.textContent = pair.user;
      botText.textContent = "";
      avatarEl.textContent = INITIALS[initialsIndex];
      initialsIndex = (initialsIndex + 1) % INITIALS.length;

      // Show the matching visual panel, hide the rest
      visualPanels.forEach((panel) => {
        const panelIndex = Number(panel.getAttribute("data-visual"));
        if (panelIndex === pair.visual) {
          panel.classList.remove("hidden");
        } else {
          panel.classList.add("hidden");
        }
      });

      // Reset all to hidden
      userBubble.classList.remove("chat-fade-in-up", "chat-fade-out-up");
      botBubble.classList.remove("chat-fade-in-up", "chat-fade-out-up");
      botImageBubble.classList.remove("chat-fade-in-up", "chat-fade-out-up");
      (userBubble as HTMLElement).style.opacity = "0";
      (botBubble as HTMLElement).style.opacity = "0";
      (botImageBubble as HTMLElement).style.opacity = "0";

      // Fade in user message
      requestAnimationFrame(() => {
        resetClasses(userBubble);
        userBubble.classList.add("chat-fade-in-up");
      });

      // Show image bubble first after user appears
      setTimeout(() => {
        resetClasses(botImageBubble);
        botImageBubble.classList.add("chat-fade-in-up");
      }, 800);

      // Show bot text bubble with thinking dots after image
      setTimeout(() => {
        showThinkingDots(botText);
        resetClasses(botBubble);
        botBubble.classList.add("chat-fade-in-up");
      }, 1400);

      // Replace dots with streaming text
      setTimeout(() => {
        streamText(botText, pair.bot, () => {
          const holdTime = 2400;
          setTimeout(() => {
            resetClasses(userBubble);
            resetClasses(botBubble);
            resetClasses(botImageBubble);
            userBubble.classList.add("chat-fade-out-up");
            botBubble.classList.add("chat-fade-out-up");
            botImageBubble.classList.add("chat-fade-out-up");

            setTimeout(() => {
              index = (index + 1) % messages.length;
              showPair();
            }, 800);
          }, holdTime);
        });
      }, 1400 + THINKING_DURATION);
    }

    showPair();
  }

  document.querySelectorAll(".chat-animation").forEach(initChatAnimation);

  // Transition: prompt bar → contact form
  document.querySelectorAll(".chat-animation-wrapper").forEach((wrapper) => {
    const input = wrapper.querySelector(".chat-prompt-input") as HTMLInputElement;
    const sendBtn = wrapper.querySelector(".chat-prompt-send") as HTMLButtonElement;
    const chatArea = wrapper.querySelector(".chat-animation") as HTMLElement;
    const promptBar = wrapper.querySelector(".chat-prompt-bar") as HTMLElement;
    const contactForm = wrapper.querySelector(".chat-contact-form") as HTMLElement;
    const messageField = contactForm.querySelector('textarea[name="message"]') as HTMLTextAreaElement;

    const barContainer = wrapper.querySelector(".chat-prompt-bar .relative") as HTMLElement;

    let transitioned = false;

    function updateSendButton() {
      if (input.value.trim()) {
        sendBtn.classList.add("bg-cyan-500", "text-white");
        sendBtn.classList.remove("bg-white/5", "text-white/40");
        barContainer.style.boxShadow = "0 0 25px rgba(34,211,238,1.0)";
      } else {
        sendBtn.classList.remove("bg-cyan-500", "text-white");
        sendBtn.classList.add("bg-white/5", "text-white/40");
        barContainer.style.boxShadow = "";
      }
    }

    input.addEventListener("input", updateSendButton);

    function showContactForm() {
      const text = input.value.trim();
      if (!text || transitioned) return;
      transitioned = true;

      // Pre-fill the message field
      if (messageField) {
        messageField.value = text;
      }

      // Fade out chat + prompt bar
      chatArea.style.opacity = "0";
      chatArea.style.transform = "translateY(-10px)";
      promptBar.style.opacity = "0";
      promptBar.style.transform = "translateY(10px)";
      promptBar.style.pointerEvents = "none";

      // Fade in contact form
      setTimeout(() => {
        contactForm.classList.remove("opacity-0", "pointer-events-none", "translate-y-4");
        contactForm.classList.add("opacity-100", "translate-y-0");
      }, 200);
    }

    sendBtn.addEventListener("click", showContactForm);
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        showContactForm();
      }
    });
  });
</script>
