---
// 3D CSS wireframe cuboid with dimension annotations
// Proportions: 6cm (W) × 4cm (H) × 6cm (D)
---

<div class="cube-scene">
  <!-- Shared RJ45 symbol (defined once, used twice) -->
  <svg style="display:none" xmlns="http://www.w3.org/2000/svg">
    <symbol id="rj45" viewBox="0 0 48 48" fill="none">
      <rect x="2" y="2" width="44" height="44" rx="5" stroke="currentColor" stroke-width="1.5" opacity="0.2"/>
      <path d="M10 8 h28 a2 2 0 0 1 2 2 v14 h-6 v8 h-20 v-8 h-6 V10 a2 2 0 0 1 2-2 Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <line x1="14" y1="11" x2="14" y2="22" stroke="currentColor" stroke-width="1.2"/>
      <line x1="18" y1="11" x2="18" y2="22" stroke="currentColor" stroke-width="1.2"/>
      <line x1="22" y1="11" x2="22" y2="22" stroke="currentColor" stroke-width="1.2"/>
      <line x1="26" y1="11" x2="26" y2="22" stroke="currentColor" stroke-width="1.2"/>
      <line x1="30" y1="11" x2="30" y2="22" stroke="currentColor" stroke-width="1.2"/>
      <line x1="34" y1="11" x2="34" y2="22" stroke="currentColor" stroke-width="1.2"/>
    </symbol>
    <symbol id="usbc" viewBox="0 0 36 20" fill="none">
      <rect x="1" y="1" width="30" height="17" rx="8" stroke="currentColor" stroke-width="1.2" opacity="0.2"/>
      <rect x="5" y="5" width="22" height="9" rx="5" stroke="currentColor" stroke-width="1.2"/>
    </symbol>
  </svg>

  <div class="cube">
    <div class="face front">
      <svg class="eth-port" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <use href="#rj45"/>
      </svg>
      <svg class="eth-port" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <use href="#rj45"/>
      </svg>
      <svg class="usbc-port" viewBox="0 0 36 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <use href="#usbc"/>
      </svg>
    </div>
    <div class="face back"></div>
    <div class="face right">
      <svg class="speaker-grill" viewBox="0 0 185 72" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Row 1: r=4.5, y=6 -->
        <circle cx="8" cy="6" r="4.5"/><circle cx="26" cy="6" r="4.5"/><circle cx="44" cy="6" r="4.5"/><circle cx="62" cy="6" r="4.5"/><circle cx="80" cy="6" r="4.5"/><circle cx="98" cy="6" r="4.5"/><circle cx="116" cy="6" r="4.5"/><circle cx="134" cy="6" r="4.5"/><circle cx="152" cy="6" r="4.5"/><circle cx="170" cy="6" r="4.5"/>
        <!-- Row 2: r=4.2, y=16, offset -->
        <circle cx="17" cy="16" r="4.2"/><circle cx="35" cy="16" r="4.2"/><circle cx="53" cy="16" r="4.2"/><circle cx="71" cy="16" r="4.2"/><circle cx="89" cy="16" r="4.2"/><circle cx="107" cy="16" r="4.2"/><circle cx="125" cy="16" r="4.2"/><circle cx="143" cy="16" r="4.2"/><circle cx="161" cy="16" r="4.2"/>
        <!-- Row 3: r=3.8, y=26 -->
        <circle cx="8" cy="26" r="3.8"/><circle cx="26" cy="26" r="3.8"/><circle cx="44" cy="26" r="3.8"/><circle cx="62" cy="26" r="3.8"/><circle cx="80" cy="26" r="3.8"/><circle cx="98" cy="26" r="3.8"/><circle cx="116" cy="26" r="3.8"/><circle cx="134" cy="26" r="3.8"/><circle cx="152" cy="26" r="3.8"/><circle cx="170" cy="26" r="3.8"/>
        <!-- Row 4: r=3.4, y=36, offset -->
        <circle cx="17" cy="36" r="3.4"/><circle cx="35" cy="36" r="3.4"/><circle cx="53" cy="36" r="3.4"/><circle cx="71" cy="36" r="3.4"/><circle cx="89" cy="36" r="3.4"/><circle cx="107" cy="36" r="3.4"/><circle cx="125" cy="36" r="3.4"/><circle cx="143" cy="36" r="3.4"/><circle cx="161" cy="36" r="3.4"/>
        <!-- Row 5: r=3.0, y=46 -->
        <circle cx="8" cy="46" r="3.0"/><circle cx="26" cy="46" r="3.0"/><circle cx="44" cy="46" r="3.0"/><circle cx="62" cy="46" r="3.0"/><circle cx="80" cy="46" r="3.0"/><circle cx="98" cy="46" r="3.0"/><circle cx="116" cy="46" r="3.0"/><circle cx="134" cy="46" r="3.0"/><circle cx="152" cy="46" r="3.0"/><circle cx="170" cy="46" r="3.0"/>
        <!-- Row 6: r=2.6, y=56, offset -->
        <circle cx="17" cy="56" r="2.6"/><circle cx="35" cy="56" r="2.6"/><circle cx="53" cy="56" r="2.6"/><circle cx="71" cy="56" r="2.6"/><circle cx="89" cy="56" r="2.6"/><circle cx="107" cy="56" r="2.6"/><circle cx="125" cy="56" r="2.6"/><circle cx="143" cy="56" r="2.6"/><circle cx="161" cy="56" r="2.6"/>
        <!-- Row 7: r=2.2, y=66 -->
        <circle cx="8" cy="66" r="2.2"/><circle cx="26" cy="66" r="2.2"/><circle cx="44" cy="66" r="2.2"/><circle cx="62" cy="66" r="2.2"/><circle cx="80" cy="66" r="2.2"/><circle cx="98" cy="66" r="2.2"/><circle cx="116" cy="66" r="2.2"/><circle cx="134" cy="66" r="2.2"/><circle cx="152" cy="66" r="2.2"/><circle cx="170" cy="66" r="2.2"/>
      </svg>
    </div>
    <div class="face left"></div>
    <div class="face top">
      <div class="grill">
        <div class="grill-row"><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div></div>
        <div class="grill-row"><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div></div>
        <div class="grill-row"><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div></div>
        <div class="grill-row"><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div></div>
        <div class="grill-row"><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div><div class="gc"></div></div>
      </div>
      <div class="power"></div>
    </div>
    <div class="face bottom"></div>

    <div class="dim dim-x"><span class="dim-label">6cm</span></div>
    <div class="dim dim-y"><span class="dim-label">4cm</span></div>
    <div class="dim dim-z"><span class="dim-label">6cm</span></div>
  </div>
</div>

<style>
  /* All dimensions driven by these three variables */
  .cube-scene {
    --w: 225px;   /* width  (6cm) */
    --h: 150px;   /* height (4cm) */
    --d: 225px;   /* depth  (6cm) */
    --half-w: 112.5px;
    --half-h: 75px;
    --half-d: 112.5px;
    --offset: 20px;           /* gap between cube edge and dimension line */
    --dim-color: rgba(255, 255, 255, 0.35);
    --edge-color: rgba(255, 255, 255, 0.6);

    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1200px;
  }

  .cube {
    position: relative;
    width: var(--w);
    height: var(--h);
    transform-style: preserve-3d;
    animation: cube-idle 8s ease-in-out infinite alternate;
  }

  @keyframes cube-idle {
    0%   { transform: rotateX(-30deg) rotateY(-40deg); }
    100% { transform: rotateX(-30deg) rotateY(-50deg); }
  }

  /* ---- Faces (shared) ---- */
  .face {
    position: absolute;
    left: 50%;
    top: 50%;
    backface-visibility: hidden;
    border: 2px solid var(--edge-color);
    background: #0f172a;
  }

  /* Front, Back, Left, Right share W × H */
  .face.front, .face.back,
  .face.left,  .face.right {
    width: var(--w);
    height: var(--h);
    margin-left: calc(-1 * var(--half-w));
    margin-top:  calc(-1 * var(--half-h));
  }
  .face.front { transform: translateZ(var(--half-d)); }
  .face.back  { transform: rotateY(180deg) translateZ(var(--half-d)); }
  .face.right { transform: rotateY(90deg)  translateZ(var(--half-w)); }
  .face.left  { transform: rotateY(-90deg) translateZ(var(--half-w)); }

  /* Top, Bottom: W × D */
  .face.top, .face.bottom {
    width: var(--w);
    height: var(--d);
    margin-left: calc(-1 * var(--half-w));
    margin-top:  calc(-1 * var(--half-d));
  }
  .face.top    { transform: rotateX(90deg)  translateZ(var(--half-h)); }
  .face.bottom { transform: rotateX(-90deg) translateZ(var(--half-h)); }

  /* ---- Power circle on top face ---- */

  /* ---- Speaker grill on right face (outlined circles) ---- */
  .speaker-grill {
    position: absolute;
    top: 15px;
    left: 20px;
    right: 20px;
    bottom: 15px;
    stroke: rgba(255, 255, 255, 0.2);
    stroke-width: 1.2;
    fill: none;
  }

  .grill {
    position: absolute;
    top: 24px;
    left: 38px;
    right: 38px;
    height: 46%;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .grill-row {
    flex: 1;
    display: flex;
    gap: 4px;
  }

  .gc {
    flex: 1;
    border: 1.5px solid rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    transform: skewX(-20deg);
  }

  .power {
    position: absolute;
    bottom: 20px;
    right: 20px;
    width: 24px;
    height: 24px;
    border: 1.5px solid var(--edge-color);
    border-radius: 50%;
  }

  /* ---- Dimension lines (shared) ---- */
  .dim {
    position: absolute;
    left: 50%;
    top: 50%;
    height: 16px;
    margin-top: -8px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-left:  2px solid var(--dim-color);
    border-right: 2px solid var(--dim-color);
  }

  .dim::before, .dim::after {
    content: '';
    flex: 1;
    border-top: 2px solid var(--dim-color);
  }

  .dim-label {
    padding: 0 10px;
    font-family: var(--font-mono, 'Roboto Mono', monospace);
    font-size: 18px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.55);
    white-space: nowrap;
    line-height: 1;
  }

  /* ---- Ethernet ports on front face ---- */
  .face.front {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .eth-port {
    width: 57px;
    height: 52px;
    color: rgba(255, 255, 255, 0.5);
  }

  .usbc-port {
    width: 48px;
    height: 28px;
    color: rgba(255, 255, 255, 0.5);
  }

  /* X — 6cm along front bottom, flat on ground plane */
  .dim-x {
    width: var(--w);
    margin-left: calc(-1 * var(--half-w));
    transform: translate3d(0, calc(var(--half-h) + var(--offset) + 5px), calc(var(--half-d) + var(--offset))) rotateX(90deg);
  }

  /* Y — 4cm vertical, right-back edge */
  .dim-y {
    width: var(--h);
    margin-left: calc(-1 * var(--half-h));
    transform: translate3d(calc(var(--half-w) + var(--offset)), 0, calc(-1 * (var(--half-d) + var(--offset)))) rotateZ(-90deg);
  }

  /* Z — 6cm along right bottom, flat on ground plane */
  .dim-z {
    width: var(--d);
    margin-left: calc(-1 * var(--half-d));
    transform: translate3d(calc(var(--half-w) + var(--offset)), calc(var(--half-h) + var(--offset) + 5px), 0) rotateY(90deg) rotateX(90deg);
  }
</style>
