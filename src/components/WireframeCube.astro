---
// 3D CSS wireframe cuboid with dimension annotations
// Proportions: 6cm (W) × 4cm (H) × 6cm (D)

// Speaker grill: 7 rows of circles, alternating offset, shrinking radii
const speakerRows = [
  { y: 6,  r: 4.5, offset: false },
  { y: 16, r: 4.2, offset: true  },
  { y: 26, r: 3.8, offset: false },
  { y: 36, r: 3.4, offset: true  },
  { y: 46, r: 3.0, offset: false },
  { y: 56, r: 2.6, offset: true  },
  { y: 66, r: 2.2, offset: false },
];
const speakerCols = 10;
const speakerSpacing = 18;
const speakerOffset = 9; // half spacing for alternating rows

// Top grill: 5 rows × 12 columns
const grillRows = 5;
const grillCols = 12;
---

<div class="cube-container">
<div class="cube-scene">
  <svg style="display:none" xmlns="http://www.w3.org/2000/svg">
    <symbol id="rj45" viewBox="0 0 48 48" fill="none">
      <rect x="2" y="2" width="44" height="44" rx="5" stroke="currentColor" stroke-width="1.5" opacity="0.2"/>
      <path d="M10 8 h28 a2 2 0 0 1 2 2 v14 h-6 v8 h-20 v-8 h-6 V10 a2 2 0 0 1 2-2 Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      {[14,18,22,26,30,34].map(x => (
        <line x1={x} y1="11" x2={x} y2="22" stroke="currentColor" stroke-width="1.2"/>
      ))}
    </symbol>
    <symbol id="usbc" viewBox="0 0 36 20" fill="none">
      <rect x="1" y="1" width="30" height="17" rx="8" stroke="currentColor" stroke-width="1.2" opacity="0.2"/>
      <rect x="5" y="5" width="22" height="9" rx="5" stroke="currentColor" stroke-width="1.2"/>
    </symbol>
  </svg>

  <div class="cube">
    <div class="face front">
      <div class="port-group">
        <span class="port-label">cam</span>
        <svg class="port eth-port" viewBox="0 0 48 48" fill="none"><use href="#rj45"/></svg>
      </div>
      <div class="port-group">
        <span class="port-label">net</span>
        <svg class="port eth-port" viewBox="0 0 48 48" fill="none"><use href="#rj45"/></svg>
      </div>
      <div class="port-group">
        <span class="port-label">pwr</span>
        <svg class="port usbc-port" viewBox="0 0 36 20" fill="none"><use href="#usbc"/></svg>
      </div>
    </div>
    <div class="face right">
      <svg class="speaker-grill" viewBox="0 0 185 72" fill="none">
        {speakerRows.map(row => {
          const count = row.offset ? speakerCols - 1 : speakerCols;
          const startX = row.offset ? speakerOffset + 8 : 8;
          return Array.from({ length: count }, (_, i) => (
            <circle cx={startX + i * speakerSpacing} cy={row.y} r={row.r}/>
          ));
        })}
      </svg>
    </div>
    <div class="face top">
      <div class="grill">
        {Array.from({ length: grillRows }, () => (
          <div class="grill-row">
            {Array.from({ length: grillCols }, () => <div class="gc"/>)}
          </div>
        ))}
      </div>
      <div class="power"></div>
    </div>

    <!-- Wireframe edges (front + right + top faces) -->
    <!-- X-axis edges (along width) -->
    <div class="edge edge-x edge-front-top"></div>
    <div class="edge edge-x edge-front-bottom"></div>
    <div class="edge edge-x edge-back-top"></div>
    <!-- Y-axis edges (along height) -->
    <div class="edge edge-y edge-front-left"></div>
    <div class="edge edge-y edge-front-right"></div>
    <div class="edge edge-y edge-back-right"></div>
    <!-- Z-axis edges (along depth) -->
    <div class="edge edge-z edge-top-left"></div>
    <div class="edge edge-z edge-top-right"></div>
    <div class="edge edge-z edge-bottom-right"></div>

    <div class="dim dim-x"><span class="dim-label">6cm</span></div>
    <div class="dim dim-y"><span class="dim-label">4cm</span></div>
    <div class="dim dim-z"><span class="dim-label">6cm</span></div>
  </div>
</div>
</div>

<style>
  /* All dimensions driven by these three variables */
  .cube-container {
    width: 100%;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    touch-action: none;
  }

  @media (min-width: 768px) {
    .cube-container {
      min-height: 450px;
    }
  }

  .cube-scene {
    --w: 225px;   /* width  (6cm) */
    --h: 150px;   /* height (4cm) */
    --d: 225px;   /* depth  (6cm) */
    --half-w: 112.5px;
    --half-h: 75px;
    --half-d: 112.5px;
    --offset: 20px;           /* gap between cube edge and dimension line */
    --dim-color: rgba(255, 255, 255, 0.35);
    --edge-color: rgba(255, 255, 255, 1.0);

    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1200px;
    padding: 40px;
    transform: scale(0.8);
    transform-origin: center;
  }

  @media (min-width: 768px) {
    .cube-scene {
      padding: 80px;
      transform: scale(1);
    }
  }

  .cube {
    position: relative;
    width: var(--w);
    height: var(--h);
    transform-style: preserve-3d;
    animation: cube-idle 5s ease-in-out infinite alternate;
  }

  /* Invisible hit-area so hover doesn't flicker at 3D edges */
  .cube::before {
    content: '';
    position: absolute;
    top: -80px;
    left: -80px;
    right: -80px;
    bottom: -80px;
    pointer-events: none;
  }

  @keyframes cube-idle {
    0%   { transform: rotateX(-25deg) rotateY(-30deg); }
    100% { transform: rotateX(-35deg) rotateY(-60deg); }
  }

  /* ---- Faces (shared) ---- */
  .face {
    position: absolute;
    left: 50%;
    top: 50%;
    backface-visibility: hidden;
  }

  /* ---- Wireframe edges ---- */
  .edge {
    position: absolute;
    left: 50%;
    top: 50%;
    height: 0;
    border-top: 3px solid var(--edge-color);
    pointer-events: none;
    z-index: 1;
  }

  /* Edges along X (width) */
  .edge-x {
    width: var(--w);
    margin-left: calc(-1 * var(--half-w));
  }
  .edge-front-top    { transform: translate3d(0, calc(-1 * var(--half-h)), var(--half-d)); }
  .edge-front-bottom { transform: translate3d(0, var(--half-h), var(--half-d)); }
  .edge-back-top     { transform: translate3d(0, calc(-1 * var(--half-h)), calc(-1 * var(--half-d))); }

  /* Edges along Y (height) */
  .edge-y {
    width: var(--h);
    margin-left: calc(-1 * var(--half-h));
    transform-origin: center;
  }
  .edge-front-left  { transform: translate3d(calc(-1 * var(--half-w)), 0, var(--half-d)) rotateZ(90deg); }
  .edge-front-right { transform: translate3d(var(--half-w), 0, var(--half-d)) rotateZ(90deg); }
  .edge-back-right  { transform: translate3d(var(--half-w), 0, calc(-1 * var(--half-d))) rotateZ(90deg); }

  /* Edges along Z (depth) */
  .edge-z {
    width: var(--d);
    margin-left: calc(-1 * var(--half-d));
  }
  .edge-top-left     { transform: translate3d(calc(-1 * var(--half-w)), calc(-1 * var(--half-h)), 0) rotateY(90deg); }
  .edge-top-right    { transform: translate3d(var(--half-w), calc(-1 * var(--half-h)), 0) rotateY(90deg); }
  .edge-bottom-right { transform: translate3d(var(--half-w), var(--half-h), 0) rotateY(90deg); }

  /* Front & Right share W × H */
  .face.front,
  .face.right {
    width: var(--w);
    height: var(--h);
    margin-left: calc(-1 * var(--half-w));
    margin-top:  calc(-1 * var(--half-h));
  }
  .face.front { transform: translateZ(var(--half-d)); }
  .face.right { transform: rotateY(90deg)  translateZ(var(--half-w)); }

  .face.top {
    width: var(--w);
    height: var(--d);
    margin-left: calc(-1 * var(--half-w));
    margin-top:  calc(-1 * var(--half-d));
  }
  .face.top    { transform: rotateX(90deg)  translateZ(var(--half-h)); }

  /* ---- Power circle on top face ---- */

  /* ---- Speaker grill on right face (outlined circles) ---- */
  .speaker-grill {
    position: absolute;
    top: 15px;
    left: 20px;
    right: 20px;
    bottom: 15px;
    stroke: rgba(255, 255, 255, 0.2);
    stroke-width: 1.2;
    fill: none;
  }

  .grill {
    position: absolute;
    top: 24px;
    left: 38px;
    right: 38px;
    height: 46%;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .grill-row {
    flex: 1;
    display: flex;
    gap: 4px;
  }

  .gc {
    flex: 1;
    border: 1.5px solid rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    transform: skewX(-20deg);
  }

  .power {
    position: absolute;
    bottom: 20px;
    right: 20px;
    width: 24px;
    height: 24px;
    border: 1.5px solid var(--edge-color);
    border-radius: 50%;
  }

  /* ---- Dimension lines (shared) ---- */
  .dim {
    position: absolute;
    left: 50%;
    top: 50%;
    height: 16px;
    margin-top: -8px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-left:  2px solid var(--dim-color);
    border-right: 2px solid var(--dim-color);
  }

  .dim::before, .dim::after {
    content: '';
    flex: 1;
    border-top: 2px solid var(--dim-color);
  }

  .dim-label {
    padding: 0 10px;
    font-family: var(--font-mono, 'Roboto Mono', monospace);
    font-size: 18px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.55);
    white-space: nowrap;
    line-height: 1;
  }

  /* ---- Ethernet ports on front face ---- */
  .face.front {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .port-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .port-label {
    font-family: var(--font-mono, 'Roboto Mono', monospace);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.5px;
  }

  .eth-port { width: 57px; height: 52px; }
  .usbc-port { width: 48px; height: 28px; }
  .port { color: rgba(255, 255, 255, 0.5); }

  /* X — 6cm along front bottom, flat on ground plane */
  .dim-x {
    width: var(--w);
    margin-left: calc(-1 * var(--half-w));
    transform: translate3d(0, calc(var(--half-h) + var(--offset) + 5px), calc(var(--half-d) + var(--offset))) rotateX(90deg);
  }

  /* Y — 4cm vertical, right-back edge */
  .dim-y {
    width: var(--h);
    margin-left: calc(-1 * var(--half-h));
    transform: translate3d(calc(var(--half-w) + var(--offset)), 0, calc(-1 * (var(--half-d) + var(--offset)))) rotateZ(-90deg);
  }

  /* Z — 6cm along right bottom, flat on ground plane */
  .dim-z {
    width: var(--d);
    margin-left: calc(-1 * var(--half-d));
    transform: translate3d(calc(var(--half-w) + var(--offset)), calc(var(--half-h) + var(--offset) + 5px), 0) rotateY(90deg) rotateX(90deg);
  }

  /* Transition for smooth hover rotation */
  .cube.is-hovering {
    animation: none !important;
  }
</style>

<script>
  const container = document.querySelector('.cube-container') as HTMLElement;
  const scene = document.querySelector('.cube-scene') as HTMLElement;
  const cube = document.querySelector('.cube') as HTMLElement;
  if (container && scene && cube) {
    let isHovering = false;

    function startInteraction() {
      if (isHovering) return;
      isHovering = true;
      const current = getComputedStyle(cube).transform;
      cube.style.transition = 'transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1)';
      cube.style.transform = current;
      cube.offsetHeight;
      cube.classList.add('is-hovering');
      setTimeout(() => {
        if (isHovering) cube.style.transition = 'none';
      }, 350);
    }

    function endInteraction() {
      if (!isHovering) return;
      isHovering = false;
      cube.style.transition = 'transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1)';
      const midRotX = -25;
      const midRotY = -30;
      cube.style.transform = `rotateX(${midRotX}deg) rotateY(${midRotY}deg)`;
      const onDone = () => {
        cube.removeEventListener('transitionend', onDone);
        cube.classList.remove('is-hovering');
        cube.style.transition = '';
        cube.style.transform = '';
      };
      cube.addEventListener('transitionend', onDone);
    }

    function updateRotation(clientX: number, clientY: number) {
      if (!isHovering) return;
      const rect = container.getBoundingClientRect();
      const x = (clientX - rect.left) / rect.width - 0.5;
      const y = (clientY - rect.top) / rect.height - 0.5;
      const rotY = x * 60 - 45;
      const rotX = -y * 30 - 30;
      cube.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg)`;
    }

    // Mouse events
    container.addEventListener('mouseenter', startInteraction);
    container.addEventListener('mouseleave', endInteraction);
    container.addEventListener('mousemove', (e) => updateRotation(e.clientX, e.clientY));

    // Touch events
    container.addEventListener('touchstart', (e) => {
      e.preventDefault();
      startInteraction();
      const touch = e.touches[0];
      updateRotation(touch.clientX, touch.clientY);
    }, { passive: false });

    container.addEventListener('touchmove', (e) => {
      e.preventDefault();
      const touch = e.touches[0];
      updateRotation(touch.clientX, touch.clientY);
    }, { passive: false });

    container.addEventListener('touchend', () => endInteraction());
    container.addEventListener('touchcancel', () => endInteraction());
  }
</script>
