---
/**
 * Interactive before/after image comparison slider.
 * Hover (or touch-drag) slides between two images.
 * When idle the divider gently oscillates to hint at interactivity.
 * Toggle buttons below switch between Age, Gender, and Staff views.
 */
---

<div class="pathmap-wrapper">
  <div class="pathmap-compare rounded-2xl border border-white/5 bg-white/[0.03] overflow-hidden select-none relative" style="aspect-ratio: 16 / 10;" role="img" aria-label="Compare heatmaps">
    <!-- Left (base layer) -->
    <img src="/images/cust path.jpg" alt="Customer path map" class="pathmap-img pathmap-img-left" draggable="false" />

    <!-- Left label (clipped to left side of split) -->
    <div class="pathmap-left-clip">
      <span class="pathmap-label left">Customer</span>
    </div>

    <!-- Right (reveal layer, clipped) -->
    <div class="pathmap-reveal">
      <img src="/images/staff path.jpg" alt="Staff path map" class="pathmap-img pathmap-img-right" draggable="false" />
      <span class="pathmap-label right">Staff</span>
    </div>

    <!-- Divider line + handle -->
    <div class="pathmap-divider">
      <div class="pathmap-handle">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M7 4L3 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M13 4L17 10L13 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Toggle buttons -->
  <div class="pathmap-toggles">
    <div class="pathmap-slider"></div>
    <button class="pathmap-toggle" data-index="0" data-left-src="/images/16 dwell.jpg" data-right-src="/images/25 dwell.jpg" data-left-label="Age 16" data-right-label="Age 25" data-left-color="#f97316" data-right-color="#ec4899">Age</button>
    <button class="pathmap-toggle" data-index="1" data-left-src="/images/female dwell.jpg" data-right-src="/images/male dwell.jpg" data-left-label="Female" data-right-label="Male" data-left-color="#f472b6" data-right-color="#60a5fa">Gender</button>
    <button class="pathmap-toggle active" data-index="2" data-left-src="/images/cust path.jpg" data-right-src="/images/staff path.jpg" data-left-label="Customer" data-right-label="Staff" data-left-color="#34d399" data-right-color="#fbbf24">Staff</button>
  </div>
</div>

<style>
  .pathmap-compare {
    position: relative;
    cursor: col-resize;
    --split: 0.5;          /* 0 = all customer, 1 = all staff */
  }

  .pathmap-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.3);
    pointer-events: none;
    user-select: none;
  }

  .pathmap-reveal {
    position: absolute;
    inset: 0;
    clip-path: inset(0 0 0 calc(var(--split) * 100%));
    will-change: clip-path;
  }

  .pathmap-left-clip {
    position: absolute;
    inset: 0;
    clip-path: inset(0 calc((1 - var(--split)) * 100%) 0 0);
    will-change: clip-path;
    z-index: 3;
  }

  /* ── labels ────────────────────────────────────── */
  .pathmap-label {
    position: absolute;
    top: 12px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: white;
    background: #0f172a;
    backdrop-filter: blur(6px);
    padding: 5px 12px;
    border-radius: 6px;
    border: 1px solid white;
    z-index: 3;
    pointer-events: none;
    user-select: none;
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .pathmap-label.left  { left: 12px; }
  .pathmap-label.right { right: 12px; }

  /* ── divider ───────────────────────────────────── */
  .pathmap-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: calc(var(--split) * 100%);
    width: 2px;
    background: rgba(255, 255, 255, 0.6);
    z-index: 2;
    pointer-events: none;
    transform: translateX(-50%);
    will-change: left;
  }

  .pathmap-handle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    border: 2px solid rgba(255, 255, 255, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  /* ── toggle buttons ────────────────────────────── */
  .pathmap-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pathmap-toggles {
    display: flex;
    justify-content: center;
    position: relative;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    padding: 4px;
    width: fit-content;
    margin: 0 auto;
  }

  .pathmap-slider {
    position: absolute;
    top: 4px;
    bottom: 4px;
    border-radius: 9999px;
    background: white;
    box-shadow: 0 0 16px rgba(255, 255, 255, 0.2);
    transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1), width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }

  .pathmap-toggle {
    position: relative;
    z-index: 1;
    padding: 0.6rem 1.8rem;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    background: transparent;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: color 0.25s ease;
  }

  .pathmap-toggle:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  .pathmap-toggle.active {
    color: #0f172a;
  }
</style>

<script>
  /* ---------- interactive slider logic ---------- */
  document.querySelectorAll<HTMLElement>('.pathmap-wrapper').forEach(wrapper => {
    const container = wrapper.querySelector<HTMLElement>('.pathmap-compare')!;
    const imgLeft = container.querySelector<HTMLImageElement>('.pathmap-img-left')!;
    const imgRight = container.querySelector<HTMLImageElement>('.pathmap-img-right')!;
    const labelLeft = container.querySelector<HTMLElement>('.pathmap-label.left')!;
    const labelRight = container.querySelector<HTMLElement>('.pathmap-label.right')!;
    const toggles = wrapper.querySelectorAll<HTMLButtonElement>('.pathmap-toggle');

    let interacting = false;
    let idleTimer: ReturnType<typeof setTimeout> | null = null;
    let lerpRaf: number | null = null;
    let currentSplit = 0.5;
    let targetSplit = 0.5;
    const lerpSpeed = 0.15; // 0–1, higher = snappier

    let wobbleRaf: number | null = null;
    let wobbleStart: number | null = null;

    function setSplit(value: number) {
      currentSplit = Math.min(1, Math.max(0, value));
      container.style.setProperty('--split', String(currentSplit));
    }

    /* ── label colors ──────────────────────────── */
    function applyLabelColors(btn: HTMLButtonElement) {
      const { leftColor, rightColor } = btn.dataset as { leftColor: string; rightColor: string };
      labelLeft.style.color = leftColor;
      labelLeft.style.borderColor = leftColor;
      labelRight.style.color = rightColor;
      labelRight.style.borderColor = rightColor;
    }

    // Apply initial colors from the active button
    const activeBtn = wrapper.querySelector<HTMLButtonElement>('.pathmap-toggle.active');
    if (activeBtn) applyLabelColors(activeBtn);

    /* ── smooth lerp loop ──────────────────────── */
    function startLerp() {
      if (lerpRaf !== null) return;
      function tick() {
        const diff = targetSplit - currentSplit;
        if (Math.abs(diff) < 0.001) {
          setSplit(targetSplit);
          lerpRaf = null;
          return;
        }
        setSplit(currentSplit + diff * lerpSpeed);
        lerpRaf = requestAnimationFrame(tick);
      }
      lerpRaf = requestAnimationFrame(tick);
    }

    function stopLerp() {
      if (lerpRaf !== null) {
        cancelAnimationFrame(lerpRaf);
        lerpRaf = null;
      }
    }

    /* ── sliding indicator ──────────────────────── */
    const slider = wrapper.querySelector<HTMLElement>('.pathmap-slider')!;

    function moveSlider(btn: HTMLButtonElement) {
      const parentRect = btn.parentElement!.getBoundingClientRect();
      const btnRect = btn.getBoundingClientRect();
      const left = btnRect.left - parentRect.left;
      slider.style.left = `${left}px`;
      slider.style.width = `${btnRect.width}px`;
    }

    /* ── toggle buttons ────────────────────────── */
    function applyView(btn: HTMLButtonElement) {
      const d = btn.dataset as Record<string, string>;
      toggles.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      imgLeft.src = d.leftSrc;
      imgLeft.alt = d.leftLabel;
      imgRight.src = d.rightSrc;
      imgRight.alt = d.rightLabel;
      labelLeft.textContent = d.leftLabel;
      labelRight.textContent = d.rightLabel;
      applyLabelColors(btn);
      moveSlider(btn);
    }

    toggles.forEach(btn => btn.addEventListener('click', () => applyView(btn)));

    // Position slider on initial active button
    if (activeBtn) moveSlider(activeBtn);
    window.addEventListener('resize', () => {
      const current = wrapper.querySelector<HTMLButtonElement>('.pathmap-toggle.active');
      if (current) moveSlider(current);
    });

    /* ── pointer interaction ───────────────────── */
    function updateFromPointer(e: PointerEvent | MouseEvent | TouchEvent) {
      const rect = container.getBoundingClientRect();
      let clientX: number;
      if ('touches' in e) {
        clientX = e.touches[0].clientX;
      } else {
        clientX = (e as MouseEvent).clientX;
      }
      targetSplit = (clientX - rect.left) / rect.width;
      startLerp();
    }

    function startInteract(e: PointerEvent | MouseEvent | TouchEvent) {
      interacting = true;
      stopWobble();
      if (idleTimer) clearTimeout(idleTimer);
      updateFromPointer(e);
    }

    function stopInteract() {
      interacting = false;
      scheduleIdle();
    }

    /* ── mouse: track on hover ─────────────────── */
    container.addEventListener('mousemove', (e) => {
      if (!interacting) startInteract(e);
      updateFromPointer(e);
    });
    container.addEventListener('mouseleave', () => stopInteract());

    /* ── touch support ─────────────────────────── */
    container.addEventListener('touchstart', (e) => { e.preventDefault(); startInteract(e); }, { passive: false });
    container.addEventListener('touchmove', (e) => { e.preventDefault(); updateFromPointer(e); }, { passive: false });
    container.addEventListener('touchend', () => stopInteract());
    container.addEventListener('touchcancel', () => stopInteract());

    /* ── idle wobble (JS-driven for cross-browser) */
    function startWobble() {
      stopLerp();
      wobbleStart = performance.now();
      function tick(now: number) {
        if (interacting) return;
        const elapsed = (now - (wobbleStart as number)) / 1000;
        const v = 0.5 + Math.sin(elapsed * ((2 * Math.PI) / 6)) * 0.18;
        setSplit(v);
        wobbleRaf = requestAnimationFrame(tick);
      }
      wobbleRaf = requestAnimationFrame(tick);
    }

    function stopWobble() {
      if (wobbleRaf !== null) {
        cancelAnimationFrame(wobbleRaf);
        wobbleRaf = null;
      }
      wobbleStart = null;
    }

    function scheduleIdle() {
      if (idleTimer) clearTimeout(idleTimer);
      idleTimer = setTimeout(() => {
        if (!interacting) startWobble();
      }, 1500);
    }

    /* kick off idle wobble on load */
    startWobble();
  });
</script>
