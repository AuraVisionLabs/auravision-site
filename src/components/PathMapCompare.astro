---
/**
 * Interactive before/after image comparison slider.
 * Hover (or touch-drag) slides between two images.
 * When idle the divider gently oscillates to hint at interactivity.
 * Toggle buttons below switch between Age, Gender, and Staff views.
 */
---

<div class="pathmap-wrapper flex flex-col gap-3">
  <div class="pathmap-compare relative cursor-col-resize rounded-2xl bg-white/[0.03] overflow-hidden select-none" style="aspect-ratio: 16 / 10; --split: 0.5; --left-color: #34d399; --right-color: #fbbf24;" role="img" aria-label="Compare heatmaps">
    <!-- Left (base layer) -->
    <img src="/images/cust path.jpg" alt="Customer path map" data-role="img-left" class="absolute inset-0 w-full h-full object-cover scale-130 pointer-events-none select-none" draggable="false" />

    <!-- Left label (clipped to left side of split) -->
    <div class="pathmap-left-clip absolute inset-0 z-[4] will-change-[clip-path]">
      <div class="pathmap-border-left absolute inset-0 rounded-2xl border-2 pointer-events-none opacity-60" style="border-color: var(--left-color); transition: border-color 0.3s ease-in-out;"></div>
      <span data-role="label-left" class="absolute top-3 left-3 text-[0.85rem] font-semibold tracking-[0.06em] uppercase text-white bg-slate-900 backdrop-blur-[6px] px-3 py-[5px] rounded-md border border-white z-[3] pointer-events-none select-none transition-[color,border-color] duration-300 ease-in-out">Customer</span>
    </div>

    <!-- Right (reveal layer, clipped) -->
    <div class="pathmap-reveal absolute inset-0 z-[2] will-change-[clip-path]">
      <img src="/images/staff path.jpg" alt="Staff path map" data-role="img-right" class="absolute inset-0 w-full h-full object-cover scale-130 pointer-events-none select-none" draggable="false" />
      <div class="pathmap-border-right absolute inset-0 rounded-2xl border-2 pointer-events-none opacity-60" style="border-color: var(--right-color); transition: border-color 0.3s ease-in-out;"></div>
      <span data-role="label-right" class="absolute top-3 right-3 text-[0.85rem] font-semibold tracking-[0.06em] uppercase text-white bg-slate-900 backdrop-blur-[6px] px-3 py-[5px] rounded-md border border-white z-[3] pointer-events-none select-none transition-[color,border-color] duration-300 ease-in-out">Staff</span>
    </div>

    <!-- Divider line + handle -->
    <div class="pathmap-divider absolute top-0 bottom-0 w-0.5 bg-white/60 z-[5] pointer-events-none -translate-x-1/2 will-change-[left]">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 size-9 rounded-full bg-black/55 backdrop-blur border-2 border-white/60 flex items-center justify-center text-white">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M7 4L3 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M13 4L17 10L13 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Toggle buttons -->
  <div class="pathmap-toggles flex justify-center relative border border-white/10 bg-white/[0.08] rounded-full p-2 w-fit mx-auto">
    <div class="pathmap-slider absolute top-2 bottom-2 rounded-full bg-white shadow-[0_0_16px_rgba(255,255,255,0.2)] transition-[left,width] duration-300 ease-in-out z-0"></div>
    <button class="pathmap-toggle relative z-[1] px-[1.8rem] py-[0.6rem] text-[0.9rem] font-semibold tracking-[0.06em] uppercase text-white/50 bg-transparent border-none rounded-full cursor-pointer transition-colors duration-[250ms] ease-in-out hover:text-white/85" data-index="0" data-left-src="/images/16 dwell.jpg" data-right-src="/images/25 dwell.jpg" data-left-label="Age 16" data-right-label="Age 25" data-left-color="#f97316" data-right-color="#ec4899">Age</button>
    <button class="pathmap-toggle relative z-[1] px-[1.8rem] py-[0.6rem] text-[0.9rem] font-semibold tracking-[0.06em] uppercase text-white/50 bg-transparent border-none rounded-full cursor-pointer transition-colors duration-[250ms] ease-in-out hover:text-white/85" data-index="1" data-left-src="/images/female dwell.jpg" data-right-src="/images/male dwell.jpg" data-left-label="Female" data-right-label="Male" data-left-color="#f472b6" data-right-color="#60a5fa">Gender</button>
    <button class="pathmap-toggle active relative z-[1] px-[1.8rem] py-[0.6rem] text-[0.9rem] font-semibold tracking-[0.06em] uppercase text-white/50 bg-transparent border-none rounded-full cursor-pointer transition-colors duration-[250ms] ease-in-out hover:text-white/85" data-index="2" data-left-src="/images/cust path.jpg" data-right-src="/images/staff path.jpg" data-left-label="Customer" data-right-label="Staff" data-left-color="#34d399" data-right-color="#fbbf24">Staff</button>
  </div>
</div>

<style>
  /* Dynamic split position — requires CSS custom property */
  .pathmap-reveal {
    clip-path: inset(0 0 0 calc(var(--split) * 100%));
  }
  .pathmap-left-clip {
    clip-path: inset(0 calc((1 - var(--split)) * 100%) 0 0);
  }
  .pathmap-divider {
    left: calc(var(--split) * 100%);
  }

  /* JS-toggled active state */
  .pathmap-toggle.active {
    color: #0f172a;
  }
</style>

<script>
  /* ---------- interactive slider logic ---------- */
  document.querySelectorAll<HTMLElement>('.pathmap-wrapper').forEach(wrapper => {
    const container = wrapper.querySelector<HTMLElement>('.pathmap-compare')!;
    const imgLeft = container.querySelector<HTMLImageElement>('[data-role="img-left"]')!;
    const imgRight = container.querySelector<HTMLImageElement>('[data-role="img-right"]')!;
    const labelLeft = container.querySelector<HTMLElement>('[data-role="label-left"]')!;
    const labelRight = container.querySelector<HTMLElement>('[data-role="label-right"]')!;
    const toggles = wrapper.querySelectorAll<HTMLButtonElement>('.pathmap-toggle');

    let interacting = false;
    let idleTimer: ReturnType<typeof setTimeout> | null = null;
    let lerpRaf: number | null = null;
    let currentSplit = 0.5;
    let targetSplit = 0.5;
    const lerpSpeed = 0.15; // 0–1, higher = snappier

    let wobbleRaf: number | null = null;
    let wobbleStart: number | null = null;

    function setSplit(value: number) {
      currentSplit = Math.min(1, Math.max(0, value));
      container.style.setProperty('--split', String(currentSplit));
    }

    /* ── label colors ──────────────────────────── */
    function applyLabelColors(btn: HTMLButtonElement) {
      const { leftColor, rightColor } = btn.dataset as { leftColor: string; rightColor: string };
      labelLeft.style.color = leftColor;
      labelLeft.style.borderColor = leftColor;
      labelRight.style.color = rightColor;
      labelRight.style.borderColor = rightColor;
      container.style.setProperty('--left-color', leftColor);
      container.style.setProperty('--right-color', rightColor);
    }

    // Apply initial colors from the active button
    const activeBtn = wrapper.querySelector<HTMLButtonElement>('.pathmap-toggle.active');
    if (activeBtn) applyLabelColors(activeBtn);

    /* ── smooth lerp loop ──────────────────────── */
    function startLerp() {
      if (lerpRaf !== null) return;
      function tick() {
        const diff = targetSplit - currentSplit;
        if (Math.abs(diff) < 0.001) {
          setSplit(targetSplit);
          lerpRaf = null;
          return;
        }
        setSplit(currentSplit + diff * lerpSpeed);
        lerpRaf = requestAnimationFrame(tick);
      }
      lerpRaf = requestAnimationFrame(tick);
    }

    function stopLerp() {
      if (lerpRaf !== null) {
        cancelAnimationFrame(lerpRaf);
        lerpRaf = null;
      }
    }

    /* ── sliding indicator ──────────────────────── */
    const slider = wrapper.querySelector<HTMLElement>('.pathmap-slider')!;

    function moveSlider(btn: HTMLButtonElement) {
      const parentRect = btn.parentElement!.getBoundingClientRect();
      const btnRect = btn.getBoundingClientRect();
      const left = btnRect.left - parentRect.left;
      slider.style.left = `${left}px`;
      slider.style.width = `${btnRect.width}px`;
    }

    /* ── toggle buttons ────────────────────────── */
    function applyView(btn: HTMLButtonElement) {
      const d = btn.dataset as Record<string, string>;
      toggles.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      imgLeft.src = d.leftSrc;
      imgLeft.alt = d.leftLabel;
      imgRight.src = d.rightSrc;
      imgRight.alt = d.rightLabel;
      labelLeft.textContent = d.leftLabel;
      labelRight.textContent = d.rightLabel;
      applyLabelColors(btn);
      moveSlider(btn);
    }

    toggles.forEach(btn => btn.addEventListener('click', () => applyView(btn)));

    // Position slider on initial active button
    if (activeBtn) moveSlider(activeBtn);
    window.addEventListener('resize', () => {
      const current = wrapper.querySelector<HTMLButtonElement>('.pathmap-toggle.active');
      if (current) moveSlider(current);
    });

    /* ── pointer interaction ───────────────────── */
    function updateFromPointer(e: PointerEvent | MouseEvent | TouchEvent) {
      const rect = container.getBoundingClientRect();
      let clientX: number;
      if ('touches' in e) {
        clientX = e.touches[0].clientX;
      } else {
        clientX = (e as MouseEvent).clientX;
      }
      targetSplit = (clientX - rect.left) / rect.width;
      startLerp();
    }

    function startInteract(e: PointerEvent | MouseEvent | TouchEvent) {
      interacting = true;
      stopWobble();
      if (idleTimer) clearTimeout(idleTimer);
      updateFromPointer(e);
    }

    function stopInteract() {
      interacting = false;
      // Smoothly lerp back toward center before wobble kicks in
      targetSplit = 0.5;
      startLerp();
      scheduleIdle();
    }

    /* ── mouse: track on hover ─────────────────── */
    container.addEventListener('mousemove', (e) => {
      if (!interacting) startInteract(e);
      updateFromPointer(e);
    });
    container.addEventListener('mouseleave', () => stopInteract());

    /* ── touch support ─────────────────────────── */
    container.addEventListener('touchstart', (e) => { e.preventDefault(); startInteract(e); }, { passive: false });
    container.addEventListener('touchmove', (e) => { e.preventDefault(); updateFromPointer(e); }, { passive: false });
    container.addEventListener('touchend', () => stopInteract());
    container.addEventListener('touchcancel', () => stopInteract());

    /* ── idle wobble (JS-driven for cross-browser) */
    function startWobble() {
      stopLerp();
      // Phase-match: start the sine wave from wherever the slider currently is
      const offset = Math.max(-1, Math.min(1, (currentSplit - 0.5) / 0.4));
      const phase = Math.asin(offset);
      const phaseElapsed = phase / ((2 * Math.PI) / 6);
      wobbleStart = performance.now() - phaseElapsed * 1000;
      function tick(now: number) {
        if (interacting) return;
        const elapsed = (now - (wobbleStart as number)) / 1000;
        const v = 0.5 + Math.sin(elapsed * ((2 * Math.PI) / 6)) * 0.4;
        setSplit(v);
        wobbleRaf = requestAnimationFrame(tick);
      }
      wobbleRaf = requestAnimationFrame(tick);
    }

    function stopWobble() {
      if (wobbleRaf !== null) {
        cancelAnimationFrame(wobbleRaf);
        wobbleRaf = null;
      }
      wobbleStart = null;
    }

    function scheduleIdle() {
      if (idleTimer) clearTimeout(idleTimer);
      idleTimer = setTimeout(() => {
        if (!interacting) startWobble();
      }, 1500);
    }

    /* kick off idle wobble on load */
    startWobble();
  });
</script>
