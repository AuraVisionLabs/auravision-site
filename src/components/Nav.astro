---
import { Menu, X } from "@lucide/astro";
---

<header class="relative">
  <nav class="mx-auto flex max-w-site items-center justify-between px-4 py-3 lg:py-6 lg:px-8">
    <!-- Logo: icon on mobile, full wordmark on desktop -->
    <a href="/" class="flex-shrink-0 -ml-1 lg:-ml-3">
      <img
        src="/images/aura-vision-icon.svg"
        alt="Aura Vision"
        class="h-20 w-auto lg:hidden"
        loading="eager"
      />
      <img
        src="/images/aura-vision-wordmark.svg"
        alt="Aura Vision"
        class="hidden lg:block h-14 w-auto"
        loading="eager"
      />
    </a>

    <!-- Desktop links -->
    <div class="hidden lg:flex items-center gap-8 font-title text-sm text-white tracking-[0.05em]">
      <a
        href="/case-studies"
        class="hover:text-white/70 transition-colors duration-200"
      >
        Case Studies
      </a>
      <a
        href="/blog"
        class="hover:text-white/70 transition-colors duration-200"
      >
        Blog
      </a>
      <a
        href="/press"
        class="hover:text-white/70 transition-colors duration-200"
      >
        Press
      </a>
      <a
        href="/about"
        class="hover:text-white/70 transition-colors duration-200"
      >
        About
      </a>
      <a href="/contact" class="btn-pill">
        Contact us
      </a>
    </div>

    <!-- Mobile menu toggle -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-1 text-white"
      aria-label="Toggle menu"
    >
      <Menu id="menu-icon" class="h-8 w-8" stroke-width={1.5} />
      <X id="close-icon" class="h-8 w-8 hidden" stroke-width={1.5} />
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="pointer-events-none lg:hidden fixed inset-x-0 bottom-0 z-40 bg-slate-800 border-t border-white/10 opacity-0 transition-opacity duration-300 ease-out"
  >
    <div class="flex flex-col items-start gap-6 px-6 py-8 text-lg">
      <a href="/case-studies" class="mobile-nav-link text-white/70 hover:text-white transition-colors">
        Case Studies
      </a>
      <a href="/blog" class="mobile-nav-link text-white/70 hover:text-white transition-colors">
        Blog
      </a>
      <a href="/press" class="mobile-nav-link text-white/70 hover:text-white transition-colors">
        Press
      </a>
      <a href="/about" class="mobile-nav-link text-white/70 hover:text-white transition-colors">
        About
      </a>
      <a href="/contact" class="mobile-nav-link btn-pill mt-4">
        Contact
      </a>
    </div>
  </div>
</header>

<style>
  .mobile-nav-link {
    opacity: 0;
    transform: translateX(-1.5rem);
    transition: opacity 0.3s ease-out, transform 0.3s ease-out;
  }

  #mobile-menu.menu-open .mobile-nav-link {
    opacity: 1;
    transform: translateX(0);
  }

  #mobile-menu.menu-open .mobile-nav-link:nth-child(1) { transition-delay: 0.05s; }
  #mobile-menu.menu-open .mobile-nav-link:nth-child(2) { transition-delay: 0.1s; }
  #mobile-menu.menu-open .mobile-nav-link:nth-child(3) { transition-delay: 0.15s; }
  #mobile-menu.menu-open .mobile-nav-link:nth-child(4) { transition-delay: 0.2s; }
  #mobile-menu.menu-open .mobile-nav-link:nth-child(5) { transition-delay: 0.25s; }
</style>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");
  let isOpen = false;

  function setMenuTop() {
    const nav = document.querySelector("header nav");
    if (nav && menu) {
      menu.style.top = nav.offsetHeight + "px";
    }
  }

  function openMenu() {
    if (!menu) return;
    setMenuTop();
    menu.classList.remove("pointer-events-none");
    menu.classList.add("opacity-100");
    menu.classList.add("menu-open");
    menuIcon?.classList.add("hidden");
    closeIcon?.classList.remove("hidden");
    isOpen = true;
  }

  function closeMenu() {
    if (!menu) return;
    menu.classList.remove("menu-open");
    menu.classList.remove("opacity-100");
    menu.classList.add("pointer-events-none");
    menuIcon?.classList.remove("hidden");
    closeIcon?.classList.add("hidden");
    isOpen = false;
  }

  btn?.addEventListener("click", () => {
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  window.addEventListener("resize", setMenuTop);
</script>
