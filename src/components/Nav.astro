---
import { Menu, X } from "@lucide/astro";
---

<header class="relative">
  <nav class="mx-auto flex max-w-site items-center justify-between px-4 py-6 lg:py-6 lg:px-8">
    <!-- Logo: icon on mobile, full wordmark on desktop -->
    <a href="/" class="flex-shrink-0 -ml-1 lg:-ml-3">
      <img
        src="/images/aura-vision-icon.svg"
        alt="Aura Vision"
        class="h-20 w-auto lg:hidden"
        loading="eager"
      />
      <img
        src="/images/aura-vision-wordmark.svg"
        alt="Aura Vision"
        class="hidden lg:block h-14 w-auto"
        loading="eager"
      />
    </a>

    <!-- Desktop links -->
    <div class="hidden lg:flex items-center gap-8 font-title text-sm text-white tracking-[0.05em]">
      <a
        href="/case-studies"
        class="hover:text-white/70 transition-colors duration-200"
      >
        Case Studies
      </a>
      <a
        href="/blog"
        class="hover:text-white/70 transition-colors duration-200"
      >
        Blog
      </a>
      <a
        href="/press"
        class="hover:text-white/70 transition-colors duration-200"
      >
        Press
      </a>
      <a
        href="/about"
        class="hover:text-white/70 transition-colors duration-200"
      >
        About
      </a>
      <a href="/contact" class="btn-pill">
        Contact us
      </a>
    </div>

    <!-- Mobile menu toggle -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-1 text-white"
      aria-label="Toggle menu"
    >
      <Menu id="menu-icon" class="h-8 w-8" stroke-width={1.5} />
      <X id="close-icon" class="h-8 w-8 hidden" stroke-width={1.5} />
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden fixed inset-x-0 bottom-0 z-40 bg-slate-800 border-t border-white/10"
  >
    <div class="flex flex-col items-start gap-6 px-6 py-8 text-lg">
      <a href="/case-studies" class="text-white/70 hover:text-white transition-colors">
        Case Studies
      </a>
      <a href="/blog" class="text-white/70 hover:text-white transition-colors">
        Blog
      </a>
      <a href="/press" class="text-white/70 hover:text-white transition-colors">
        Press
      </a>
      <a href="/about" class="text-white/70 hover:text-white transition-colors">
        About
      </a>
      <a href="/contact" class="btn-pill mt-4">
        Contact
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  function setMenuTop() {
    const nav = document.querySelector("header nav");
    if (nav && menu) {
      menu.style.top = nav.offsetHeight + "px";
    }
  }

  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
    setMenuTop();
  });

  window.addEventListener("resize", setMenuTop);
</script>
