<header class="fixed top-0 inset-x-0 z-50 border-b border-white/5 bg-slate-950/60 backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <!-- Logo (wordmark) -->
    <a href="/" class="flex-shrink-0">
      <img
        src="/images/aura-vision-wordmark.svg"
        alt="Aura Vision"
        class="h-6 w-auto"
        loading="eager"
      />
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      <a
        href="/#case-studies"
        class="text-sm text-white/60 hover:text-white transition-colors duration-200"
      >
        Case Studies
      </a>
      <a
        href="/contact"
        class="text-sm text-white/60 hover:text-white transition-colors duration-200"
      >
        Contact
      </a>
      <a
        href="/contact"
        class="ml-2 inline-flex items-center rounded-full bg-accent px-5 py-2 text-sm font-medium text-white hover:bg-accent-muted transition-colors duration-200"
      >
        Book a Demo
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Toggle menu"
    >
      <span class="block h-px w-6 bg-white transition-transform duration-200" id="bar1"></span>
      <span class="block h-px w-6 bg-white transition-opacity duration-200" id="bar2"></span>
      <span class="block h-px w-6 bg-white transition-transform duration-200" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden fixed inset-0 top-[57px] bg-slate-950/90 backdrop-blur-md z-40"
  >
    <div class="flex flex-col items-center justify-center gap-8 pt-20 text-lg">
      <a href="/#case-studies" class="text-white/70 hover:text-white transition-colors">
        Case Studies
      </a>
      <a href="/contact" class="text-white/70 hover:text-white transition-colors">
        Contact
      </a>
      <a
        href="/contact"
        class="mt-4 inline-flex items-center rounded-full bg-accent px-8 py-3 text-base font-medium text-white"
      >
        Book a Demo
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const bar1 = document.getElementById("bar1");
  const bar2 = document.getElementById("bar2");
  const bar3 = document.getElementById("bar3");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    if (!isOpen) {
      bar1?.classList.add("translate-y-[4px]", "rotate-45");
      bar2?.classList.add("opacity-0");
      bar3?.classList.add("-translate-y-[4px]", "-rotate-45");
    } else {
      bar1?.classList.remove("translate-y-[4px]", "rotate-45");
      bar2?.classList.remove("opacity-0");
      bar3?.classList.remove("-translate-y-[4px]", "-rotate-45");
    }
  });
</script>
