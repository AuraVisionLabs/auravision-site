---
import ChatAnimation from "./ChatAnimation.astro";
import Button from "./Button.astro";
---

<section class="relative pt-12 pb-24 md:pt-20 md:pb-32 overflow-hidden">
  <div class="mx-auto max-w-site px-6 lg:px-8 w-full">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Text - always first in DOM, displays first when stacked -->
      <div class="max-w-2xl">
        <h1 class="font-title text-4xl tracking-tight md:text-6xl lg:text-7xl leading-[1.05] text-gradient" data-text="Instantly validate any store decision.">
          Instantly validate any store decision.
        </h1>
        <p class="mt-8 max-w-lg text-2xl text-white/70 font-light md:text-4xl leading-[1.4]">
          Stop digging for answers, just <span class="text-white font-semibold">Ask&nbsp;Aura</span>.
        </p>
        <!-- <div class="mt-12">
          <Button href="/contact">
            Ask Aura a question
          </Button>
        </div> -->
      </div>

      <!-- Chat animation -->
      <div>
        <ChatAnimation />
      </div>
    </div>
  </div>
</section>
