---
import { ArrowRight } from "@lucide/astro";

interface Props {
  slug: string;
  title: string;
  client: string;
  clientLogo?: string;
  summary: string;
  coverImage?: string;
  headingLevel?: "h2" | "h3";
  class?: string;
}

const {
  slug,
  title,
  client,
  clientLogo,
  summary,
  coverImage,
  headingLevel = "h3",
  class: className,
} = Astro.props;

const Heading = headingLevel;
---

<a
  href={`/case-studies/${slug}`}
  class:list={[
    "group flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-sm overflow-hidden transition-all duration-300 hover:border-cyan-400/30 hover:bg-white/[0.06] hover:shadow-[0_0_40px_rgba(8,145,178,1.0)]",
    className,
  ]}
>
  {coverImage && (
    <div class="aspect-video overflow-hidden bg-white/5">
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    </div>
  )}
  <div class="p-6 flex flex-col flex-grow">
    <Heading class="font-title text-xl tracking-tight mb-3 text-white group-hover:text-accent transition-colors duration-300">
      {title}
    </Heading>

    <div class="mt-auto flex items-center justify-between gap-4">
      <span class="shrink-0 inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-full bg-white/10 text-white/70 group-hover:bg-accent/20 group-hover:text-accent transition-all duration-300 whitespace-nowrap">
        Read story
        <ArrowRight class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5" />
      </span>

      {clientLogo && (
        <img
          src={clientLogo}
          alt={client}
          class="h-8 max-w-[120px] w-auto object-contain flex-shrink opacity-60 [filter:brightness(0)_invert(1)]"
        />
      )}
    </div>
  </div>
</a>
