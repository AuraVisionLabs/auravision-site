---
import { ExternalLink } from "@lucide/astro";

interface Props {
  title: string;
  publication: string;
  pubDate: Date;
  externalUrl: string;
  coverImage?: string;
  containImage?: boolean;
  summary: string;
  headingLevel?: "h2" | "h3";
  class?: string;
}

const {
  title,
  publication,
  pubDate,
  externalUrl,
  coverImage,
  containImage = false,
  summary,
  headingLevel = "h3",
  class: className,
} = Astro.props;

const Heading = headingLevel;

const formattedDate = pubDate.toLocaleDateString("en-GB", {
  day: "numeric",
  month: "short",
  year: "numeric",
});
---

<a
  href={externalUrl}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    "group flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-sm overflow-hidden transition-all duration-300 hover:border-cyan-400/30 hover:bg-white/[0.06] hover:shadow-[0_0_40px_rgba(8,145,178,1.0)]",
    className,
  ]}
>
  {coverImage ? (
    <div class:list={["aspect-video overflow-hidden flex items-center justify-center", containImage ? "bg-gray-50 p-6" : "bg-gray-50"]}>
      <img
        src={coverImage}
        alt={title}
        class:list={["transition-transform duration-500 group-hover:scale-105", containImage ? "max-w-full max-h-full w-auto h-auto object-contain" : "w-full h-full object-cover"]}
      />
    </div>
  ) : (
    <div class="aspect-video overflow-hidden bg-gray-50 flex items-center justify-center">
      <img
        src="/images/aura-vision-icon.svg"
        alt="Aura Vision"
        class="h-16 w-auto opacity-20 transition-opacity duration-300 group-hover:opacity-35"
      />
    </div>
  )}
  <div class="p-6 flex flex-col flex-grow">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-xs font-medium px-3 py-1 rounded-full bg-accent/10 text-accent">
        {publication}
      </span>
      <span class="text-xs text-white/40">
        {formattedDate}
      </span>
    </div>

    <Heading class="font-title text-xl tracking-tight mb-5 text-white group-hover:text-accent transition-colors duration-300">
      {title}
    </Heading>

    <div class="mt-auto">
      <span class="shrink-0 inline-flex items-center gap-2 text-xs font-medium px-4 py-2 rounded-full bg-white/10 text-white/70 group-hover:bg-accent/20 group-hover:text-accent transition-all duration-300 whitespace-nowrap">
        Read article
        <ExternalLink class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5" />
      </span>
    </div>
  </div>
</a>
