---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const studies = await getCollection("case-studies");
  return studies.map((study: CollectionEntry<"case-studies">) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

interface Props {
  study: CollectionEntry<"case-studies">;
}

const { study } = Astro.props;
const { Content } = await study.render();

const formattedDate = study.data.pubDate.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
});
---

<BaseLayout
  title={study.data.title}
  description={study.data.summary}
  ogImage={study.data.coverImage}
>
  <Nav />

  <main class="pt-32 pb-24 px-6 md:px-12 max-w-5xl mx-auto">
    <!-- Header -->
    <div class="mb-16">
      <p class="text-xs uppercase tracking-widest text-white/40 mb-4">{study.data.client}</p>
      <h1 class="font-title text-4xl md:text-6xl tracking-tight leading-tight mb-6">
        {study.data.title}
      </h1>
      <p class="text-xl text-white/50 max-w-2xl leading-relaxed">{study.data.summary}</p>

      <div class="mt-10 flex flex-wrap gap-x-12 gap-y-6 text-sm">
        <div>
          <p class="text-white/30 uppercase tracking-widest text-xs mb-1">Date</p>
          <p class="text-white/70">{formattedDate}</p>
        </div>
        {
          study.data.services && study.data.services.length > 0 && (
            <div>
              <p class="text-white/30 uppercase tracking-widest text-xs mb-1">Services</p>
              <p class="text-white/70">{study.data.services.join(", ")}</p>
            </div>
          )
        }
        {
          study.data.tags && study.data.tags.length > 0 && (
            <div>
              <p class="text-white/30 uppercase tracking-widest text-xs mb-1">Tags</p>
              <div class="flex flex-wrap gap-2 mt-1">
                {study.data.tags.map((tag: string) => (
                  <span class="text-xs px-3 py-1 rounded-full border border-white/5 bg-white/[0.03] text-white/40">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>

    <!-- Key Results -->
    {
      study.data.metrics && study.data.metrics.length > 0 && (
        <div class="mb-16 rounded-2xl border border-white/10 bg-gradient-to-br from-white/[0.04] to-white/[0.01] backdrop-blur-sm p-8 md:p-10">
          <h2 class="font-title text-lg uppercase tracking-widest text-white/40 mb-8">Key Results</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6">
            {study.data.metrics.map((metric: { value: string; label: string }, i: number) => (
              <div class:list={[
                "flex flex-col items-center text-center md:items-start md:text-left",
                i > 0 && "border-t md:border-t-0 md:border-l border-white/10 pt-8 md:pt-0 md:pl-6"
              ]}>
                <p class="font-title text-4xl md:text-5xl tracking-tight text-accent mb-2">
                  {metric.value}
                </p>
                <p class="text-sm md:text-base text-white/50 leading-relaxed">{metric.label}</p>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <!-- Cover image -->
    {
      study.data.coverImage && (
        <div class="mb-16 aspect-video rounded-2xl overflow-hidden bg-white/5">
          <img
            src={study.data.coverImage}
            alt={study.data.title}
            class="w-full h-full object-cover"
          />
        </div>
      )
    }

    <!-- Body content -->
    <article class="case-study-prose">
      <Content />
    </article>
  </main>

  <Footer />
</BaseLayout>
