---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import TestimonialCard from "../../components/TestimonialCard.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { ArrowLeft } from "@lucide/astro";

export async function getStaticPaths() {
  const studies = await getCollection("case-studies");
  return studies.map((study: CollectionEntry<"case-studies">) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

interface Props {
  study: CollectionEntry<"case-studies">;
}

const { study } = Astro.props;

const formattedDate = study.data.pubDate.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
});

// Split markdown body at testimonial marker, render each part to HTML
import { marked } from "marked";

const TESTIMONIAL_MARKER = "<!-- testimonial -->";
const rawBody = study.body ?? "";
const testimonial = study.data.testimonial;
const hasMarker = testimonial && rawBody.includes(TESTIMONIAL_MARKER);

let contentParts: string[];
if (hasMarker) {
  const [before, after] = rawBody.split(TESTIMONIAL_MARKER);
  contentParts = [await marked.parse(before), await marked.parse(after)];
} else {
  contentParts = [await marked.parse(rawBody)];
}
---

<BaseLayout
  title={study.data.title}
  description={study.data.summary}
  ogImage={study.data.coverImage}
>
  <Nav />

  <main class="page-padding">
    <div class="container-site">

      <!-- Back link -->
      <a href="/case-studies" class="inline-flex items-center gap-2 rounded-full border border-white/20 px-5 py-2 text-sm text-white/60 hover:bg-white/10 hover:text-white transition-all duration-300 mb-10 group">
        <ArrowLeft class="w-4 h-4 transition-transform group-hover:-translate-x-1" />
        Back to case studies
      </a>

      <!-- Title block -->
      <div class="mb-8">
        <p class="text-xs uppercase tracking-widest text-white/40 mb-4">{study.data.client} · {formattedDate}</p>
        <h1 class="font-title font-normal text-3xl md:text-4xl lg:text-5xl tracking-tight leading-tight mb-4 text-gradient" data-text={study.data.title}>
          {study.data.title}
        </h1>
        <div class="flex items-center justify-between gap-8">
          <p class="text-lg text-white/50 leading-relaxed max-w-3xl">{study.data.summary}</p>
          {study.data.clientLogo && (
            <img
              src={study.data.clientLogo}
              alt={study.data.client}
              class="hidden md:block max-h-[57.6px] max-w-[150px] w-auto shrink-0 object-contain opacity-50 [filter:brightness(0)_invert(1)]"
            />
          )}
        </div>
      </div>

      <!-- Cover image + Key Results -->
      <div class="mb-16 rounded-2xl overflow-hidden border border-white/10 bg-white/[0.03] backdrop-blur-sm">
        {
          study.data.coverImage && (
            <div class="max-h-[480px] overflow-hidden">
              <img
                src={study.data.coverImage}
                alt={study.data.title}
                class="w-full h-full object-cover"
              />
            </div>
          )
        }
        {
          study.data.metrics && study.data.metrics.length > 0 && (
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 p-4 border-t border-white/10">
              {study.data.metrics.map((metric: { value: string; label: string }) => (
                <div class="flex items-center gap-4 rounded-full bg-white/5 px-5 py-3">
                  <p class="font-title text-2xl md:text-3xl tracking-tight text-accent leading-none shrink-0">
                    {metric.value}
                  </p>
                  <p class="font-title text-sm text-white/50">{metric.label}</p>
                </div>
              ))}
            </div>
          )
        }
      </div>

      <!-- Article body -->
      <article class="case-study-prose mx-auto max-w-3xl">
        <Fragment set:html={contentParts[0]} />
      </article>

      <!-- Testimonial (inline if marker present, otherwise after article) -->
      {
        testimonial && (
          <div class="mx-auto max-w-xl my-12">
            <TestimonialCard
              headliner={testimonial.headliner}
              quote={testimonial.quote}
              name={testimonial.name}
              role={testimonial.role}
              photo={testimonial.photo}
              logo={study.data.clientLogo}
              company={study.data.client}
            />
          </div>
        )
      }

      {contentParts.length > 1 && (
        <article class="case-study-prose mx-auto max-w-3xl">
          <Fragment set:html={contentParts[1]} />
        </article>
      )}

      <!-- Tags -->
      {
        study.data.tags && study.data.tags.length > 0 && (
            <div class="mt-16 pt-8">
              <div class="flex flex-wrap gap-2">
                {study.data.tags.map((tag: string) => (
                  <span class="text-xs px-3 py-1 rounded-full border border-white/10 bg-white/[0.03] text-white/40">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
        )
      }
    </div>
  </main>

  <Footer />
</BaseLayout>
