---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { ArrowLeft } from "@lucide/astro";

export async function getStaticPaths() {
  const studies = await getCollection("case-studies");
  return studies.map((study: CollectionEntry<"case-studies">) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

interface Props {
  study: CollectionEntry<"case-studies">;
}

const { study } = Astro.props;
const { Content } = await study.render();

const formattedDate = study.data.pubDate.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
});
---

<BaseLayout
  title={study.data.title}
  description={study.data.summary}
  ogImage={study.data.coverImage}
>
  <Nav />

  <main class="pt-8 pb-24 md:pt-12 md:pb-32">
    <div class="container-site">

      <!-- Back link -->
      <a href="/case-studies" class="inline-flex items-center gap-2 rounded-full border border-white/20 px-5 py-2 text-sm text-white/60 hover:bg-white/10 hover:text-white transition-all duration-300 mb-10 group">
        <ArrowLeft class="w-4 h-4 transition-transform group-hover:-translate-x-1" />
        Back to case studies
      </a>

      <!-- Title block -->
      <div class="mb-8">
        <p class="text-xs uppercase tracking-widest text-white/40 mb-4">{study.data.client} · {formattedDate}</p>
        <h1 class="font-title font-normal text-3xl md:text-4xl lg:text-5xl tracking-tight leading-tight mb-4">
          {study.data.title}
        </h1>
        <p class="text-lg text-white/50 leading-relaxed max-w-3xl mb-6">{study.data.summary}</p>

        {/* Combined services & tags as pills */}
        {
          (() => {
            const allTags = [
              ...(study.data.services || []),
              ...(study.data.tags || []),
            ];
            return allTags.length > 0 ? (
              <div class="flex flex-wrap gap-2">
                {allTags.map((item: string) => (
                  <span class="text-xs px-3 py-1 rounded-full border border-white/10 bg-white/[0.03] text-white/40">
                    {item}
                  </span>
                ))}
              </div>
            ) : null;
          })()
        }
      </div>

      <!-- Cover image -->
      {
        study.data.coverImage && (
          <div class="mb-12 rounded-2xl overflow-hidden bg-white/5 max-h-[480px]">
            <img
              src={study.data.coverImage}
              alt={study.data.title}
              class="w-full h-full object-cover"
            />
          </div>
        )
      }

      <!-- Key Results panel -->
      {
        study.data.metrics && study.data.metrics.length > 0 && (
          <div class="mb-16 grid grid-cols-1 sm:grid-cols-3 gap-6">
            {study.data.metrics.map((metric: { value: string; label: string }) => (
              <div class="rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-sm p-6 text-center">
                <p class="font-title text-3xl md:text-4xl tracking-tight text-accent leading-none mb-2">
                  {metric.value}
                </p>
                <p class="font-title text-sm text-white/50">{metric.label}</p>
              </div>
            ))}
          </div>
        )
      }

      <!-- Article body -->
      <article class="case-study-prose mx-auto max-w-3xl">
        <Content />
      </article>
    </div>
  </main>

  <Footer />
</BaseLayout>
