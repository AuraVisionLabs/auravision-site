---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { ArrowLeft } from "@lucide/astro";

export async function getStaticPaths() {
  const studies = await getCollection("case-studies");
  return studies.map((study: CollectionEntry<"case-studies">) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

interface Props {
  study: CollectionEntry<"case-studies">;
}

const { study } = Astro.props;
const { Content } = await study.render();

const formattedDate = study.data.pubDate.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
});
---

<BaseLayout
  title={study.data.title}
  description={study.data.summary}
  ogImage={study.data.coverImage}
>
  <Nav />

  <main class="pt-32 pb-24 px-6 md:px-12">
    <div class="mx-auto max-w-7xl">

      <!-- Back link -->
      <a href="/case-studies" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white transition-colors mb-8 group">
        <ArrowLeft class="w-4 h-4 transition-transform group-hover:-translate-x-1" />
        Back
      </a>

      <!-- Cover image (contained with rounded corners) -->
      {
        study.data.coverImage && (
          <div class="mb-12 rounded-2xl overflow-hidden bg-white/5 max-h-[480px]">
            <img
              src={study.data.coverImage}
              alt={study.data.title}
              class="w-full h-full object-cover"
            />
          </div>
        )
      }

      <!-- Two-column layout: sidebar left, content right -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 lg:gap-16">

        <!-- Left column: title, meta, key results (sticky on desktop) -->
        <div class="lg:sticky lg:top-24 lg:self-start">
          <p class="text-xs uppercase tracking-widest text-white/40 mb-4">{study.data.client}</p>
          <h1 class="font-title text-3xl md:text-4xl lg:text-5xl tracking-tight leading-tight mb-4">
            {study.data.title}
          </h1>
          <p class="text-base text-white/50 leading-relaxed mb-8">{study.data.summary}</p>

          <div class="text-sm text-white/70 mb-8">
            {formattedDate}
          </div>

          {
            study.data.services && study.data.services.length > 0 && (
              <div class="mb-6">
                <p class="text-white/30 uppercase tracking-widest text-xs mb-2">Services</p>
                <p class="text-sm text-white/60">{study.data.services.join(" · ")}</p>
              </div>
            )
          }

          {
            study.data.tags && study.data.tags.length > 0 && (
              <div class="mb-8">
                <div class="flex flex-wrap gap-2">
                  {study.data.tags.map((tag: string) => (
                    <span class="text-xs px-3 py-1 rounded-full border border-white/5 bg-white/[0.03] text-white/40">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            )
          }

          <!-- Key Results -->
          {
            study.data.metrics && study.data.metrics.length > 0 && (
              <div class="border-t border-white/10 pt-8">
                <h2 class="font-title text-xs uppercase tracking-widest text-white/40 mb-6">Key Results</h2>
                <div class="space-y-6">
                  {study.data.metrics.map((metric: { value: string; label: string }) => (
                    <div>
                      <p class="font-title text-3xl md:text-4xl tracking-tight text-accent leading-none mb-1">
                        {metric.value}
                      </p>
                      <p class="text-sm text-white/50">{metric.label}</p>
                    </div>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        <!-- Right column: article body -->
        <article class="case-study-prose">
          <Content />
        </article>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
