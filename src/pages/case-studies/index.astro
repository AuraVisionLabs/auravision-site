---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import CaseStudyCard from "../../components/CaseStudyCard.astro";
import { getCollection } from "astro:content";

const studies = await getCollection("case-studies");
const sorted = studies.sort(
  (a, b) => (a.data.sortOrder ?? 999) - (b.data.sortOrder ?? 999) || b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Case Studies | Aura Vision",
  "description": "Explore how our retail partners turn their stores' data into business value using their existing CCTV infrastructure.",
  "url": "https://auravision.ai/case-studies",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": sorted.map((study, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": study.data.title,
      "url": `https://auravision.ai/case-studies/${study.slug}`
    }))
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://auravision.ai" },
    { "@type": "ListItem", "position": 2, "name": "Case Studies" }
  ]
};
---

<BaseLayout
  title="Case Studies"
  description="Explore how our retail partners turn their stores' data into business value using their existing CCTV infrastructure."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Nav />

  <main class="page-padding">
    <div class="container-site">
      <!-- Header -->
      <div class="mb-16 max-w-3xl">
        <h1 class="heading-section text-gradient" data-text="Customer Stories">
          Customer Stories
        </h1>
      </div>

      <!-- Grid -->
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          sorted.map((study) => (
            <CaseStudyCard
              slug={study.slug}
              title={study.data.title}
              client={study.data.client}
              clientLogo={study.data.clientLogo}
              summary={study.data.summary}
              coverImage={study.data.coverImage}
              headingLevel="h2"
            />
          ))
        }
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
