---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { ArrowLeft } from "@lucide/astro";
import { marked } from "marked";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const formattedDate = post.data.pubDate.toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const content = await marked.parse(post.body ?? "");

// Find related blog posts by tag overlap
const allPosts = await getCollection("blog");
const currentTags = new Set(post.data.tags ?? []);

const related = allPosts
  .filter((p) => p.slug !== post.slug)
  .map((p) => {
    const overlap = (p.data.tags ?? []).filter((t) => currentTags.has(t)).length;
    return { post: p, overlap };
  })
  .filter((r) => r.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap)
  .slice(0, 3)
  .map((r) => r.post);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.summary,
  "image": post.data.coverImage ? new URL(post.data.coverImage, Astro.site).href : undefined,
  "datePublished": post.data.pubDate.toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": "Aura Vision",
    "logo": {
      "@type": "ImageObject",
      "url": "https://auravision.ai/images/aura-vision-logo.svg",
    },
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://auravision.ai" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://auravision.ai/blog" },
    { "@type": "ListItem", "position": 3, "name": post.data.title },
  ],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.summary}
  ogImage={post.data.coverImage}
  ogType="article"
  publishedTime={post.data.pubDate.toISOString()}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Nav />

  <main class="page-padding">
    <div class="container-site">

      <!-- Back link -->
      <a href="/blog" class="inline-flex items-center gap-2 rounded-full border border-white/20 px-5 py-2 text-sm text-white/60 hover:bg-white/10 hover:text-white transition-all duration-300 mb-10 group">
        <ArrowLeft class="w-4 h-4 transition-transform group-hover:-translate-x-1" />
        Back to blog
      </a>

      <!-- Title block -->
      <div class="mb-8">
        <div class="flex items-center gap-4 mb-4">
          <p class="text-xs uppercase tracking-widest text-white/40">{formattedDate}</p>
        </div>
        <h1 class="font-title font-normal text-3xl md:text-4xl lg:text-5xl tracking-tight leading-tight mb-4 text-gradient" data-text={post.data.title}>
          {post.data.title}
        </h1>
        <p class="text-lg text-white/50 leading-relaxed max-w-3xl">{post.data.summary}</p>
      </div>

      <!-- Cover image -->
      {post.data.coverImage && (
        <div class="mb-16 rounded-2xl overflow-hidden border border-white/10 bg-white/[0.03] backdrop-blur-sm">
          <div class="max-h-[480px] overflow-hidden">
            <img
              src={post.data.coverImage}
              alt={post.data.title}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      )}

      <!-- Article body -->
      <article class="case-study-prose mx-auto max-w-3xl">
        <Fragment set:html={content} />
      </article>

      <!-- Tags -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="mt-16 pt-8">
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="text-xs px-3 py-1 rounded-full border border-white/10 bg-white/[0.03] text-white/40">
                {tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Related Posts -->
      {related.length > 0 && (
        <div class="mt-20 pt-12">
          <h2 class="font-title text-2xl tracking-tight mb-8 text-white/80">Related articles</h2>
          <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {related.map((r) => (
              <BlogCard
                slug={r.slug}
                title={r.data.title}
                pubDate={r.data.pubDate}
                summary={r.data.summary}
                coverImage={r.data.coverImage}
                tags={r.data.tags}
              />
            ))}
          </div>
        </div>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>
