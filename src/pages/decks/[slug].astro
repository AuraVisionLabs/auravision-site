---
import { getCollection } from "astro:content";
import DeckLayout from "../../layouts/DeckLayout.astro";

import CoverSlide from "../../components/slides/CoverSlide.astro";
import TechSlide from "../../components/slides/TechSlide.astro";
import TableSlide from "../../components/slides/TableSlide.astro";

export async function getStaticPaths() {
  const decks = await getCollection("decks");
  return decks.map((deck) => ({
    params: { slug: deck.slug || deck.id.replace(/\.md$/, "") },
    props: { deck },
  }));
}

const { deck } = Astro.props;
const { slides, title } = deck.data;
---

<DeckLayout title={title}>
  {slides.map((slide) => {
    switch (slide.type) {
      case "cover":
        return <CoverSlide title={slide.title} tagline={slide.tagline} logo={slide.logo} footer={slide.footer} />;
      case "tech":
        return <TechSlide title={slide.title} subtitle={slide.subtitle} callout={slide.callout} video={slide.video} category={slide.category} />;
      case "table":
        return <TableSlide title={slide.title} subtitle={slide.subtitle} colWidths={slide.colWidths} layout={slide.layout} rows={slide.rows} category={slide.category} />;
      default:
        return null;
    }
  })}
</DeckLayout>
