---
import { getCollection } from "astro:content";
import DeckLayout from "../../layouts/DeckLayout.astro";

import CoverSlide from "../../components/slides/CoverSlide.astro";
import MetricsSlide from "../../components/slides/MetricsSlide.astro";
import CaseStudySlide from "../../components/slides/CaseStudySlide.astro";
import TestimonialSlide from "../../components/slides/TestimonialSlide.astro";
import FeatureSlide from "../../components/slides/FeatureSlide.astro";
import LogoWallSlide from "../../components/slides/LogoWallSlide.astro";
import ImageSlide from "../../components/slides/ImageSlide.astro";
import TextSlide from "../../components/slides/TextSlide.astro";
import ComparisonSlide from "../../components/slides/ComparisonSlide.astro";
import CTASlide from "../../components/slides/CTASlide.astro";

export async function getStaticPaths() {
  const decks = await getCollection("decks");
  return decks.map((deck) => ({
    params: { slug: deck.slug || deck.id.replace(/\.md$/, "") },
    props: { deck },
  }));
}

const { deck } = Astro.props;
const { slides, title, prospect } = deck.data;
---

<DeckLayout title={title} prospect={prospect}>
  {slides.map((slide) => {
    switch (slide.type) {
      case "cover":
        return <CoverSlide title={slide.title} subtitle={slide.subtitle} logo={slide.logo} background={slide.background} />;
      case "metrics":
        return <MetricsSlide title={slide.title} items={slide.items} />;
      case "case-study":
        return <CaseStudySlide ref={slide.ref} />;
      case "testimonial":
        return <TestimonialSlide headliner={slide.headliner} quote={slide.quote} name={slide.name} role={slide.role} photo={slide.photo} logo={slide.logo} company={slide.company} />;
      case "feature":
        return <FeatureSlide title={slide.title} subtitle={slide.subtitle} bullets={slide.bullets} image={slide.image} reversed={slide.reversed} />;
      case "logo-wall":
        return <LogoWallSlide title={slide.title} logos={slide.logos} />;
      case "image":
        return <ImageSlide src={slide.src} alt={slide.alt} caption={slide.caption} />;
      case "text":
        return <TextSlide title={slide.title} subtitle={slide.subtitle} body={slide.body} bullets={slide.bullets} />;
      case "comparison":
        return <ComparisonSlide title={slide.title} left={slide.left} right={slide.right} />;
      case "cta":
        return <CTASlide title={slide.title} subtitle={slide.subtitle} buttonText={slide.buttonText} buttonHref={slide.buttonHref} />;
      default:
        return null;
    }
  })}
</DeckLayout>
