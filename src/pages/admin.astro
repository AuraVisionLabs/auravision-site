---
// Decap CMS admin panel.
// import.meta.env.DEV is true during `astro dev`, false in production builds.
const isDev = import.meta.env.DEV;
---

<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Content Manager | Auravision</title>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <script is:inline>window.CMS_MANUAL_INIT = true;</script>
    <script is:inline src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
    <script is:inline define:vars={{ isDev }}>
      CMS.registerEditorComponent({
        id: "testimonial",
        label: "Testimonial",
        pattern: /^<!-- testimonial -->$/m,
        fromBlock: function () {
          return {};
        },
        toBlock: function () {
          return "<!-- testimonial -->";
        },
        toPreview: function () {
          return '<div style="padding:16px;border:1px dashed #888;border-radius:8px;text-align:center;color:#888;">📣 Testimonial (from frontmatter) will appear here</div>';
        },
      });

      CMS.registerPreviewStyle(
        "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      );

      CMS.registerPreviewStyle(`
        body {
          font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
          color: #1a1a1a;
          line-height: 1.7;
          padding: 24px;
          max-width: 100%;
        }
        img {
          max-width: 100%;
          height: auto;
          border-radius: 8px;
        }
        h1, h2, h3, h4 {
          font-weight: 700;
          line-height: 1.3;
          margin-top: 1.5em;
          margin-bottom: 0.5em;
        }
        h1 { font-size: 1.75rem; }
        h2 { font-size: 1.4rem; }
        h3 { font-size: 1.15rem; }
        p { margin-bottom: 1em; }
        ul, ol { padding-left: 1.5em; margin-bottom: 1em; }
        li { margin-bottom: 0.35em; }
        strong { font-weight: 600; }
        blockquote {
          border-left: 3px solid #6366f1;
          padding-left: 1em;
          margin: 1.5em 0;
          color: #555;
          font-style: italic;
        }
        a { color: #6366f1; text-decoration: underline; }
      `, { raw: true });

      CMS.init({ config: isDev ? { local_backend: true } : {} });
    </script>
  </body>
</html>
