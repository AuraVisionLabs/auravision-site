---
// Decap CMS admin panel.
// import.meta.env.DEV is true during `astro dev`, false in production builds.
const isDev = import.meta.env.DEV;
---

<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Content Manager | Auravision</title>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <script is:inline>window.CMS_MANUAL_INIT = true;</script>
    <script is:inline src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
    <script is:inline define:vars={{ isDev }}>
      CMS.registerEditorComponent({
        id: "testimonial",
        label: "Testimonial",
        pattern: /^<!-- testimonial -->$/m,
        fromBlock: function () {
          return {};
        },
        toBlock: function () {
          return "<!-- testimonial -->";
        },
        toPreview: function () {
          return '<div style="padding:16px;border:1px dashed #888;border-radius:8px;text-align:center;color:#888;">📣 Testimonial (from frontmatter) will appear here</div>';
        },
      });

      CMS.registerPreviewStyle(
        "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      );

      CMS.registerPreviewStyle(`
        body {
          font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
          color: #1a1a1a;
          line-height: 1.7;
          padding: 24px;
          max-width: 100%;
        }
        img {
          max-width: 100%;
          height: auto;
          border-radius: 8px;
        }
        h1, h2, h3, h4 {
          font-weight: 700;
          line-height: 1.3;
          margin-top: 1.5em;
          margin-bottom: 0.5em;
        }
        h1 { font-size: 1.75rem; }
        h2 { font-size: 1.4rem; }
        h3 { font-size: 1.15rem; }
        p { margin-bottom: 1em; }
        ul, ol { padding-left: 1.5em; margin-bottom: 1em; }
        li { margin-bottom: 0.35em; }
        strong { font-weight: 600; }
        blockquote {
          border-left: 3px solid #6366f1;
          padding-left: 1em;
          margin: 1.5em 0;
          color: #555;
          font-style: italic;
        }
        a { color: #6366f1; text-decoration: underline; }
      `, { raw: true });

      /* ── Deck preview: iframe to the real rendered page ── */
      var DeckPreview = createClass({
        render: function() {
          var entry = this.props.entry;
          var data = entry.get('data');
          var title = data.get('title') || 'Untitled Deck';
          var slug = entry.get('slug') || '';
          var slides = (data.get('slides') || { toJS: function() { return []; } }).toJS();
          var deckUrl = '/decks/' + (slug || title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''));

          return h('div', { style: { fontFamily: "'Inter', -apple-system, BlinkMacSystemFont, sans-serif", background: '#111827', minHeight: '100vh', display: 'flex', flexDirection: 'column' } },
            /* header */
            h('div', { style: { padding: '16px 20px', display: 'flex', alignItems: 'center', justifyContent: 'space-between', borderBottom: '1px solid rgba(255,255,255,0.08)' } },
              h('div', {},
                h('h1', { style: { fontSize: '16px', fontWeight: 600, color: '#fff', margin: '0 0 2px' } }, title)
              ),
              h('div', { style: { display: 'flex', alignItems: 'center', gap: '12px' } },
                h('span', { style: { fontSize: '11px', color: '#64748b' } }, slides.length + ' slides'),
                h('a', { href: deckUrl, target: '_blank', rel: 'noopener noreferrer', style: { fontSize: '12px', color: '#22d3ee', textDecoration: 'none', fontFamily: 'monospace' } }, deckUrl)
              )
            ),
            /* iframe to real deck page */
            h('div', { style: { flex: 1, display: 'flex', flexDirection: 'column', minHeight: 0 } },
              h('iframe', {
                src: deckUrl + '?scroll',
                style: { width: '100%', flex: 1, border: 'none', background: '#0a0f1e' },
                title: 'Deck preview',
              })
            ),
            /* hint */
            h('div', { style: { padding: '8px 20px 16px', textAlign: 'center' } },
              h('p', { style: { fontSize: '11px', color: '#475569', margin: 0 } }, 'Save to update the preview. Click the URL to open the full deck.')
            )
          );
        }
      });

      CMS.registerPreviewTemplate('decks', DeckPreview);

      CMS.init({ config: isDev ? { local_backend: true } : {} });
    </script>
  </body>
</html>
