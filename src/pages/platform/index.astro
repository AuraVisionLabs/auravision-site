---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import ContactForm from "../../components/ContactForm.astro";
import { BarChart3, Users, Map, ShoppingCart, Zap, Shield, MonitorSmartphone, Cpu } from "@lucide/astro";

const features = [
  {
    icon: BarChart3,
    title: "Enhanced Footfall",
    description: "Discover new traffic and conversion opportunities with industry-leading counting accuracy. Benchmark location busyness with passer-by traffic counts and unique customer segmentation.",
  },
  {
    icon: Users,
    title: "Precision Staff Planning",
    description: "Align staffing rotas to real customer demand across every store, floor and department — improving the shopping experience for customers and staff alike.",
  },
  {
    icon: Map,
    title: "Path to Purchase",
    description: "See exactly where customers spend their time to optimise store utilisation and identify the best-performing concepts that maximise conversion.",
  },
  {
    icon: ShoppingCart,
    title: "Queue & Checkout Optimisation",
    description: "Reduce queue times and lost sales. Empower teams to deliver the best customer experiences and minimise abandoned purchases.",
  },
  {
    icon: BarChart3,
    title: "Sales Conversion",
    description: "Accurate customer-only counts, age filtering, segmented staff and sales data integration mean you can measure conversion performance more accurately than ever.",
  },
  {
    icon: Users,
    title: "Demographic Insights",
    description: "Comprehensive age and gender segmentation reveals how different customer groups use your stores, so you can design experiences that fully engage your audiences.",
  },
];

const howItWorks = [
  {
    step: "01",
    icon: Cpu,
    title: "Plug & play setup",
    description: "Connect our compact APU to your internet and existing CCTV system. Compatible with all leading IP camera brands. Analogue cameras work too via digital encoders.",
  },
  {
    step: "02",
    icon: Zap,
    title: "No-code AI personalisation",
    description: "Our team identifies zones of interest, trains AI on your staff uniforms and conducts fully transparent accuracy audits — all without a single line of code.",
  },
  {
    step: "03",
    icon: MonitorSmartphone,
    title: "Real-time insights",
    description: "Access your intuitive dashboard with unlimited users, email reports and API. Integrate with your sales data to measure conversion at store and department level.",
  },
];

const platformSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Aura Vision Platform",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Cloud-based",
  "description": "AI-powered retail analytics platform that transforms existing CCTV into actionable store insights — footfall, demographics, heatmaps, queue analytics and more.",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "GBP",
    "description": "Contact for pricing"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Aura Vision",
    "url": "https://auravision.ai"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://auravision.ai" },
    { "@type": "ListItem", "position": 2, "name": "Platform" }
  ]
};
---

<BaseLayout
  title="Platform"
  description="Actionable data for smarter retail decisions. Increase sales, reduce costs and improve customer experience using your existing cameras."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(platformSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Nav />

  <main class="page-padding">
    <!-- Hero -->
    <section class="pb-24 md:pb-32">
      <div class="container-site">
        <div class="max-w-3xl">
          <h1 class="heading-section text-gradient" data-text="Actionable data for smarter decisions">
            Actionable data for smarter decisions
          </h1>
          <p class="mt-6 text-xl text-white font-medium md:text-2xl">
            Increase sales, reduce costs and improve customer experience using your existing cameras.
          </p>
          <a href="https://calendly.com/zach-n5m/aura-vision-introduction" target="_blank" rel="noopener noreferrer" class="btn-pill mt-10">
            Book a call
          </a>
        </div>
      </div>
    </section>

    <!-- Features Grid -->
    <section class="section-major border-t border-white/10">
      <div class="container-site">
        <h2 class="font-title text-2xl tracking-tight text-white/80 mb-12">What you can do</h2>
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {features.map((feature) => (
            <div class="glass-card p-8">
              <feature.icon class="w-8 h-8 text-accent mb-5" stroke-width={1.5} />
              <h3 class="font-title text-xl tracking-tight text-white mb-3">{feature.title}</h3>
              <p class="text-body text-base">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="section-major border-t border-white/10">
      <div class="container-site">
        <div class="max-w-3xl mb-16">
          <h2 class="heading-section text-gradient" data-text="In-store visibility in 5 minutes">
            In-store visibility in 5 minutes
          </h2>
          <p class="mt-6 text-xl text-white font-medium md:text-2xl">
            No new hardware purchases. No complex integrations. Just plug in and go.
          </p>
        </div>

        <div class="grid gap-12 lg:grid-cols-3">
          {howItWorks.map((step) => (
            <div class="relative">
              <span class="font-mono text-6xl text-white/5 absolute -top-4 -left-2">{step.step}</span>
              <div class="relative">
                <step.icon class="w-8 h-8 text-accent mb-5" stroke-width={1.5} />
                <h3 class="font-title text-xl tracking-tight text-white mb-3">{step.title}</h3>
                <p class="text-body text-base">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Security & Privacy -->
    <section class="section-major border-t border-white/10">
      <div class="container-site">
        <div class="grid gap-16 md:grid-cols-2 items-start">
          <div>
            <Shield class="w-10 h-10 text-accent mb-6" stroke-width={1.5} />
            <h2 class="font-title text-3xl tracking-tight text-white mb-4">100% anonymous & secure</h2>
            <p class="text-body">
              Aura Vision never stores or transmits personal data from video cameras. Our AI runs on-premise, turning footage into anonymous count analytics that are discarded immediately. Only aggregated data reaches the cloud.
            </p>
          </div>
          <div class="grid gap-6">
            {[
              { label: "End-to-end encryption", detail: "AES-128 in transit, AES-256 at rest via AWS." },
              { label: "No inbound connections", detail: "APUs don't accept inbound requests — bad actors can't alter device software." },
              { label: "GDPR & privacy compliant", detail: "Deployable in any public space or retail store, meeting the world's strictest regulations." },
              { label: "Auth0 & role-based access", detail: "SSO, LDAP, MFA and granular permissions for every user." },
            ].map((item) => (
              <div class="glass-card p-6">
                <p class="font-title text-sm tracking-tight text-white mb-1">{item.label}</p>
                <p class="text-sm text-white/50">{item.detail}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <ContactForm title="See it in action" subtitle="Book a call to discover how our platform transforms your existing cameras into actionable retail insights." />
  <Footer />
</BaseLayout>
