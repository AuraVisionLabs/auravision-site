---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import LogoMarquee from "../components/LogoMarquee.astro";
import Hero from "../components/Hero.astro";
import MetricsGrid from "../components/MetricsGrid.astro";
import Testimonials from "../components/Testimonials.astro";
import FeatureSection from "../components/FeatureSection.astro";
import Button from "../components/Button.astro";
import { ArrowRight } from "@lucide/astro";
---

<BaseLayout title="Instant answers with Ask Aura">
  <Nav />

  <Hero />

  <!-- Logo Marquee -->
  <LogoMarquee />

  <!-- Centered Tagline -->
  <section class="pt-24 md:pt-32">
    <div class="mx-auto max-w-4xl px-6 text-center lg:px-8">
      <h2 class="font-title text-3xl leading-tight tracking-tight md:text-5xl lg:text-6xl text-gradient" data-text="Anonymous full-store analytics using your existing cameras">
        Anonymous full-store analytics using your existing cameras
      </h2>
      <p class="mt-6 text-xl text-white font-medium md:text-2xl">
        No new sensors. No personal data. Just answers.
      </p>
    </div>
  </section>

  <!-- Metrics Grid -->
  <MetricsGrid />

  <!-- Insanely Fast Install -->
  <FeatureSection
    title="Lightning fast install"
    subtitle="About 108x faster than a footfall counter."
    description="plug & play our tiny Point your existing cameras at our cloud. No sensors to mount, no wiring to run, no ladders required. Most stores are live in under an hour."
    linkText="How installation works"
  >
    <div slot="visual" class="flex items-center justify-center rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm aspect-video">
      <div class="flex flex-col items-center gap-6 px-8 w-full">
        <div class="w-full">
          <div class="flex items-center justify-between text-xs text-white/40 mb-2">
            <span>Traditional sensors</span>
            <span>Weeks</span>
          </div>
          <div class="h-3 w-full rounded-full bg-white/5">
            <div class="h-3 rounded-full bg-white/10" style="width: 100%"></div>
          </div>
        </div>
        <div class="w-full">
          <div class="flex items-center justify-between text-xs text-white/40 mb-2">
            <span>Auravision</span>
            <span>Minutes</span>
          </div>
          <div class="h-3 w-full rounded-full bg-white/5">
            <div class="h-3 rounded-full bg-accent" style="width: 8%"></div>
          </div>
        </div>
      </div>
    </div>
  </FeatureSection>

  <!-- Instant Validation -->
  <FeatureSection
    title="Accurate data"
    subtitle="Segment Age, Gender and Staff without facial recognition."
    description="See occupancy the moment cameras connect. Ask Aura any question about your stores and get answers in seconds — no analyst required. Historical trends, live counts, and mobile access all included."
    linkText="See the dashboard"
    reversed
  >
    <div slot="visual" class="flex items-center justify-center rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm aspect-video">
      <p class="text-sm text-white/20">Dashboard screenshot coming soon</p>
    </div>
  </FeatureSection>

  <!-- Unbelievably Precise Insights -->
  <FeatureSection
    title="Compelling stories"
    subtitle="Bring you closer to customers and staff."
    description="Unbelievably precise insights into who your customers are and how they're interacting with your sales associates."
    linkText="Ask Aura a question"
  >
    <div slot="visual" class="flex items-center justify-center rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm aspect-video">
      <div class="flex flex-col items-center gap-6 px-8 w-full">
        <div class="w-full">
          <div class="flex items-center justify-between text-xs text-white/40 mb-2">
            <span>Traditional sensors</span>
            <span>Weeks</span>
          </div>
          <div class="h-3 w-full rounded-full bg-white/5">
            <div class="h-3 rounded-full bg-white/10" style="width: 100%"></div>
          </div>
        </div>
        <div class="w-full">
          <div class="flex items-center justify-between text-xs text-white/40 mb-2">
            <span>Auravision</span>
            <span>Minutes</span>
          </div>
          <div class="h-3 w-full rounded-full bg-white/5">
            <div class="h-3 rounded-full bg-accent" style="width: 8%"></div>
          </div>
        </div>
      </div>
    </div>
  </FeatureSection>

  <!-- Word Is Out -->
  <Testimonials />

  <!-- Form and Function -->
  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <div class="text-center mb-20">
        <h2 class="font-title text-4xl tracking-tight md:text-5xl lg:text-6xl">
          <span class="text-gradient block" data-text="Cutting-edge computer vision">Cutting-edge computer vision</span>
          <span class="text-gradient block" data-text="that just works">that just works</span>
        </h2>
      </div>

      <div class="grid gap-16 md:grid-cols-2">
        <!-- Specs List -->
        <div class="space-y-8">
          <div class="border-b border-white/10 pb-6">
            <p class="text-xs font-medium uppercase tracking-widest text-white/40 mb-2">Cameras</p>
            <p class="font-title text-lg text-white/90">Works with Fisheye and Standard lense IP cameras</p>
          </div>
          <div class="border-b border-white/10 pb-6">
            <p class="text-xs font-medium uppercase tracking-widest text-white/40 mb-2">Demographics</p>
            <p class="font-title text-lg text-white/90">Age, gender & staff-customer segmentation</p>
          </div>
          <div class="border-b border-white/10 pb-6">
            <p class="text-xs font-medium uppercase tracking-widest text-white/40 mb-2">Latency</p>
            <p class="font-title text-lg text-white/90">Real-time processing, 15 minute granularity</p>
          </div>
          <div class="border-b border-white/10 pb-6">
            <p class="text-xs font-medium uppercase tracking-widest text-white/40 mb-2">Privacy</p>
            <p class="font-title text-lg text-white/90">GDPR & CCPA compliant, no PII stored, no facial recognition</p>
          </div>
          <div class="border-b border-white/10 pb-6">
            <p class="text-xs font-medium uppercase tracking-widest text-white/40 mb-2">API</p>
            <p class="font-title text-lg text-white/90">Full REST API and sales integration</p>
          </div>
          <div class="pb-6">
            <p class="text-xs font-medium uppercase tracking-widest text-white/40 mb-2">Scale</p>
            <p class="font-title text-lg text-white/90">1 to 10,000+ cameras</p>
          </div>
        </div>

        <!-- Visual / Highlights -->
        <div class="space-y-8">
          <div class="rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm p-8">
            <h3 class="font-title text-2xl mb-3 text-white font-medium">No new sensors</h3>
            <p class="text-lg leading-relaxed text-white">
              Leverage your existing security camera infrastructure. No footfall counters, wiring, or RFID tags.
            </p>
          </div>
          <div class="rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm p-8">
            <h3 class="font-title text-2xl mb-3 text-white font-medium">Scales with you</h3>
            <p class="text-lg leading-relaxed text-white">
              From a single entrance to an entire estate. Edge-first architecture means consistent performance whether you have one location or thousands.
            </p>
          </div>
          <div class="rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm p-8">
            <h3 class="font-title text-2xl mb-3 text-white font-medium">Budget friendly</h3>
            <p class="text-lg leading-relaxed text-white">
              No upfront hardware costs. Simple per-camera pricing that scales down as you grow. Contact us for volume pricing.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-6xl px-6 text-center lg:px-8">
      <h2 class="font-title text-4xl tracking-tight md:text-5xl text-gradient" data-text="Your teams need more than sales data">
        Your teams need more than sales data
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg text-white">
        You made it this far, so here goes — we're the world's second best in-store analytics provider, honest.
      </p>
      <Button href="/contact" class="mt-10">
        Book a demo to find out why
      </Button>
    </div>
  </section>

  <Footer />
</BaseLayout>


