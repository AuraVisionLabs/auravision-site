---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import LogoMarquee from "../components/LogoMarquee.astro";
import Hero from "../components/Hero.astro";
import MetricsGrid from "../components/MetricsGrid.astro";
import Testimonials from "../components/Testimonials.astro";
import FeatureSection from "../components/FeatureSection.astro";
import Button from "../components/Button.astro";
import ContactForm from "../components/ContactForm.astro";
import ComputerVision from "../components/ComputerVision.astro";
import RecentCaseStudies from "../components/RecentCaseStudies.astro";
import WireframeCube from "../components/WireframeCube.astro";
import PathMapCompare from "../components/PathMapCompare.astro";
import { ArrowRight } from "@lucide/astro";
---

<BaseLayout title="Instant answers with Ask Aura">
  <Nav />

  <Hero />

  <!-- Logo Marquee -->
  <LogoMarquee />

  <!-- Centered Tagline -->
  <section class="pt-24 md:pt-32">
    <div class="mx-auto max-w-site px-6 text-center lg:px-8">
      <h2 class="font-title text-3xl leading-tight tracking-tight md:text-5xl lg:text-6xl text-gradient" data-text="Anonymous full-store analytics using your existing cameras">
        Anonymous full-store analytics using your existing cameras
      </h2>
      <p class="mt-6 text-xl text-white font-medium md:text-2xl">
        No new sensors. No personal data. Just answers.
      </p>
    </div>
  </section>

  <!-- Metrics Grid -->
  <MetricsGrid />

  <!-- Insanely Fast Install -->
  <FeatureSection
    title="Super fast install"
    subtitle="Skip overhead wiring and expensive hardware"
    description="Just plug & play our tiny APU into your store's internet and camera networks and we'll do the rest."
    linkText="How installation works"
  >
    <div slot="visual" class="flex items-center justify-center">
      <WireframeCube />
    </div>
  </FeatureSection>

  <!-- Instant Validation -->
  <FeatureSection
    title="Precise insights"
    subtitle="Move beyond basic and inaccurate foot traffic"
    description="See occupancy the moment cameras connect. Ask Aura any question about your stores and get answers in seconds — no analyst required. Historical trends, live counts, and mobile access all included."
    linkText="See the dashboard"
    reversed
  >
    <PathMapCompare slot="visual" />
  </FeatureSection>

  <!-- Unbelievably Precise Insights -->
  <FeatureSection
    title="Compelling stories"
    subtitle="Bring you closer to customers and staff."
    description="Unbelievably precise insights into who your customers are and how they're interacting with your sales associates."
    linkText="Ask Aura a question"
  >
    <PathMapCompare slot="visual" />
  </FeatureSection>

  <!-- Word Is Out -->
  <Testimonials />

  <!-- Cutting-Edge Computer Vision -->
  <ComputerVision />

  <!-- Recent Case Studies -->
  <RecentCaseStudies />

  <!-- Contact Form -->
  <ContactForm />

  <Footer />
</BaseLayout>


