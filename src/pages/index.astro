---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const caseStudies: CollectionEntry<"case-studies">[] = await getCollection("case-studies");
caseStudies.sort(
  (a: CollectionEntry<"case-studies">, b: CollectionEntry<"case-studies">) =>
    b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout title="Home">
  <!-- Nav -->
  <header class="fixed top-0 inset-x-0 z-50 flex items-center justify-between px-8 py-6">
    <a href="/" class="text-lg font-semibold tracking-tight">Auravision</a>
    <nav class="flex items-center gap-8 text-sm text-white/60">
      <a href="#work" class="hover:text-white transition-colors">Work</a>
      <a href="#about" class="hover:text-white transition-colors">About</a>
      <a href="mailto:hello@auravision.ai" class="hover:text-white transition-colors">Contact</a>
    </nav>
  </header>

  <!-- Hero -->
  <section class="min-h-screen flex flex-col items-center justify-center text-center px-6">
    <p class="text-sm uppercase tracking-widest text-white/40 mb-6">AI · Vision · Intelligence</p>
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight max-w-4xl leading-tight">
      We build AI systems that <em class="not-italic text-white/40">see</em> and <em class="not-italic text-white/40">decide</em>.
    </h1>
    <p class="mt-8 text-lg text-white/50 max-w-xl">
      Auravision partners with ambitious companies to design, build, and deploy production-grade AI solutions.
    </p>
    <div class="mt-12 flex flex-col sm:flex-row gap-4">
      <a
        href="#work"
        class="px-8 py-3 bg-white text-black font-medium rounded-full hover:bg-white/90 transition-colors"
      >
        See our work
      </a>
      <a
        href="mailto:hello@auravision.ai"
        class="px-8 py-3 border border-white/20 rounded-full hover:border-white/50 transition-colors"
      >
        Get in touch
      </a>
    </div>
  </section>

  <!-- Case Studies -->
  <section id="work" class="py-32 px-6 md:px-12 max-w-7xl mx-auto">
    <h2 class="text-xs uppercase tracking-widest text-white/40 mb-16">Selected Work</h2>
    <div class="grid md:grid-cols-2 gap-8">
      {
        caseStudies.map((study) => (
          <a
            href={`/case-studies/${study.slug}/`}
            class="group block border border-white/10 rounded-2xl overflow-hidden hover:border-white/30 transition-colors"
          >
            {study.data.coverImage && (
              <div class="aspect-video bg-white/5 overflow-hidden">
                <img
                  src={study.data.coverImage}
                  alt={study.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}
            <div class="p-8">
              <p class="text-xs text-white/40 uppercase tracking-widest mb-3">
                {study.data.client}
              </p>
              <h3 class="text-xl font-semibold mb-3 group-hover:text-white/80 transition-colors">
                {study.data.title}
              </h3>
              <p class="text-white/50 text-sm leading-relaxed">{study.data.summary}</p>
              {study.data.tags && study.data.tags.length > 0 && (
                <div class="mt-6 flex flex-wrap gap-2">
                  {study.data.tags.map((tag) => (
                    <span class="text-xs px-3 py-1 rounded-full border border-white/10 text-white/40">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-32 px-6 md:px-12 max-w-7xl mx-auto border-t border-white/10">
    <div class="max-w-2xl">
      <h2 class="text-xs uppercase tracking-widest text-white/40 mb-8">About</h2>
      <p class="text-3xl font-medium leading-snug">
        We're a specialist AI studio focused on computer vision, intelligent automation, and production AI systems.
      </p>
      <p class="mt-6 text-white/50 leading-relaxed">
        From initial strategy through to deployed infrastructure, we work end-to-end with our clients — embedding deeply in their teams to ship systems that actually work in the real world.
      </p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-white/10 px-6 md:px-12 py-12 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 text-sm text-white/30">
    <span>© {new Date().getFullYear()} Auravision</span>
    <a href="mailto:hello@auravision.ai" class="hover:text-white transition-colors">
      hello@auravision.ai
    </a>
  </footer>
</BaseLayout>
