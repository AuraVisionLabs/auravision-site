---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import LogoMarquee from "../components/LogoMarquee.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const caseStudies: CollectionEntry<"case-studies">[] = await getCollection("case-studies");
caseStudies.sort(
  (a: CollectionEntry<"case-studies">, b: CollectionEntry<"case-studies">) =>
    b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const latestStudies = caseStudies.slice(0, 3);
---

<BaseLayout title="Instant answers with Ask Aura">
  <Nav />

  <!-- Hero -->
  <section class="relative pt-48 pb-32 overflow-hidden bg-gradient-to-tr from-slate-900 via-indigo-950 to-purple-900">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 w-full">
      <div class="max-w-2xl">
        <h1 class="font-title text-4xl tracking-tight md:text-6xl lg:text-7xl">
          Instantly validate store decisions.
        </h1>
        <p class="mt-8 max-w-lg text-2xl text-white/50 md:text-4xl">
          Introducing <span class="text-white">Ask Aura</span>,<br />your AI retail analyst.
        </p>
        <div class="mt-12">
          <a
            href="/contact"
            class="inline-flex items-center rounded-full bg-purple-600 px-10 py-4 text-base font-title tracking-[0.05em] text-lg text-white transition-colors hover:bg-accent-muted"
          >
            See it in action
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Logo Marquee -->
  <LogoMarquee />

  <!-- Capability Row -->
  <section class="mx-auto max-w-7xl px-6 py-24 lg:px-8">
    <div class="grid grid-cols-3 gap-8">
      <div class="flex flex-col items-center text-center">
        <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-accent/10">
          <svg class="h-7 w-7 text-accent-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128H9m6 0a5.972 5.972 0 0 0-.786-3.07M9 19.128A9.38 9.38 0 0 1 6.375 19.5a9.337 9.337 0 0 1-4.121-.952 4.125 4.125 0 0 1 7.533-2.493M9 19.128v-.003c0-1.113.285-2.16.786-3.07m0 0a5.838 5.838 0 0 1 .786-.231" />
          </svg>
        </div>
        <p class="font-title text-sm md:text-base text-white/70">Enhanced Footfall</p>
      </div>
      <div class="flex flex-col items-center text-center">
        <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-accent/10">
          <svg class="h-7 w-7 text-accent-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
          </svg>
        </div>
        <p class="font-title text-sm md:text-base text-white/70">Path to Purchase</p>
      </div>
      <div class="flex flex-col items-center text-center">
        <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-accent/10">
          <svg class="h-7 w-7 text-accent-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
          </svg>
        </div>
        <p class="font-title text-sm md:text-base text-white/70">Brand Performance</p>
      </div>
    </div>
  </section>

  <!-- Split: Enhanced Footfall (text left, visual right) -->
  <section class="py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid items-center gap-16 md:grid-cols-2">
        <div>
          <p class="text-xs font-medium uppercase tracking-widest text-accent-light/60 mb-4">Enhanced Footfall</p>
          <h2 class="font-title text-3xl leading-snug tracking-tight md:text-4xl">
            Know exactly who enters, when they arrive, and how long they stay
          </h2>
          <p class="mt-6 text-base leading-relaxed text-white/50">
            Make staffing and layout decisions backed by real data, not guesswork. Auravision counts every visitor with camera-level accuracy and surfaces trends the moment they emerge.
          </p>
          <a href="/contact" class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-accent-light transition-colors hover:text-white">
            Learn more
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
        <div class="flex items-center justify-center rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm aspect-video">
          <p class="text-sm text-white/20">Screenshot coming soon</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Split: Path to Purchase (visual left, text right) -->
  <section class="border-t border-white/10 py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid items-center gap-16 md:grid-cols-2">
        <div class="order-2 md:order-1 flex items-center justify-center rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm aspect-video">
          <p class="text-sm text-white/20">Screenshot coming soon</p>
        </div>
        <div class="order-1 md:order-2">
          <p class="text-xs font-medium uppercase tracking-widest text-accent-light/60 mb-4">Path to Purchase</p>
          <h2 class="font-title text-3xl leading-snug tracking-tight md:text-4xl">
            Trace every customer journey through your store
          </h2>
          <p class="mt-6 text-base leading-relaxed text-white/50">
            Identify high-traffic zones, dead spots, and conversion bottlenecks with precision. See exactly how shoppers move from entrance to checkout — and where they drop off.
          </p>
          <a href="/contact" class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-accent-light transition-colors hover:text-white">
            Learn more
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Split: Brand Performance (text left, visual right) -->
  <section class="border-t border-white/10 py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid items-center gap-16 md:grid-cols-2">
        <div>
          <p class="text-xs font-medium uppercase tracking-widest text-accent-light/60 mb-4">Brand Performance</p>
          <h2 class="font-title text-3xl leading-snug tracking-tight md:text-4xl">
            Unified dashboards that tie it all together
          </h2>
          <p class="mt-6 text-base leading-relaxed text-white/50">
            Footfall, dwell time, and conversion in one picture. Ask Aura any question about your stores and get answers in seconds — no analyst required.
          </p>
          <a href="/contact" class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-accent-light transition-colors hover:text-white">
            Learn more
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
        <div class="flex items-center justify-center rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm aspect-video">
          <p class="text-sm text-white/20">Screenshot coming soon</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="border-t border-white/10 py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <p class="text-xs font-medium uppercase tracking-widest text-accent-light/60 mb-4">What our clients say</p>
      <h2 class="font-title text-4xl tracking-tight md:text-5xl mb-16">Trusted by leading retailers</h2>

      <div class="flex gap-8 overflow-x-auto snap-x snap-mandatory pb-4 -mx-6 px-6 scrollbar-none">
        <!-- Quote 1 -->
        <div class="min-w-[340px] max-w-[400px] flex-shrink-0 snap-start rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm p-8">
          <svg class="h-8 w-8 text-accent/30 mb-6" viewBox="0 0 24 24" fill="currentColor"><path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" /></svg>
          <p class="text-base leading-relaxed text-white/70 mb-8">
            "Auravision transformed how we understand our stores. We went from guessing to knowing — and our conversion rates show it."
          </p>
          <div>
            <p class="font-medium text-white/90">Client Name</p>
            <p class="text-sm text-white/40">Role, Company</p>
          </div>
        </div>

        <!-- Quote 2 -->
        <div class="min-w-[340px] max-w-[400px] flex-shrink-0 snap-start rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm p-8">
          <svg class="h-8 w-8 text-accent/30 mb-6" viewBox="0 0 24 24" fill="currentColor"><path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" /></svg>
          <p class="text-base leading-relaxed text-white/70 mb-8">
            "The ease of deployment is exactly what we needed. Ask Aura gives our team answers in seconds instead of waiting days for reports."
          </p>
          <div>
            <p class="font-medium text-white/90">Client Name</p>
            <p class="text-sm text-white/40">Role, Company</p>
          </div>
        </div>

        <!-- Quote 3 -->
        <div class="min-w-[340px] max-w-[400px] flex-shrink-0 snap-start rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm p-8">
          <svg class="h-8 w-8 text-accent/30 mb-6" viewBox="0 0 24 24" fill="currentColor"><path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" /></svg>
          <p class="text-base leading-relaxed text-white/70 mb-8">
            "Privacy-first analytics that actually work at scale. Auravision is the only solution we found that checked every box."
          </p>
          <div>
            <p class="font-medium text-white/90">Client Name</p>
            <p class="text-sm text-white/40">Role, Company</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section id="case-studies" class="border-t border-white/10 py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-16 flex items-end justify-between">
        <div>
          <p class="text-xs font-medium uppercase tracking-widest text-accent-light/60 mb-4">Results</p>
          <h2 class="font-title text-4xl tracking-tight md:text-5xl">Case Studies</h2>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {latestStudies.map((study) => (
          <a
            href={`/case-studies/${study.slug}/`}
            class="group block overflow-hidden rounded-2xl border border-white/5 bg-white/[0.03] backdrop-blur-sm transition-all hover:border-white/15 hover:bg-white/[0.06]"
          >
            {study.data.coverImage ? (
              <div class="aspect-video overflow-hidden bg-white/5">
                <img
                  src={study.data.coverImage}
                  alt={study.data.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>
            ) : (
              <div class="aspect-video bg-white/5"></div>
            )}
            <div class="p-6">
              <p class="mb-2 text-xs uppercase tracking-widest text-white/40">
                {study.data.client}
              </p>
              <h3 class="font-title text-lg mb-2 transition-colors group-hover:text-white/80">
                {study.data.title}
              </h3>
              <p class="text-sm leading-relaxed text-white/50">{study.data.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About / Why Auravision -->
  <section id="about" class="border-t border-white/10 py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl mb-20">
        <p class="text-xs font-medium uppercase tracking-widest text-accent-light/60 mb-4">Why Auravision</p>
        <h2 class="font-title text-4xl leading-snug tracking-tight md:text-5xl">
          Retail intelligence you can trust at any scale
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-white/50">
          We built Auravision for retailers who need answers, not more data. Our platform turns existing camera infrastructure into an always-on analytics layer — without capturing or storing personal data.
        </p>
      </div>

      <div class="grid gap-12 md:grid-cols-3">
        <div>
          <div class="mb-4 text-3xl font-title text-white/80">Scalable</div>
          <p class="text-sm leading-relaxed text-white/50">
            From a single store to thousands of locations. Our edge-first architecture scales with you, not against you.
          </p>
        </div>
        <div>
          <div class="mb-4 text-3xl font-title text-white/80">Secure</div>
          <p class="text-sm leading-relaxed text-white/50">
            Enterprise-grade encryption, SOC 2 compliance, and on-premise deployment options. Your data stays yours.
          </p>
        </div>
        <div>
          <div class="mb-4 text-3xl font-title text-white/80">Anonymous</div>
          <p class="text-sm leading-relaxed text-white/50">
            Privacy by design. We count and track movement patterns without identifying individuals. GDPR-compliant from day one.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-white/10 py-32">
    <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
      <h2 class="font-title text-4xl tracking-tight md:text-5xl">
        Ready to transform your retail intelligence?
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg text-white/50">
        See how Ask Aura can give your team instant, actionable insights from your existing camera infrastructure.
      </p>
      <a
        href="/contact"
        class="mt-10 inline-flex items-center rounded-full bg-accent px-10 py-4 text-base font-medium text-white transition-colors hover:bg-accent-muted"
      >
        Book a Demo
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
