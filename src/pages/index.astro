---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import LogoMarquee from "../components/LogoMarquee.astro";
import Hero from "../components/Hero.astro";
import MetricsGrid from "../components/MetricsGrid.astro";
import Testimonials from "../components/Testimonials.astro";
import FeatureSection from "../components/FeatureSection.astro";
import Button from "../components/Button.astro";
import ContactForm from "../components/ContactForm.astro";
import ComputerVision from "../components/ComputerVision.astro";
import RecentCaseStudies from "../components/RecentCaseStudies.astro";
import WireframeCube from "../components/WireframeCube.astro";
import PathMapCompare from "../components/PathMapCompare.astro";
import { ArrowRight } from "@lucide/astro";
import ChatAnimation from "../components/ChatAnimation.astro";
---

<BaseLayout title="AI-Powered Retail Analytics From Your Existing Cameras">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://auravision.ai/#organization",
        "name": "Aura Vision",
        "url": "https://auravision.ai",
        "logo": {
          "@type": "ImageObject",
          "url": "https://auravision.ai/images/aura-vision-logo.svg"
        },
        "description": "AI-powered retail analytics from your existing cameras. No new sensors. No personal data. Just answers.",
        "foundingDate": "2017",
        "founders": [
          { "@type": "Person", "name": "Daniel" },
          { "@type": "Person", "name": "Jaime" }
        ],
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "81 Rivington Street",
          "addressLocality": "London",
          "postalCode": "EC2A 3AY",
          "addressCountry": "GB"
        },
        "sameAs": [
          "https://www.linkedin.com/company/auravisionlabs"
        ],
        "knowsAbout": ["Computer Vision", "Retail Analytics", "Machine Learning", "In-Store Analytics", "Footfall Counting", "Customer Journey Mapping", "Privacy-Preserving AI"]
      },
      {
        "@type": "WebSite",
        "@id": "https://auravision.ai/#website",
        "url": "https://auravision.ai",
        "name": "Aura Vision",
        "publisher": { "@id": "https://auravision.ai/#organization" },
        "description": "AI-powered retail analytics from your existing cameras. No new sensors. No personal data. Just answers."
      },
      {
        "@type": "SoftwareApplication",
        "name": "Ask Aura",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web",
        "description": "AI-powered natural language interface for instant retail analytics insights from your existing cameras.",
        "offers": {
          "@type": "Offer",
          "availability": "https://schema.org/OnlineOnly"
        },
        "creator": { "@id": "https://auravision.ai/#organization" }
      }
    ]
  })} />
  <Nav />

  <Hero />

  <!-- Logo Marquee -->
  <LogoMarquee />

  <!-- Centered Tagline -->
  <section class="pt-24 md:pt-32">
    <div data-fade="400" class="container-site text-center">
      <h2 class="heading-section leading-tight text-gradient" data-text="Anonymous full-store analytics using your existing cameras">
        Anonymous full-store analytics using your existing cameras
      </h2>
      <p class="mt-6 text-xl text-white font-medium md:text-2xl">
        No new sensors. No personal data. Just answers.
      </p>
    </div>
  </section>

  <!-- Metrics Grid -->
  <MetricsGrid />

  <!-- Insanely Fast Install -->
  <FeatureSection
    title="Super fast install"
    subtitle="Skip buying more expensive hardware and overhead wiring."
    description="Just <span class='font-black text-white'>plug & play</span> our tiny APU into your store's internet and camera networks and we'll do the rest."
  >
    <div slot="visual" class="flex items-center justify-center">
      <WireframeCube />
    </div>
  </FeatureSection>

  <!-- Instant Validation -->
  <FeatureSection
    title="Precise insights"
    subtitle="Never miss a moment with your customers and staff in-store."
    description="Your <span class='font-black text-white'>tailored AI</span> ensures every journey is measured accurately, segmented by age, gender and staff."
    reversed
  >
    <PathMapCompare slot="visual" />
  </FeatureSection>

  <!-- Unbelievably Precise Insights -->
  <FeatureSection
    title="Instant answers"
    subtitle="The wait to interpret data is over."
    description="<span class='font-black text-white'>Ask Aura</span> enables your teams to build compelling narratives to take immediate action on any decision."
  >
    <ChatAnimation slot="visual" />
  </FeatureSection>

  <!-- Word Is Out -->
  <Testimonials />

  <!-- Cutting-Edge Computer Vision -->
  <ComputerVision />

  <!-- Recent Case Studies -->
  <RecentCaseStudies />

  <!-- Contact Form -->
  <ContactForm title="Switching doesn't have to be daunting" subtitle="Let's talk it through together." />

  <Footer />
</BaseLayout>


