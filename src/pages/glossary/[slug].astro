---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import GlossaryCard from "../../components/GlossaryCard.astro";
import CTABanner from "../../components/CTABanner.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { ArrowLeft } from "@lucide/astro";
import { marked } from "marked";

export async function getStaticPaths() {
  const entries = await getCollection("glossary");
  return entries.map((entry: CollectionEntry<"glossary">) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"glossary">;
}

const { entry } = Astro.props;

const content = await marked.parse(entry.body ?? "");

// Resolve related glossary entries
const allEntries = await getCollection("glossary");
const relatedEntries = allEntries.filter((e) =>
  (entry.data.relatedTerms ?? []).includes(e.slug)
);

// Resolve related case studies
const allCaseStudies = await getCollection("case-studies");
const relatedCaseStudies = allCaseStudies.filter((cs) =>
  (entry.data.relatedCaseStudies ?? []).includes(cs.slug)
);

// Resolve related blog posts
const allBlogPosts = await getCollection("blog");
const relatedBlogPosts = allBlogPosts.filter((bp) =>
  (entry.data.relatedBlogPosts ?? []).includes(bp.slug)
);

const categoryLabels: Record<string, string> = {
  analytics: "Analytics & Metrics",
  technology: "Technology",
  privacy: "Privacy & Compliance",
  operations: "Retail Operations",
};

// Schema.org: DefinedTerm
const definedTermSchema = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  name: entry.data.title.replace(/^What is |[?]$/g, ""),
  description: entry.data.description,
  url: `https://auravision.ai/glossary/${entry.slug}`,
  inDefinedTermSet: {
    "@type": "DefinedTermSet",
    name: "Retail Analytics Glossary",
    url: "https://auravision.ai/glossary",
  },
};

// Schema.org: FAQPage (if FAQs present)
const faqSchema =
  entry.data.faq && entry.data.faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: entry.data.faq.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      }
    : null;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://auravision.ai",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Glossary",
      item: "https://auravision.ai/glossary",
    },
    { "@type": "ListItem", position: 3, name: entry.data.title },
  ],
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogType="article"
  publishedTime={entry.data.publishedDate.toISOString()}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(definedTermSchema)}
  />
  {
    faqSchema && (
      <script
        slot="head"
        type="application/ld+json"
        set:html={JSON.stringify(faqSchema)}
      />
    )
  }
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  <Nav />

  <main class="page-padding">
    <div class="container-site">
      <!-- Back link -->
      <a
        href="/glossary"
        class="inline-flex items-center gap-2 rounded-full border border-white/20 px-5 py-2 text-sm text-white/60 hover:bg-white/10 hover:text-white transition-all duration-300 mb-10 group"
      >
        <ArrowLeft
          class="w-4 h-4 transition-transform group-hover:-translate-x-1"
        />
        All glossary terms
      </a>

      <!-- Title block -->
      <div class="mb-8">
        <div class="flex items-center gap-4 mb-4">
          <span
            class:list={[
              "text-xs font-medium px-3 py-1 rounded-full capitalize",
              entry.data.category === "analytics" &&
                "bg-cyan-500/10 text-cyan-400",
              entry.data.category === "technology" &&
                "bg-violet-500/10 text-violet-400",
              entry.data.category === "privacy" &&
                "bg-emerald-500/10 text-emerald-400",
              entry.data.category === "operations" &&
                "bg-amber-500/10 text-amber-400",
            ]}
          >
            {categoryLabels[entry.data.category]}
          </span>
        </div>
        <h1
          class="font-title font-normal text-3xl md:text-4xl lg:text-5xl tracking-tight leading-tight mb-4 text-gradient"
          data-text={entry.data.title}
        >
          {entry.data.title}
        </h1>
        <p class="text-lg text-white/50 leading-relaxed max-w-3xl">
          {entry.data.description}
        </p>
      </div>

      <!-- Article body -->
      <article class="case-study-prose mx-auto max-w-3xl">
        <Fragment set:html={content} />
      </article>

      <!-- FAQ Section -->
      {
        entry.data.faq && entry.data.faq.length > 0 && (
          <section class="mx-auto max-w-3xl mt-16 pt-12 border-t border-white/10">
            <h2 class="font-title text-2xl tracking-tight mb-8 text-white/80">
              Frequently asked questions
            </h2>
            <div class="space-y-4">
              {entry.data.faq.map((item) => (
                <details class="group rounded-xl border border-white/10 bg-white/[0.03] backdrop-blur-sm overflow-hidden">
                  <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 text-white/90 font-medium hover:bg-white/[0.03] transition-colors">
                    <span>{item.question}</span>
                    <span class="shrink-0 text-white/30 text-xl leading-none transition-transform duration-200 group-open:rotate-45">
                      +
                    </span>
                  </summary>
                  <div class="px-6 pb-5 text-sm text-white/60 leading-relaxed">
                    {item.answer}
                  </div>
                </details>
              ))}
            </div>
          </section>
        )
      }

      <!-- Related case studies -->
      {
        relatedCaseStudies.length > 0 && (
          <section class="mx-auto max-w-3xl mt-16 pt-12 border-t border-white/10">
            <h2 class="font-title text-2xl tracking-tight mb-6 text-white/80">
              Related case studies
            </h2>
            <div class="flex flex-wrap gap-3">
              {relatedCaseStudies.map((cs) => (
                <a
                  href={`/case-studies/${cs.slug}`}
                  class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-5 py-2 text-sm text-white/60 hover:bg-white/[0.06] hover:border-cyan-400/30 hover:text-white transition-all duration-300"
                >
                  {cs.data.title}
                </a>
              ))}
            </div>
          </section>
        )
      }

      <!-- Related blog posts -->
      {
        relatedBlogPosts.length > 0 && (
          <section class="mx-auto max-w-3xl mt-12">
            <h2 class="font-title text-2xl tracking-tight mb-6 text-white/80">
              Further reading
            </h2>
            <div class="flex flex-wrap gap-3">
              {relatedBlogPosts.map((bp) => (
                <a
                  href={`/blog/${bp.slug}`}
                  class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-5 py-2 text-sm text-white/60 hover:bg-white/[0.06] hover:border-cyan-400/30 hover:text-white transition-all duration-300"
                >
                  {bp.data.title}
                </a>
              ))}
            </div>
          </section>
        )
      }

      <!-- Related glossary terms -->
      {
        relatedEntries.length > 0 && (
          <div class="mt-20 pt-12">
            <h2 class="font-title text-2xl tracking-tight mb-8 text-white/80">
              Related terms
            </h2>
            <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
              {relatedEntries.map((r) => (
                <GlossaryCard
                  slug={r.slug}
                  title={r.data.title}
                  description={r.data.description}
                  category={r.data.category}
                />
              ))}
            </div>
          </div>
        )
      }
    </div>
  </main>

  <CTABanner
    heading="See it in action"
    subheading="Discover how Aura Vision turns your existing cameras into powerful retail analytics."
  />

  <Footer />
</BaseLayout>
