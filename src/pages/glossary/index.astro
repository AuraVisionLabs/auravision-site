---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import GlossaryCard from "../../components/GlossaryCard.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("glossary");
const sorted = entries.sort((a, b) => a.data.title.localeCompare(b.data.title));

const categoryOrder = ["analytics", "technology", "privacy", "operations"] as const;
const categoryLabels: Record<string, string> = {
  analytics: "Analytics & Metrics",
  technology: "Technology",
  privacy: "Privacy & Compliance",
  operations: "Retail Operations",
};

const grouped = categoryOrder
  .map((cat) => ({
    key: cat,
    label: categoryLabels[cat],
    items: sorted.filter((e) => e.data.category === cat),
  }))
  .filter((g) => g.items.length > 0);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Retail Analytics Glossary | Aura Vision",
  description:
    "Definitions and explanations of key retail analytics, computer vision, and in-store intelligence terms.",
  url: "https://auravision.ai/glossary",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: sorted.map((entry, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: entry.data.title,
      url: `https://auravision.ai/glossary/${entry.slug}`,
    })),
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://auravision.ai",
    },
    { "@type": "ListItem", position: 2, name: "Glossary" },
  ],
};
---

<BaseLayout
  title="Retail Analytics Glossary"
  description="Definitions and explanations of key retail analytics, computer vision, and in-store intelligence terms."
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(itemListSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  <Nav />

  <main class="page-padding">
    <div class="container-site">
      <!-- Header -->
      <div class="mb-16 max-w-3xl">
        <h1
          class="heading-section text-gradient"
          data-text="Retail Analytics Glossary"
        >
          Retail Analytics Glossary
        </h1>
        <p class="mt-4 text-lg text-white/50 leading-relaxed">
          Clear, concise definitions of the key concepts behind in-store
          analytics, computer vision, and retail intelligence.
        </p>
      </div>

      <!-- Grouped sections -->
      {
        grouped.map((group) => (
          <section class="mb-16">
            <h2 class="font-title text-2xl tracking-tight mb-8 text-white/80">
              {group.label}
            </h2>
            <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
              {group.items.map((entry) => (
                <GlossaryCard
                  slug={entry.slug}
                  title={entry.data.title}
                  description={entry.data.description}
                  category={entry.data.category}
                  headingLevel="h3"
                />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </main>

  <Footer />
</BaseLayout>
